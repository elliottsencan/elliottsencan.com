---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import Link from "@components/Link.astro";
import Layout from "@layouts/Layout.astro";

const work = (await getCollection("work"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.dateStart.valueOf() - a.data.dateStart.valueOf());
---

<Layout title="Work" description="Professional experience and roles.">
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-10">
        <h1 class="font-heading text-3xl font-medium text-black dark:text-white">
          Work
        </h1>
        {
          work.length > 0 ? (
            <ul class="space-y-8">
              {work.map((entry) => (
                <li class="border-l-2 border-black/10 pl-4 dark:border-white/15">
                  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                    <h2 class="font-heading text-lg font-medium text-black dark:text-white">
                      {entry.data.role}
                    </h2>
                    <span class="text-xs text-neutral-500">
                      <FormattedDate date={entry.data.dateStart} />
                      {" — "}
                      {entry.data.dateEnd ? (
                        <FormattedDate date={entry.data.dateEnd} />
                      ) : (
                        "Present"
                      )}
                    </span>
                  </div>
                  <div class="text-sm">
                    {entry.data.url ? (
                      <Link href={entry.data.url} external>
                        {entry.data.company}
                      </Link>
                    ) : (
                      entry.data.company
                    )}
                  </div>
                  <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
                    {entry.data.description}
                  </p>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-neutral-500">Coming soon.</p>
          )
        }
      </div>
    </aside>
  </Container>
</Layout>
