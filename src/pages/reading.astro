---
import { type CollectionEntry, getCollection } from "astro:content";
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import HeroMeta from "@components/HeroMeta.astro";
import Link from "@components/Link.astro";
import PageHero from "@components/PageHero.astro";
import Layout from "@layouts/Layout.astro";
import { monthKey, SITE_TIMEZONE } from "@lib/utils";

// Reading log — the per-source citation index. Every entry is public; the
// site-ingest worker commits a markdown file to src/content/reading/{YYYY-MM}/
// each time the mobile shortcut pings /link with a URL. Anthropic drafts the
// summary, category, and topics; nothing is hand-edited post-commit unless I
// decide to. Cross-source synthesis (one article per concept, drawing on
// multiple sources from this index) lives at /wiki.
const entries = (await getCollection("reading")).sort(
  (a, b) => b.data.added.valueOf() - a.data.added.valueOf(),
);

// Forward-link from reading → wiki. When a reading entry contributed sources
// to one or more wiki articles, the entry-level page already shows a "cited
// by" section; here we lift the same query up to the index so the through-
// line (raw input → synthesis) is visible without clicking in.
const wikiCitations = await getCollection("wiki");
const citingByEntry = new Map<string, { id: string; title: string }[]>();
for (const concept of wikiCitations) {
  for (const source of concept.data.sources) {
    const list = citingByEntry.get(source);
    const ref = { id: concept.id, title: concept.data.title };
    if (list) {
      list.push(ref);
    } else {
      citingByEntry.set(source, [ref]);
    }
  }
}

type Entry = CollectionEntry<"reading">;

function monthLabel(key: string): string {
  const [year, month] = key.split("-").map(Number);
  const date = new Date(Date.UTC(year, month - 1, 1, 12));
  return `${date.toLocaleString("en-US", { month: "long", timeZone: "UTC" })} ${year}`;
}

// Group into ordered buckets by month, preserving reverse-chron order so
// the first bucket is the most recent month and entries within it are
// newest-first.
type Bucket = { key: string; label: string; entries: Entry[] };
const buckets: Bucket[] = [];
for (const entry of entries) {
  const key = monthKey(entry.id);
  const last = buckets[buckets.length - 1];
  if (last && last.key === key) {
    last.entries.push(entry);
  } else {
    buckets.push({ key, label: monthLabel(key), entries: [entry] });
  }
}

const years = [...new Set(entries.map((e) => monthKey(e.id).slice(0, 4)))].sort((a, b) =>
  b.localeCompare(a),
);

// Format in the site's time zone — entry.data.added is the same instant
// regardless of representation (UTC `Z` or Pacific offset), but rendering it
// without `timeZone` falls back to the build container's TZ (UTC on
// Cloudflare Pages) and an entry stamped 23:22 PDT renders as the next day.
const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
  timeZone: SITE_TIMEZONE,
});

// Compact mono-strip date for the mobile (<md) caption row: "May 04". The
// desktop column above keeps the long format.
const compactDateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "2-digit",
  month: "short",
  timeZone: SITE_TIMEZONE,
});

const lastAdded = entries[0]?.data.added;
const heroMetaFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "short",
  year: "numeric",
  timeZone: SITE_TIMEZONE,
});
const heroMetaLabel = lastAdded
  ? `${entries.length} source${entries.length === 1 ? "" : "s"} · ${heroMetaFormatter.format(lastAdded)}`
  : `${entries.length} source${entries.length === 1 ? "" : "s"}`;
---

<Layout
  title="Reading"
  description="Articles, essays, and books I've been reading."
>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:Reading"
    >
      <PageHero>
        <Fragment slot="title">Reading</Fragment>
        <Fragment slot="summary">
          Per-source citation index. Each entry is one URL with a short
          AI-compiled summary and topic tags. Cross-source synthesis lives at
          the <Link href="/wiki">wiki</Link>, where any concept with two or
          more contributing sources gets a compiled article.
        </Fragment>
        <HeroMeta slot="meta" count={entries.length} label={heroMetaLabel} />
      </PageHero>

      {
        years.length > 1 && (
          <nav
            class="flex flex-wrap items-baseline gap-x-3 gap-y-1 font-mono text-xs uppercase tracking-wider text-black/55 dark:text-white/55"
            aria-label="Archive by year"
          >
            <span>Archive:</span>
            {years.map((y, i) => (
              <>
                <Link href={`/reading/${y}/`} class="font-sans text-xs">
                  {y}
                </Link>
                {i < years.length - 1 && <span aria-hidden="true">·</span>}
              </>
            ))}
          </nav>
        )
      }

      {
        buckets.length > 0 ? (
          buckets.map((bucket, bucketIndex) => (
            <section class="space-y-6">
              <h2
                class="font-heading text-sm font-medium text-black/65 dark:text-white/65"
              >
                {bucket.label}
              </h2>
              <ul class="not-prose flex flex-col gap-3 text-sm md:gap-3">
                {bucket.entries.map((entry) => {
                  const sourceLine = [entry.data.author, entry.data.source]
                    .filter(Boolean)
                    .join(", ");
                  const citings = citingByEntry.get(entry.id) ?? [];
                  return (
                    <li class="group relative flex flex-col gap-2 py-2 md:flex-row md:items-baseline md:gap-4 md:py-3">
                      {/* Desktop date column. Hidden below md so the mobile
                          variant can promote the date into the caption strip
                          where it belongs. */}
                      <time
                        datetime={entry.data.added.toISOString()}
                        class="hidden w-32 shrink-0 font-sans text-xs text-black/50 md:block dark:text-white/60"
                      >
                        {dateFormatter.format(entry.data.added)}
                      </time>
                      <div class="flex-1 space-y-1.5">
                        {/* Mobile: title-led row with the source pinned to
                            the right (truncated). On md+ the source drops
                            back to its own line under the title. */}
                        <div class="flex items-baseline justify-between gap-3 md:block">
                          {/* Title carries the stretched-link pseudo: clicking
                              anywhere on the row routes to the source URL
                              (same destination as the title text). The cited-
                              in links below opt out via relative z-10 so
                              they remain independently clickable. */}
                          <Link
                            href={entry.data.url}
                            external
                            class="font-heading text-lg font-medium tracking-[-0.011em] text-black transition-colors hover:text-[color:var(--accent)] before:absolute before:inset-y-0 before:-inset-x-3 before:rounded-md before:content-[''] md:before:-inset-x-4 dark:text-white"
                          >
                            {entry.data.title}
                          </Link>
                          {sourceLine && (
                            <span class="max-w-[40%] shrink-0 truncate text-xs text-black/55 md:hidden dark:text-white/60">
                              {sourceLine}
                            </span>
                          )}
                        </div>
                        {sourceLine && (
                          <p class="hidden text-xs text-black/55 md:block dark:text-white/60">
                            {sourceLine}
                          </p>
                        )}
                        <p class="leading-relaxed text-black/75 dark:text-white/75">
                          {entry.data.summary}
                        </p>
                        {/* Mobile caption strip: monospace, dot-separated.
                            Promotes date into the row, keeps the cited-in
                            link as the accent-tinted final segment. */}
                        <div class="flex flex-wrap items-center gap-x-2.5 gap-y-1 pt-1 font-mono text-xs tracking-wider text-black/55 md:hidden dark:text-white/55">
                          <time datetime={entry.data.added.toISOString()}>
                            {compactDateFormatter.format(entry.data.added)}
                          </time>
                          <span aria-hidden="true" class="size-0.5 rounded-full bg-black/40 dark:bg-white/40" />
                          <span class="lowercase text-black/65 dark:text-white/65">
                            {entry.data.category}
                          </span>
                          {citings.map((ref) => (
                            <>
                              <span aria-hidden="true" class="size-0.5 rounded-full bg-black/40 dark:bg-white/40" />
                              <a
                                href={`/wiki/${ref.id}/`}
                                class="relative z-10 text-[color:var(--accent)] no-underline hover:underline"
                              >
                                cited in /wiki/{ref.id}
                              </a>
                            </>
                          ))}
                        </div>
                        {/* Desktop meta row keeps the existing chip + arrow
                            treatment. Hidden on mobile in favour of the
                            mono caption above. */}
                        <div class="hidden flex-wrap items-center gap-x-3 gap-y-1.5 pt-1 md:flex">
                          <span class="inline-flex items-center rounded-sm bg-black/5 px-2 py-0.5 text-xs capitalize text-black/65 dark:bg-white/5 dark:text-white/65">
                            {entry.data.category}
                          </span>
                          {citings.map((ref) => (
                            <span class="inline-flex items-baseline gap-1 font-mono text-xs text-[color:var(--accent)]">
                              <span aria-hidden="true">→</span>
                              <a
                                href={`/wiki/${ref.id}/`}
                                class="relative z-10 font-sans text-xs underline decoration-[color:var(--accent)]/40 underline-offset-[3px] hover:decoration-[color:var(--accent)]"
                              >
                                cited in /wiki/{ref.id}
                              </a>
                            </span>
                          ))}
                        </div>
                      </div>
                    </li>
                  );
                })}
              </ul>
              {bucketIndex < buckets.length - 1 && <EditorialRule />}
            </section>
          ))
        ) : (
          <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
            Nothing here yet. The pipeline is wired up — as soon as I start
            saving links from my phone, they'll appear here.
          </p>
        )
      }

      <EditorialRule />

      <p class="text-xs text-black/55 dark:text-white/55">
        <Link href="/wiki">wiki →</Link>
      </p>
    </div>
  </Container>
</Layout>
