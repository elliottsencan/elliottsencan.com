---
import { type CollectionEntry, getCollection } from "astro:content";
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import Layout from "@layouts/Layout.astro";
import { monthKey } from "@lib/utils";

// Reading log — the per-source citation index. Every entry is public; the
// site-ingest worker commits a markdown file to src/content/reading/{YYYY-MM}/
// each time the mobile shortcut pings /link with a URL. Anthropic drafts the
// summary, category, and topics; nothing is hand-edited post-commit unless I
// decide to. Cross-source synthesis (one article per concept, drawing on
// multiple sources from this index) lives at /wiki.
const entries = (await getCollection("reading")).sort(
  (a, b) => b.data.added.valueOf() - a.data.added.valueOf(),
);

type Entry = CollectionEntry<"reading">;

function monthLabel(key: string): string {
  const [year, month] = key.split("-").map(Number);
  const date = new Date(Date.UTC(year, month - 1, 1, 12));
  return `${date.toLocaleString("en-US", { month: "long", timeZone: "UTC" })} ${year}`;
}

// Group into ordered buckets by month, preserving reverse-chron order so
// the first bucket is the most recent month and entries within it are
// newest-first.
type Bucket = { key: string; label: string; entries: Entry[] };
const buckets: Bucket[] = [];
for (const entry of entries) {
  const key = monthKey(entry.id);
  const last = buckets[buckets.length - 1];
  if (last && last.key === key) {
    last.entries.push(entry);
  } else {
    buckets.push({ key, label: monthLabel(key), entries: [entry] });
  }
}

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout
  title="Reading"
  description="Articles, essays, and books I've been reading."
>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:Reading"
    >
      <LabeledRule>Reading</LabeledRule>

      <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
        Per-source citation index. Each entry is one URL with a short
        AI-compiled summary and topic tags. Cross-source synthesis lives at the{" "}
        <Link href="/wiki">wiki</Link>, where any concept with two or more
        contributing sources gets a compiled article.
      </p>

      {
        buckets.length > 0 ? (
          buckets.map((bucket, bucketIndex) => (
            <section class="space-y-6">
              <h2
                class="font-heading text-sm font-medium text-black/65 dark:text-white/65"
              >
                {bucket.label}
              </h2>
              <ul class="not-prose flex flex-col gap-6 text-sm">
                {bucket.entries.map((entry) => (
                  <li class="flex items-baseline gap-4">
                    <time
                      datetime={entry.data.added.toISOString()}
                      class="shrink-0 font-sans text-xs text-black/50 dark:text-white/60"
                    >
                      {dateFormatter.format(entry.data.added)}
                    </time>
                    <div class="flex-1 space-y-1.5">
                      <Link
                        href={entry.data.url}
                        external
                        class="font-heading font-medium text-black dark:text-white"
                      >
                        {entry.data.title}
                      </Link>
                      {(entry.data.author || entry.data.source) && (
                        <p class="text-xs text-black/55 dark:text-white/60">
                          {[entry.data.author, entry.data.source]
                            .filter(Boolean)
                            .join(", ")}
                        </p>
                      )}
                      <p class="leading-relaxed text-black/75 dark:text-white/75">
                        {entry.data.summary}
                      </p>
                      <div class="pt-1">
                        <span class="inline-flex items-center rounded-sm bg-black/5 px-2 py-0.5 text-xs capitalize text-black/65 dark:bg-white/5 dark:text-white/65">
                          {entry.data.category}
                        </span>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
              {bucketIndex < buckets.length - 1 && <EditorialRule />}
            </section>
          ))
        ) : (
          <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
            Nothing here yet. The pipeline is wired up — as soon as I start
            saving links from my phone, they'll appear here.
          </p>
        )
      }
    </div>
  </Container>
</Layout>
