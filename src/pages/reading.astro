---
import { type CollectionEntry, getCollection } from "astro:content";
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import Layout from "@layouts/Layout.astro";

// Reading log. Every entry is public — the site-ingest worker commits a
// markdown file to src/content/reading/{YYYY-MM}/ each time the mobile
// shortcut pings /link with a URL. Anthropic drafts the summary + category;
// nothing is hand-edited post-commit unless I decide to.
const entries = (await getCollection("reading")).sort(
  (a, b) => b.data.added.valueOf() - a.data.added.valueOf(),
);

type Entry = CollectionEntry<"reading">;

function monthKey(date: Date): string {
  return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}`;
}

function monthLabel(date: Date): string {
  return `${date.toLocaleString("en-US", { month: "long" })} ${date.getFullYear()}`;
}

// Group into ordered buckets by month, preserving reverse-chron order so
// the first bucket is the most recent month and entries within it are
// newest-first.
type Bucket = { key: string; label: string; entries: Entry[] };
const buckets: Bucket[] = [];
for (const entry of entries) {
  const key = monthKey(entry.data.added);
  const last = buckets[buckets.length - 1];
  if (last && last.key === key) {
    last.entries.push(entry);
  } else {
    buckets.push({ key, label: monthLabel(entry.data.added), entries: [entry] });
  }
}

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
});
---

<Layout
  title="Reading"
  description="Articles, essays, and books I've been reading."
>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:Reading"
    >
      <LabeledRule>Reading</LabeledRule>

      {
        buckets.length > 0 ? (
          buckets.map((bucket, bucketIndex) => (
            <section class="space-y-6">
              <h2
                class="font-heading text-sm font-medium text-black/65 dark:text-white/65"
              >
                {bucket.label}
              </h2>
              <ul class="not-prose flex flex-col gap-8">
                {bucket.entries.map((entry) => (
                  <li class="space-y-1.5">
                    <Link
                      href={entry.data.url}
                      external
                      class="font-heading text-base font-medium text-black dark:text-white"
                    >
                      {entry.data.title}
                    </Link>
                    <div class="flex flex-wrap items-baseline gap-x-2 text-xs text-black/55 dark:text-white/60">
                      <time datetime={entry.data.added.toISOString()}>
                        {dateFormatter.format(entry.data.added)}
                      </time>
                      {(entry.data.author || entry.data.source) && (
                        <>
                          <span aria-hidden="true">&middot;</span>
                          <span>
                            {[entry.data.author, entry.data.source]
                              .filter(Boolean)
                              .join(", ")}
                          </span>
                        </>
                      )}
                      <span aria-hidden="true">&middot;</span>
                      <span>{entry.data.category}</span>
                    </div>
                    <p class="text-sm leading-relaxed text-black/75 dark:text-white/75">
                      {entry.data.summary}
                    </p>
                  </li>
                ))}
              </ul>
              {bucketIndex < buckets.length - 1 && <EditorialRule />}
            </section>
          ))
        ) : (
          <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
            Nothing here yet. The pipeline is wired up — as soon as I start
            saving links from my phone, they'll appear here.
          </p>
        )
      }
    </div>
  </Container>
</Layout>
