---
import { getCollection } from "astro:content";
import BackToPrevious from "@components/BackToPrevious.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  // Get unique tags
  const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))];

  // Create paths for each tag
  return tags.map((tag) => ({
    params: { id: tag },
    props: {
      posts: posts.filter((post) => post.data.tags?.includes(tag)),
    },
  }));
}

const { id } = Astro.params;
const { posts } = Astro.props;

// Sort posts by date, most recent first
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={`Tag: ${id}`} description={`Posts with the tag: ${id}`}>
  <Container>
    <div class="space-y-10" data-pagefind-ignore>
      <BackToPrevious href="/tags"> All tags </BackToPrevious>
      <h1 class="font-semibold text-black dark:text-white">
        Posts tagged with "{id}"
      </h1>
      <ul class="not-prose flex flex-col gap-3 text-sm">
        {
          sortedPosts.map((post) => (
            <li class="flex items-baseline gap-4">
              <time
                datetime={post.data.date.toISOString()}
                class="shrink-0 font-sans text-xs text-black/50 dark:text-white/60"
              >
                {dateFormatter.format(post.data.date)}
              </time>
              <span>
                <Link
                  href={`/writing/${post.id}`}
                  class="font-heading font-medium text-black dark:text-white"
                >
                  {post.data.title}
                </Link>
                {post.data.description && (
                  <span class="text-black/60 dark:text-white/60">
                    {" — "}
                    {post.data.description}
                  </span>
                )}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</Layout>
