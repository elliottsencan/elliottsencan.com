---
import { getCollection } from "astro:content";
import BackToPrevious from "@components/BackToPrevious.astro";
import Container from "@components/Container.astro";
import EditorialList from "@components/EditorialList.astro";
import EditorialListItem from "@components/EditorialListItem.astro";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  // Get unique tags
  const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))];

  // Create paths for each tag
  return tags.map((tag) => ({
    params: { id: tag },
    props: {
      posts: posts.filter((post) => post.data.tags?.includes(tag)),
    },
  }));
}

const { id } = Astro.params;
const { posts } = Astro.props;

// Sort posts by date, most recent first
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Tags", url: "/tags/" },
  { name: id ?? "Tag", url: `/tags/${id}/` },
];
---

<Layout
  title={`Tag: ${id}`}
  description={`Posts with the tag: ${id}`}
  breadcrumbs={breadcrumbs}
>
  <Container>
    <div class="space-y-10" data-pagefind-ignore>
      <BackToPrevious href="/tags"> All tags </BackToPrevious>
      <h1 class="font-heading text-display font-normal tracking-tight leading-[1.06] text-black dark:text-white">
        Posts tagged with "{id}"
      </h1>
      <EditorialList>
        {
          sortedPosts.map((post) => (
            <EditorialListItem
              title={post.data.title}
              href={`/writing/${post.id}`}
              meta={dateFormatter.format(post.data.date)}
              metaDateTime={post.data.date.toISOString()}
            >
              {post.data.description}
            </EditorialListItem>
          ))
        }
      </EditorialList>
    </div>
  </Container>
</Layout>
