---
import { getCollection } from "astro:content";
import Breadcrumb from "@components/Breadcrumb.astro";
import EditorialList from "@components/EditorialList.astro";
import EditorialListItem from "@components/EditorialListItem.astro";
import PageBody from "@components/PageBody.astro";
import PageHero from "@components/PageHero.astro";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  // Get unique tags
  const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))];

  // Create paths for each tag
  return tags.map((tag) => ({
    params: { id: tag },
    props: {
      posts: posts.filter((post) => post.data.tags?.includes(tag)),
    },
  }));
}

const { id } = Astro.params;
const { posts } = Astro.props;

// Sort posts by date, most recent first
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Tags", url: "/tags/" },
  { name: id ?? "Tag", url: `/tags/${id}/` },
];
---

<Layout
  title={`Tag: ${id}`}
  description={`Posts with the tag: ${id}`}
  breadcrumbs={breadcrumbs}
>
  <PageBody data-pagefind-ignore>
    <PageHero breadcrumb>
      <Breadcrumb slot="breadcrumb" parent={{ label: "Tags", href: "/tags/" }} />
      <Fragment slot="title">Posts tagged with "{id}"</Fragment>
    </PageHero>
    <EditorialList>
        {
          sortedPosts.map((post) => (
            <EditorialListItem
              title={post.data.title}
              href={`/writing/${post.id}`}
              meta={dateFormatter.format(post.data.date)}
              metaDateTime={post.data.date.toISOString()}
            >
              {post.data.description}
            </EditorialListItem>
          ))
        }
    </EditorialList>
  </PageBody>
</Layout>
