---
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import Layout from "@layouts/Layout.astro";

// Hand-edit this when the focus shifts. A "now" page is only useful if the
// update date is honest — no auto-stamp.
const lastUpdated = "APR 2026";

// Reformat the same human label into an ISO date for Pagefind meta so search
// results can sort/filter by recency. The hand-edited string is the source of
// truth; this is just a derived format.
const [lastUpdatedMonth, lastUpdatedYear] = lastUpdated.split(" ");
const lastUpdatedISO = new Date(`${lastUpdatedMonth} 1, ${lastUpdatedYear}`)
  .toISOString()
  .slice(0, 10);
---

<Layout
  title="Now"
  description="What I'm working on right now."
>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:About"
      data-pagefind-meta={`date:${lastUpdatedISO}`}
    >
      <div>
        <h1 class="sr-only">Now</h1>
        <p
          class="font-mono text-xs uppercase tracking-wider text-black/55 dark:text-white/55"
          style="font-variant-numeric: tabular-nums;"
        >
          Now &middot; Updated {lastUpdated}
        </p>
      </div>

      <EditorialRule />

      <section class="space-y-6 text-base leading-relaxed text-black/85 dark:text-white/85">
        <p>
          Building <em>herald-ui</em> &mdash; a design system for teams that
          don't want to re-solve the same primitives every quarter.
        </p>
      </section>
    </div>
  </Container>
</Layout>
