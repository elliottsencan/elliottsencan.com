---
import { getEntry, render } from "astro:content";
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import Link from "@components/Link.astro";
import Layout from "@layouts/Layout.astro";

// Source of truth: src/content/now/current.md. The site-ingest worker
// owns the `updated` field — hand-edits will be overwritten by the next
// weekly draft PR. A missing entry fails the build, which means the
// content collection is mis-configured.
const entry = await getEntry("now", "current");
if (!entry) throw new Error("src/content/now/current.md missing");

const { Content } = await render(entry);

const updated = entry.data.updated;
const lastUpdated = `${updated.toLocaleString("en-US", { month: "short" }).toUpperCase()} ${updated.getFullYear()}`;
const lastUpdatedISO = updated.toISOString().slice(0, 10);
---

<Layout title="Now" description={entry.data.description}>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:About"
      data-pagefind-meta={`date:${lastUpdatedISO}`}
    >
      <div>
        <h1 class="sr-only">Now</h1>
        <p
          class="font-mono text-xs uppercase tracking-wider text-black/55 dark:text-white/55"
          style="font-variant-numeric: tabular-nums;"
        >
          Now &middot; Updated {lastUpdated}
        </p>
      </div>

      <EditorialRule />

      <section
        class="prose prose-neutral dark:prose-invert max-w-none text-base leading-relaxed text-black/85 dark:text-white/85"
      >
        <Content />
      </section>

      <EditorialRule />

      <p
        class="font-mono text-xs uppercase tracking-wider text-black/55 dark:text-white/55"
      >
        <Link href="/now/how-this-works">how this page works</Link>
        &nbsp;&middot;&nbsp;
        <Link href="/now/archive">archive</Link>
      </p>
    </div>
  </Container>
</Layout>
