---
import Container from "@components/Container.astro";
import ContributionsGrid from "@components/ContributionsGrid.astro";
import EditorialRule from "@components/EditorialRule.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";
import Layout from "@layouts/Layout.astro";
import { getAnnotatedPinned, getContributions, getProfile, getRecentActivity } from "@lib/github";

// Every block fetches independently so a failure in one doesn't blank the
// rest. All four helpers return null on any error (missing token, network,
// rate limit) and never throw; see src/lib/github.ts. The contributions
// grid is the page's hero — repeated from the footer rail at full size, so
// the page becomes the canonical view of the data and the footer stays a
// teaser.
const [contributions, profile, pinned, activity] = await Promise.all([
  getContributions(SITE.GITHUB_LOGIN),
  getProfile(SITE.GITHUB_LOGIN),
  getAnnotatedPinned(SITE.GITHUB_LOGIN),
  getRecentActivity(SITE.GITHUB_LOGIN, 5),
]);

const anyData =
  Boolean(contributions) ||
  Boolean(profile) ||
  (pinned !== null && pinned.length > 0) ||
  (activity !== null && activity.length > 0);

const githubProfileUrl = `https://github.com/${SITE.GITHUB_LOGIN}`;

// "14 APR" — matches homepage's tabular font-mono styling but drops the year
// for activity which is always within the last ~90 days (the events API cap).
const eventDateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "2-digit",
  month: "short",
});

const formatCount = (n: number): string => new Intl.NumberFormat("en-US").format(n);

// Heatmap window label, e.g. "APR '25 → APR '26".
function formatMonthYear(iso: string | undefined): string {
  if (!iso) {
    return "";
  }
  const d = new Date(`${iso}T00:00:00Z`);
  const month = d.toLocaleDateString("en-US", { month: "short", timeZone: "UTC" }).toUpperCase();
  const yy = d.getUTCFullYear().toString().slice(-2);
  return `${month} '${yy}`;
}

function addDays(iso: string, days: number): string {
  const d = new Date(`${iso}T00:00:00Z`);
  d.setUTCDate(d.getUTCDate() + days);
  return d.toISOString().slice(0, 10);
}

let heatmapCaption = "";
if (contributions) {
  const first = contributions.weeks.at(0)?.startDate;
  const last = contributions.weeks.at(-1)?.startDate;
  const startLabel = formatMonthYear(first);
  const endLabel = formatMonthYear(last ? addDays(last, 6) : undefined);
  heatmapCaption = `${formatCount(contributions.total)} contributions · ${startLabel} → ${endLabel}`;
}
---

<Layout
  title="GitHub"
  description={`GitHub presence for ${SITE.TITLE} — selected projects with annotations, contribution heatmap, and recent activity.`}
>
  <Container>
    <div class="space-y-10" data-pagefind-ignore>
      <div>
        <h1 class="sr-only">GitHub</h1>
        <p
          class="font-mono text-xs uppercase tracking-wider text-black/55 dark:text-white/55"
          style="font-variant-numeric: tabular-nums;"
        >
          GitHub
        </p>
      </div>

      <EditorialRule />

      {
        !anyData && (
          <section>
            <p class="text-base text-black/75 dark:text-white/75">
              Live data from GitHub isn&rsquo;t available right now. Visit{" "}
              <Link href={githubProfileUrl} external>
                github.com/{SITE.GITHUB_LOGIN}
              </Link>{" "}
              for the source of truth.
            </p>
          </section>
        )
      }

      {
        contributions && (
          <section class="space-y-4">
            {/* Full-size heatmap. Larger cells than the footer grid so the
                day-level texture is legible at desktop width. The component
                is responsive only via the cell pixel size — the column
                count is fixed at 52 weeks. Horizontal overflow on narrow
                viewports falls into a scrollable strip rather than
                squeezing the cells unreadably small. */}
            <div class="overflow-x-auto">
              <ContributionsGrid data={contributions} cellSize={10} gap={2} />
            </div>
            <p
              class="font-mono text-xs uppercase tracking-wider text-black/55 dark:text-white/55"
              style="font-variant-numeric: tabular-nums;"
            >
              {heatmapCaption}
            </p>
          </section>
        )
      }

      {
        profile && (
          <section class="space-y-6">
            <div class="flex items-start gap-5">
              <img
                src={profile.avatarUrl}
                alt={profile.name ?? profile.login}
                class="size-14 shrink-0 rounded-full"
                width="56"
                height="56"
                loading="eager"
                decoding="async"
              />
              <div class="space-y-1">
                <h2 class="font-heading text-2xl font-medium tracking-tight text-black dark:text-white">
                  {profile.name ?? profile.login}
                </h2>
                <p
                  class="font-mono text-xs uppercase tracking-wider text-black/55 dark:text-white/55"
                >
                  <Link href={profile.url} external>
                    @{profile.login}
                  </Link>
                  {profile.location && (
                    <>
                      <span aria-hidden="true" class="text-black/30 dark:text-white/30">
                        {" "}&middot;{" "}
                      </span>
                      {profile.location.toUpperCase()}
                    </>
                  )}
                </p>
              </div>
            </div>
            {profile.bio && (
              <p class="text-base text-black/75 dark:text-white/75">
                {profile.bio}
              </p>
            )}
            <ul
              class="not-prose flex flex-wrap items-baseline gap-x-3 gap-y-1 font-mono text-xs uppercase tracking-wider text-black/60 dark:text-white/60"
              style="font-variant-numeric: tabular-nums;"
            >
              <li>{formatCount(profile.publicRepos)} repos</li>
              <li aria-hidden="true" class="text-black/30 dark:text-white/30">
                &middot;
              </li>
              <li>{formatCount(profile.followers)} followers</li>
              <li aria-hidden="true" class="text-black/30 dark:text-white/30">
                &middot;
              </li>
              <li>{formatCount(profile.following)} following</li>
            </ul>
          </section>
        )
      }

      {
        pinned && pinned.length > 0 && (
          <section class="space-y-4">
            <div class="flex items-baseline justify-between">
              <h2 class="font-mono text-xs uppercase tracking-wider text-black/60 dark:text-white/60">
                Selected projects
              </h2>
              <Link href={`${githubProfileUrl}?tab=repositories`} external>
                <span class="text-sm">All repositories &rarr;</span>
              </Link>
            </div>
            <ul class="not-prose flex flex-col gap-4 text-sm">
              {pinned.map((repo) => (
                <li class="space-y-1">
                  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                    <Link href={repo.url} external>
                      <span class="font-medium text-black dark:text-white">
                        {repo.name}
                      </span>
                    </Link>
                    <span
                      class="whitespace-nowrap font-mono text-xs uppercase tracking-wider text-black/50 dark:text-white/50"
                      style="font-variant-numeric: tabular-nums;"
                    >
                      {repo.primaryLanguage && (
                        <>
                          {repo.primaryLanguage.name}
                          {" · "}
                        </>
                      )}
                      {formatCount(repo.stargazerCount)} &#9733;
                    </span>
                  </div>
                  <p class="text-black/70 dark:text-white/70">
                    {repo.annotation ?? repo.description ?? ""}
                  </p>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        activity && activity.length > 0 && (
          <section class="space-y-4">
            <div class="flex items-baseline justify-between">
              <h2 class="font-mono text-xs uppercase tracking-wider text-black/60 dark:text-white/60">
                Recent activity
              </h2>
              <Link href={githubProfileUrl} external>
                <span class="text-sm">Full timeline &rarr;</span>
              </Link>
            </div>
            <ul class="not-prose flex flex-col gap-2 text-sm">
              {activity.map((event) => (
                <li class="flex items-baseline gap-4">
                  <time
                    datetime={event.createdAt}
                    class="shrink-0 font-mono text-xs uppercase tracking-wider text-black/50 dark:text-white/50"
                    style="font-variant-numeric: tabular-nums;"
                  >
                    {eventDateFormatter.format(new Date(event.createdAt)).toUpperCase()}
                  </time>
                  <span>
                    {event.summary}
                    {" in "}
                    <Link href={event.repo.url} external>
                      {event.repo.nameWithOwner}
                    </Link>
                  </span>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </div>
  </Container>
</Layout>
