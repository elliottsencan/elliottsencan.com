---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BackToPrevious from "@components/BackToPrevious.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import Link from "@components/Link.astro";
import TableOfContents from "@components/TableOfContents.astro";
import ProjectLayout from "@layouts/ProjectLayout.astro";
import { readingTime } from "@lib/utils";

export async function getStaticPaths() {
  const projects = (await getCollection("projects"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return projects.map((project) => ({
    params: { id: project.id },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { Content, headings } = await render(project);

const statusColors: Record<string, string> = {
  active: "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400",
  archived: "bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-400",
  killed: "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400",
};

// Operational rail content — same affordance as wiki sources / labs status:
// facts about the project the body keeps referring back to (what role,
// what stack, where to see it). Hide the rail on projects that wouldn't
// fill it (small one-off projects with no role/stack/links/non-default
// status); they render single-column instead.
const showStatusInRail = Boolean(project.data.status) && project.data.status !== "active";
const hasRail =
  showStatusInRail ||
  Boolean(project.data.role) ||
  (project.data.stack && project.data.stack.length > 0) ||
  Boolean(project.data.demoURL) ||
  Boolean(project.data.repoURL);
---

<ProjectLayout project={project}>
  <Container>
    <div>
      <BackToPrevious href="/about">Back to about</BackToPrevious>
    </div>
    <div class="my-10 max-w-[62ch] space-y-2">
      <div class="flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={project.data.date} />
        </div>
        &bull;
        {project.body && (
          <div class="font-base text-sm">{readingTime(project.body)}</div>
        )}
      </div>
      <h1
        class="font-heading text-2xl font-medium tracking-tight text-black md:text-3xl dark:text-white"
      >
        {project.data.title}
      </h1>
    </div>

    {/*
      Impact metrics stay full-width above the body — they read as the
      headline finding of the case study, editorial weight rather than
      operational metadata, and earn their own row.
    */}
    {project.data.impact && project.data.impact.length > 0 && (
      <div class="mb-12 grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4 md:grid-cols-3">
        {project.data.impact.map((item) => (
          <div class="rounded-sm border border-black/10 p-3 dark:border-white/15">
            <div class="font-heading text-lg font-medium text-black dark:text-white">
              {item.value}
            </div>
            <div class="text-xs text-neutral-500">{item.metric}</div>
          </div>
        ))}
      </div>
    )}

    <div
      class={
        hasRail
          ? "grid gap-8 md:grid-cols-[minmax(0,1fr)_220px] md:gap-12"
          : ""
      }
    >
      <div class="min-w-0">
        <TableOfContents headings={headings} />
        <article
          data-pagefind-body
          data-pagefind-filter="type:Projects"
          data-pagefind-meta={`date:${project.data.date.toISOString().slice(0, 10)}`}
        >
          {project.data.stack && project.data.stack.length > 0 && (
            <span data-pagefind-meta="tags" hidden>
              {project.data.stack.join(", ")}
            </span>
          )}
          <Content />
        </article>
      </div>

      {hasRail && (
        <aside class="md:sticky md:top-28 md:self-start">
          <dl class="flex flex-col gap-5">
            {showStatusInRail && (
              <div class="flex flex-col gap-1.5">
                <dt class="font-heading text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
                  Status
                </dt>
                <dd>
                  <span
                    class={`inline-flex rounded-sm px-2 py-0.5 text-xs font-medium ${statusColors[project.data.status as string]}`}
                  >
                    {project.data.status}
                  </span>
                </dd>
              </div>
            )}

            {project.data.role && (
              <div class="flex flex-col gap-1.5">
                <dt class="font-heading text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
                  Role
                </dt>
                <dd class="text-sm text-black/85 dark:text-white/85">
                  {project.data.role}
                </dd>
              </div>
            )}

            {project.data.stack && project.data.stack.length > 0 && (
              <div class="flex flex-col gap-1.5">
                <dt class="font-heading text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
                  Stack
                </dt>
                <dd>
                  <ul class="flex flex-wrap gap-1.5">
                    {project.data.stack.map((tech) => (
                      <li class="rounded-sm border border-black/10 px-2 py-0.5 text-xs dark:border-white/15">
                        {tech}
                      </li>
                    ))}
                  </ul>
                </dd>
              </div>
            )}

            {(project.data.demoURL || project.data.repoURL) && (
              <div class="flex flex-col gap-1.5">
                <dt class="font-heading text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
                  Links
                </dt>
                <dd class="flex flex-col gap-1 text-xs">
                  {project.data.demoURL && (
                    <Link href={project.data.demoURL} external>
                      demo ↗
                    </Link>
                  )}
                  {project.data.repoURL && (
                    <Link href={project.data.repoURL} external>
                      repo ↗
                    </Link>
                  )}
                </dd>
              </div>
            )}
          </dl>
        </aside>
      )}
    </div>
  </Container>
</ProjectLayout>
