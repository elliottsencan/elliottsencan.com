---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import { PROJECTS } from "@consts";
import Layout from "@layouts/Layout.astro";

const allProjects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => {
    if (a.data.order !== undefined && b.data.order !== undefined) {
      return a.data.order - b.data.order;
    }
    if (a.data.order !== undefined) {
      return -1;
    }
    if (b.data.order !== undefined) {
      return 1;
    }
    return b.data.date.valueOf() - a.data.date.valueOf();
  });

const caseStudies = allProjects.filter((p) => p.data.isCaseStudy);
const otherProjects = allProjects.filter((p) => !p.data.isCaseStudy);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-10">
        <LabeledRule>Projects</LabeledRule>

        {
          caseStudies.length > 0 && (
            <section class="space-y-6">
              <h2 class="font-heading text-sm font-medium text-black/65 dark:text-white/65">
                Case studies
              </h2>
              <ul class="not-prose flex flex-col gap-3 text-sm">
                {caseStudies.map((project) => (
                  <li class="flex items-baseline gap-4">
                    <time
                      datetime={project.data.date.toISOString()}
                      class="shrink-0 font-sans text-xs text-black/50 dark:text-white/60"
                    >
                      {dateFormatter.format(project.data.date)}
                    </time>
                    <span>
                      <Link
                        href={`/projects/${project.id}`}
                        class="font-heading font-medium text-black dark:text-white"
                      >
                        {project.data.title}
                      </Link>
                      {project.data.description && (
                        <span class="text-black/60 dark:text-white/60">
                          {" — "}
                          {project.data.description}
                        </span>
                      )}
                    </span>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <section class="space-y-6">
          <h2 class="font-heading text-sm font-medium text-black/65 dark:text-white/65">
            {caseStudies.length > 0 ? "Other projects" : "All projects"}
          </h2>
          {
            otherProjects.length > 0 ? (
              <ul class="not-prose flex flex-col gap-3 text-sm">
                {otherProjects.map((project) => (
                  <li class="flex items-baseline gap-4">
                    <time
                      datetime={project.data.date.toISOString()}
                      class="shrink-0 font-sans text-xs text-black/50 dark:text-white/60"
                    >
                      {dateFormatter.format(project.data.date)}
                    </time>
                    <span>
                      <Link
                        href={`/projects/${project.id}`}
                        class="font-heading font-medium text-black dark:text-white"
                      >
                        {project.data.title}
                      </Link>
                      {project.data.description && (
                        <span class="text-black/60 dark:text-white/60">
                          {" — "}
                          {project.data.description}
                        </span>
                      )}
                    </span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-sm text-black/60 dark:text-white/60">
                Coming soon.
              </p>
            )
          }
        </section>
      </div>
    </aside>
  </Container>
</Layout>
