---
import { getCollection, getEntry } from "astro:content";
import Container from "@components/Container.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import Masthead from "@components/Masthead.astro";
import { HOME } from "@consts";
import Layout from "@layouts/Layout.astro";

// The homepage IS the writing feed — flat reverse-chron, no slice, no year
// grouping, no bio. Post titles + dates are the entire content below the
// masthead dateline; full bio lives at /about.
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Standfirst is co-authored by the /now drafting step and lives in the
// now collection's frontmatter. One sentence, landing-page dateline. If
// the entry or field is missing (old seed, edge case), the block is
// skipped and the writing list sits directly under the Masthead rule.
const nowEntry = await getEntry("now", "current");
const standfirst = nowEntry?.data.standfirst;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <Masthead standfirst={standfirst} />

      {
        posts.length > 0 ? (
          <>
            <LabeledRule as="h2">Writing</LabeledRule>
            <section data-pagefind-ignore>
              <ul class="not-prose flex flex-col gap-3 text-sm">
                {posts.map((post) => (
                  <li class="flex items-baseline gap-4">
                    <time
                      datetime={post.data.date.toISOString()}
                      class="shrink-0 font-sans text-xs text-black/50 dark:text-white/60"
                    >
                      {dateFormatter.format(post.data.date)}
                    </time>
                    <span>
                      <Link
                        href={`/writing/${post.id}`}
                        class="font-heading font-medium text-black dark:text-white"
                      >
                        {post.data.title}
                      </Link>
                      {post.data.description && (
                        <span class="text-black/60 dark:text-white/60">
                          {" — "}
                          {post.data.description}
                        </span>
                      )}
                    </span>
                  </li>
                ))}
              </ul>
            </section>
          </>
        ) : null
      }
    </div>
  </Container>
</Layout>
