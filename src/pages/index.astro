---
import { getCollection, getEntry } from "astro:content";
import Container from "@components/Container.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import Masthead from "@components/Masthead.astro";
import { HOME } from "@consts";
import Layout from "@layouts/Layout.astro";

// The homepage IS the writing feed — flat reverse-chron, no slice, no year
// grouping, no bio. Post titles + dates are the entire content below the
// masthead dateline; full bio lives at /about.
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Standfirst is co-authored by the /now drafting step and lives in the
// now collection's frontmatter. One sentence, landing-page dateline. If
// the entry or field is missing (old seed, edge case), the block is
// skipped and the writing list sits directly under the Masthead rule.
const nowEntry = await getEntry("now", "current");
const standfirst = nowEntry?.data.standfirst;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

// Trails — three input/synthesis/data surfaces, surfaced from the home
// page so the new IA is legible without bloating the nav. Counts and
// "latest" lines are computed at build from the live collections so
// they stay accurate as content lands.
const reading = await getCollection("reading");
const wiki = await getCollection("wiki");
const labs = await getCollection("labs");

const latestReading = [...reading].sort(
  (a, b) => b.data.added.valueOf() - a.data.added.valueOf(),
)[0];
const latestWiki = [...wiki].sort(
  (a, b) => b.data.compiled_at.valueOf() - a.data.compiled_at.valueOf(),
)[0];
const latestLab = [...labs].sort(
  (a, b) => b.data.lastRunDate.valueOf() - a.data.lastRunDate.valueOf(),
)[0];

const totalSources = wiki.reduce((sum, concept) => sum + concept.data.sources.length, 0);

const trails = [
  {
    key: "reading",
    href: "/reading",
    caption: `${reading.length} sources saved`,
    blurb: "Per-source citation log. The raw input.",
    latest: latestReading
      ? { title: latestReading.data.title, href: `/reading/${latestReading.id}/` }
      : null,
  },
  {
    key: "wiki",
    href: "/wiki",
    caption: `${wiki.length} articles · ${totalSources} sources`,
    blurb: "Synthesis. Concepts compiled across multiple sources.",
    latest: latestWiki ? { title: latestWiki.data.title, href: `/wiki/${latestWiki.id}/` } : null,
  },
  {
    key: "labs",
    href: "/labs",
    caption: labs.length > 0 ? `${labs.length} cells` : "data behind posts",
    blurb: "Numbers behind the posts. Cost, evals, telemetry.",
    latest: latestLab ? { title: latestLab.data.title, href: `/labs/${latestLab.id}/` } : null,
  },
];
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <Masthead standfirst={standfirst} />

      {
        posts.length > 0 ? (
          <>
            <LabeledRule as="h2">Writing</LabeledRule>
            <section data-pagefind-ignore>
              <ul class="not-prose flex flex-col gap-3 text-sm">
                {posts.map((post) => (
                  <li class="flex items-baseline gap-4">
                    <time
                      datetime={post.data.date.toISOString()}
                      class="shrink-0 font-sans text-xs text-black/50 dark:text-white/60"
                    >
                      {dateFormatter.format(post.data.date)}
                    </time>
                    <span>
                      <Link
                        href={`/writing/${post.id}`}
                        class="font-heading font-medium text-black dark:text-white"
                      >
                        {post.data.title}
                      </Link>
                      {post.data.description && (
                        <span class="text-black/60 dark:text-white/60">
                          {" — "}
                          {post.data.description}
                        </span>
                      )}
                    </span>
                  </li>
                ))}
              </ul>
            </section>
          </>
        ) : null
      }

      {/*
        Trails — three input/synthesis/data surfaces in one row. Lets the new
        IA show on the home page without bloating the nav.
      */}
      <LabeledRule as="h2">Trails</LabeledRule>
      <section data-pagefind-ignore>
        <ul class="not-prose flex flex-col text-sm">
          {
            trails.map((trail, i) => (
              <li
                class:list={[
                  "grid grid-cols-[7.5rem_1fr] items-baseline gap-x-6 gap-y-1 py-4",
                  i === 0 && "border-t border-black/10 dark:border-white/10",
                  "border-b border-black/10 dark:border-white/10",
                ]}
              >
                <div class="flex flex-col gap-1">
                  <Link
                    href={trail.href}
                    underline={false}
                    class="font-heading text-lg font-medium text-black dark:text-white"
                  >
                    /{trail.key}
                  </Link>
                  <span class="font-mono text-[11px] uppercase tracking-wider text-black/55 dark:text-white/55">
                    {trail.caption}
                  </span>
                </div>
                <div class="flex flex-col gap-1.5">
                  <p class="leading-relaxed text-black/75 dark:text-white/75">
                    {trail.blurb}
                  </p>
                  {trail.latest && (
                    <span class="font-mono text-[11px] text-black/55 dark:text-white/55">
                      latest ·{" "}
                      <Link href={trail.latest.href} class="font-sans text-xs">
                        {trail.latest.title}
                      </Link>
                    </span>
                  )}
                </div>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </Container>
</Layout>
