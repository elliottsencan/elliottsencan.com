---
import { getCollection, getEntry } from "astro:content";
import EditorialRule from "@components/EditorialRule.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import Sparkline from "@components/labs/Sparkline.astro";
import Masthead from "@components/Masthead.astro";
import MetaLine from "@components/MetaLine.astro";
import PageBody from "@components/PageBody.astro";
import { HOME } from "@consts";
import Layout from "@layouts/Layout.astro";
import { splitMetricValue } from "@lib/format";
import { loadLabData } from "@lib/lab-data";
import { SITE_TIMEZONE } from "@lib/utils";

// Homepage layout: Masthead → Recent posts → Where this writing comes from
// (the wiki-led trail cards). Writing list mirrors /reading's grammar so
// the rhythm reads as one site rather than two. Trail cards drop the count
// caption in favour of an inline stat block (number + unit + a small
// mini-viz + aux line) so each surface signals scale and cadence at a
// glance, on real data only.
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const nowEntry = await getEntry("now", "current");
const standfirst = nowEntry?.data.standfirst;

const longDate = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const compactDate = new Intl.DateTimeFormat("en-US", {
  day: "2-digit",
  month: "short",
  timeZone: SITE_TIMEZONE,
});

const reading = await getCollection("reading");
const wiki = await getCollection("wiki");
const labs = await getCollection("labs");

const latestReading = [...reading].sort(
  (a, b) => b.data.added.valueOf() - a.data.added.valueOf(),
)[0];
const latestWiki = [...wiki].sort(
  (a, b) => b.data.compiled_at.valueOf() - a.data.compiled_at.valueOf(),
)[0];
// Prefer the most-recent live cell with a concrete headline value over
// one whose first run is still pending (TBD / em-dash placeholder). The
// homepage signal is "this number is real today," not "we have a card
// reserved for a future number."
const isConcreteValue = (v: string) => !/^(tbd|—|-|n\/a)$/i.test(v.trim());
const liveLabs = labs.filter((l) => l.data.status === "live");
const sortByLastRun = <T extends { data: { lastRunDate: Date } }>(arr: T[]): T[] =>
  [...arr].sort((a, b) => b.data.lastRunDate.valueOf() - a.data.lastRunDate.valueOf());
const latestLab =
  sortByLastRun(liveLabs.filter((l) => isConcreteValue(l.data.headlineMetric.value)))[0] ??
  sortByLastRun(liveLabs)[0] ??
  sortByLastRun(labs)[0];

// Wiki signal: total contributing-source citations across every concept.
// One entry can be cited from multiple concepts, so this is the reach of
// the synthesis rather than the deduped reading count.
const wikiCitationCount = wiki.reduce((sum, c) => sum + c.data.sources.length, 0);

// Reading cadence — last 12 weeks, bucketed by week-of (Pacific). Empty
// weeks render as a 1-unit bar so the row reads as a continuous rhythm
// rather than a gappy column chart.
const WEEKS = 12;
function pacificWeekStart(d: Date): number {
  // Convert to PT then floor to Monday 00:00. The PT offset bounces
  // between -7 and -8 across DST; for week-bucketing the off-by-an-hour
  // edge cases all collapse to adjacent weeks at midnight, which doesn't
  // change the cadence reading.
  const pt = new Date(d.getTime() - 7 * 60 * 60 * 1000);
  const day = pt.getUTCDay();
  const diff = (day + 6) % 7;
  pt.setUTCDate(pt.getUTCDate() - diff);
  pt.setUTCHours(0, 0, 0, 0);
  return pt.getTime();
}
const thisWeekStart = pacificWeekStart(new Date());
const cadenceBuckets: number[] = Array.from({ length: WEEKS }, () => 0);
for (const entry of reading) {
  const weekStart = pacificWeekStart(entry.data.added);
  const weeksAgo = Math.round((thisWeekStart - weekStart) / (1000 * 60 * 60 * 24 * 7));
  if (weeksAgo >= 0 && weeksAgo < WEEKS) {
    cadenceBuckets[WEEKS - 1 - weeksAgo] += 1;
  }
}
const thisWeekCount = cadenceBuckets[WEEKS - 1];
const cadenceMax = Math.max(1, ...cadenceBuckets);

// Labs spark — pull the latest live cell's chart values.
const labSparkData =
  latestLab && latestLab.data.kind === "chart" ? await loadLabData(latestLab.data.dataPath) : null;
const labSparkValues =
  labSparkData &&
  typeof labSparkData === "object" &&
  Array.isArray((labSparkData as { values?: unknown }).values)
    ? (labSparkData as { values: number[] }).values
    : null;

const trails = [
  {
    key: "wiki" as const,
    href: "/wiki",
    blurb:
      "Concept-indexed synthesis. One article per topic with two or more contributing sources from the reading log, recompiled per batch with a citation-faithfulness sidecar attached.",
    latest: latestWiki ? { title: latestWiki.data.title, href: `/wiki/${latestWiki.id}/` } : null,
    provenance: latestWiki
      ? { action: "Compiled by Claude" as const, date: latestWiki.data.compiled_at }
      : null,
    meta: [`${wikiCitationCount} ${wikiCitationCount === 1 ? "citation" : "citations"}`],
    stat: {
      n: wiki.length.toString(),
      unit: wiki.length === 1 ? "concept" : "concepts",
    },
  },
  {
    key: "reading" as const,
    href: "/reading",
    blurb:
      "Per-source citation log. One file per URL I've saved from my phone, summarized and topic-tagged at ingest. The raw input the wiki compiles over.",
    latest: latestReading
      ? { title: latestReading.data.title, href: `/reading/${latestReading.id}/` }
      : null,
    provenance: latestReading
      ? { action: "Summarized by Claude" as const, date: latestReading.data.added }
      : null,
    meta: [
      thisWeekCount > 0 ? `+${thisWeekCount} this week` : "0 this week",
      `${WEEKS}-week cadence`,
    ],
    stat: {
      n: reading.length.toString(),
      unit: reading.length === 1 ? "source" : "sources",
    },
  },
  {
    key: "labs" as const,
    href: "/labs",
    blurb:
      "Numbers behind the posts. Cost breakdowns, eval runs, telemetry — each cell names a question and reports a measurement against it.",
    latest: latestLab ? { title: latestLab.data.title, href: `/labs/${latestLab.id}/` } : null,
    provenance: latestLab
      ? { action: "Last run" as const, date: latestLab.data.lastRunDate }
      : null,
    meta: [`${labs.length} ${labs.length === 1 ? "cell" : "cells"}`],
    // Composite values ("89% · 103 claims") split: the numeral renders at
    // display size, the qualifier folds into the unit micro-label — a
    // composite wraps into a three-line stack at --text-num-lg.
    stat: latestLab
      ? (() => {
          const { numeral, qualifier } = splitMetricValue(latestLab.data.headlineMetric.value);
          return {
            n: numeral,
            unit: [qualifier, latestLab.data.headlineMetric.label.toLowerCase()]
              .filter(Boolean)
              .join(" · "),
          };
        })()
      : null,
  },
];
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <PageBody>
    <Masthead standfirst={standfirst} />

    {
      posts.length > 0 ? (
        <div class="reveal" style="--reveal-delay: 260ms;">
          <LabeledRule as="h2">Recent posts</LabeledRule>
          <section data-pagefind-ignore class="mt-2">
            <ul class="not-prose m-0 flex list-none flex-col p-0">
              {posts.map((post, i) => (
                <li class="group">
                  <div class="grid grid-cols-1 gap-x-14 gap-y-1.5 py-7 md:grid-cols-[minmax(0,1fr)_160px] md:items-baseline">
                    <time
                      datetime={post.data.date.toISOString()}
                      class="font-mono text-xs text-black/55 md:col-start-2 md:row-start-1 md:text-right dark:text-white/55"
                      style="font-variant-numeric: tabular-nums;"
                    >
                      <span class="md:hidden">{compactDate.format(post.data.date)}</span>
                      <span class="hidden md:inline">{longDate.format(post.data.date)}</span>
                    </time>
                    <div class="flex min-w-0 flex-col gap-2 md:col-start-1 md:row-start-1">
                      <div class="flex items-baseline gap-3 text-xl">
                        <Link
                          href={`/writing/${post.id}`}
                          class="font-heading text-xl font-medium leading-[1.15] tracking-[-0.013em] text-black no-underline transition-colors duration-300 ease-in-out group-hover:text-[color:var(--accent)] hover:text-[color:var(--accent)] dark:text-white"
                        >
                          {post.data.title}
                        </Link>
                        <span class="hover-arrow" aria-hidden="true">
                          →
                        </span>
                      </div>
                      <p class="m-0 max-w-[52ch] text-sm leading-relaxed text-black/65 dark:text-white/65">
                        {post.data.description}
                      </p>
                    </div>
                  </div>
                  {/* Dot-rule separator (was a solid hairline): same visual
                      language as the section rules, and it crawls under the
                      cursor on full motion. -my-2/py-2 keeps the 1px layout
                      footprint while giving the cursor halo a hover band. */}
                  {i < posts.length - 1 && (
                    <div
                      role="presentation"
                      aria-hidden="true"
                      class="dot-rule crawl-rule -my-2 h-px py-2"
                    />
                  )}
                </li>
              ))}
            </ul>
          </section>
        </div>
      ) : null
    }

    {/*
      Trail rows — wiki leads, reading + labs follow. Instrument grid:
      the count carries the hierarchy as a thin display numeral in the
      left column, the slug + blurb + provenance MetaLine sit in the
      middle, and the mini-viz (cluster snippet / cadence bars /
      sparkline) holds the right edge. The labs row leads with the
      headline metric, not the cell count — the number is the story.
    */}
    <div data-pagefind-ignore>
      <div class="reveal" style="--reveal-delay: 350ms;">
        <LabeledRule as="h2">Where the writing comes from</LabeledRule>
      </div>
      <ol class="not-prose m-0 mt-6 flex list-none flex-col p-0">
        {
          trails.map((trail, i) => (
            <li
              data-observe
              class:list={[
                "rise group relative grid grid-cols-[auto_minmax(0,1fr)] items-start gap-x-8 gap-y-5 border-t border-black/10 py-8 md:grid-cols-[240px_minmax(0,1fr)_200px] md:gap-x-14 md:py-10 dark:border-white/10",
                i === trails.length - 1 && "border-b border-black/10 dark:border-white/10",
              ]}
            >
              <div class="flex flex-col gap-1 md:gap-2.5">
                <span
                  class="num-display text-[2.5rem] text-black md:text-num-lg dark:text-white"
                  style="overflow-wrap: anywhere;"
                >
                  {trail.stat?.n}
                </span>
                <span class="font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
                  {trail.stat?.unit}
                </span>
              </div>

              <div class="col-span-2 flex min-w-0 flex-col gap-2.5 md:col-span-1 md:pt-1.5">
                {/* Stretched-link slug. The ::before pseudo extends the
                    click target across the entire <li> (positioned
                    ancestor); MetaLine links opt back into pointer
                    events with relative z-10. */}
                <div class="flex items-baseline gap-3 text-xl">
                  <Link
                    href={trail.href}
                    class="font-heading text-xl font-medium leading-[1.1] tracking-[-0.013em] text-black no-underline transition-colors duration-300 ease-in-out group-hover:text-(--accent) before:absolute before:inset-0 before:content-[''] dark:text-white"
                  >
                    /{trail.key}
                  </Link>
                  <span class="hover-arrow" aria-hidden="true">→</span>
                </div>
                <p class="m-0 max-w-[44ch] text-sm leading-relaxed text-black/65 dark:text-white/65">
                  {trail.blurb}
                </p>
                {trail.provenance && (
                  <MetaLine
                    class="relative z-10 mt-0.5"
                    segments={[
                      trail.provenance.action,
                      { date: trail.provenance.date },
                      ...(trail.latest
                        ? [
                            "latest",
                            { text: trail.latest.title, href: trail.latest.href, sans: true },
                          ]
                        : []),
                    ]}
                  />
                )}
              </div>

              <div class="col-span-2 w-[200px] max-w-full text-black/65 md:col-span-1 md:pt-2.5 dark:text-white/65">
                {trail.key === "wiki" && (
                  <svg
                    viewBox="0 0 80 40"
                    aria-hidden="true"
                    class="h-[84px] w-full"
                    preserveAspectRatio="xMaxYMid meet"
                  >
                    <line x1="12" y1="22" x2="32" y2="10" stroke="currentColor" stroke-width="0.5" opacity="0.3" />
                    <line x1="32" y1="10" x2="54" y2="24" stroke="currentColor" stroke-width="0.5" opacity="0.3" />
                    <line x1="54" y1="24" x2="68" y2="14" stroke="currentColor" stroke-width="0.5" opacity="0.3" />
                    <line x1="32" y1="10" x2="40" y2="30" stroke="currentColor" stroke-width="0.5" opacity="0.3" />
                    <line x1="40" y1="30" x2="54" y2="24" stroke="currentColor" stroke-width="0.5" opacity="0.3" />
                    {/* Ambient life: nodes twinkle on a 7s cycle with offset
                        phases; the accent node — the most recently compiled
                        concept — breathes. Full motion only. */}
                    <circle
                      class="node-twinkle"
                      style="--twinkle-delay: 0.8s; --node-opacity: 0.7;"
                      cx="12"
                      cy="22"
                      r="1.6"
                      fill="currentColor"
                      opacity="0.7"
                    />
                    <circle class="node-pulse" cx="32" cy="10" r="2.2" fill="var(--accent)" />
                    <circle
                      class="node-twinkle"
                      style="--twinkle-delay: 3.4s; --node-opacity: 0.7;"
                      cx="40"
                      cy="30"
                      r="1.6"
                      fill="currentColor"
                      opacity="0.7"
                    />
                    <circle
                      class="node-twinkle"
                      style="--twinkle-delay: 5.6s; --node-opacity: 0.85;"
                      cx="54"
                      cy="24"
                      r="2"
                      fill="currentColor"
                      opacity="0.85"
                    />
                    <circle
                      class="node-twinkle"
                      style="--twinkle-delay: 1.9s; --node-opacity: 0.6;"
                      cx="68"
                      cy="14"
                      r="1.4"
                      fill="currentColor"
                      opacity="0.6"
                    />
                  </svg>
                )}
                {trail.key === "reading" && (
                  <svg
                    viewBox="0 0 80 40"
                    aria-hidden="true"
                    class="h-[84px] w-full"
                    preserveAspectRatio="none"
                  >
                    {cadenceBuckets.map((v, idx) => {
                      const barW = 80 / WEEKS - 1.4;
                      const x = idx * (80 / WEEKS) + 0.7;
                      const h = Math.max(2, (v / cadenceMax) * 36);
                      const y = 38 - h;
                      const isCurrent = idx === WEEKS - 1;
                      return (
                        <rect
                          class="bar-rise"
                          style={`--bar-delay: ${idx * 45}ms;`}
                          x={x}
                          y={y}
                          width={barW}
                          height={h}
                          fill={isCurrent ? "var(--accent)" : "currentColor"}
                          opacity={isCurrent ? 1 : 0.55}
                        />
                      );
                    })}
                  </svg>
                )}
                {trail.key === "labs" && labSparkValues && labSparkValues.length > 0 && (
                  <Sparkline data={labSparkValues} width={200} height={84} variant="line" draw />
                )}
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    <EditorialRule />

    <p class="text-xs text-black/55 dark:text-white/55">
      <Link href="/about">about →</Link>
    </p>
  </PageBody>
</Layout>
