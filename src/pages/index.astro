---
import { getCollection, getEntry } from "astro:content";
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import Link from "@components/Link.astro";
import Masthead from "@components/Masthead.astro";
import { HOME } from "@consts";
import Layout from "@layouts/Layout.astro";

// The homepage IS the writing feed — flat reverse-chron, no slice, no year
// grouping, no bio. Post titles + dates are the entire content below the
// masthead dateline; full bio lives at /about.
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Standfirst is co-authored by the /now drafting step and lives in the
// now collection's frontmatter. One sentence, landing-page dateline. If
// the entry or field is missing (old seed, edge case), the block is
// skipped and the writing list sits directly under the Masthead rule.
const nowEntry = await getEntry("now", "current");
const standfirst = nowEntry?.data.standfirst;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "2-digit",
  month: "short",
  year: "2-digit",
});
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <Masthead />
      <EditorialRule />

      {
        standfirst ? (
          <>
            <p
              class="text-base leading-relaxed text-black/85 dark:text-white/85"
              data-pagefind-meta={`standfirst:${standfirst}`}
            >
              {standfirst}
            </p>
            <EditorialRule />
          </>
        ) : null
      }

      {
        posts.length > 0 ? (
          <section data-pagefind-ignore>
            <h2 class="sr-only">Writing</h2>
            <ul class="not-prose flex flex-col gap-2 text-sm">
              {posts.map((post) => (
                <li class="flex items-baseline gap-4">
                  <time
                    datetime={post.data.date.toISOString()}
                    class="shrink-0 font-mono text-xs uppercase tracking-wider text-black/50 dark:text-white/50"
                    style="font-variant-numeric: tabular-nums;"
                  >
                    {dateFormatter.format(post.data.date)}
                  </time>
                  <span>
                    <Link href={`/writing/${post.id}`}>{post.data.title}</Link>
                    {post.data.description && (
                      <span class="text-black/60 dark:text-white/60">
                        {" — "}
                        {post.data.description}
                      </span>
                    )}
                  </span>
                </li>
              ))}
            </ul>
          </section>
        ) : null
      }
    </div>
  </Container>
</Layout>
