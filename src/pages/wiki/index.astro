---
import { getCollection } from "astro:content";
import EditorialRule from "@components/EditorialRule.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import ConstellationStrip from "@components/wiki/ConstellationStrip.astro";
import WikiConceptCard from "@components/wiki/WikiConceptCard.astro";
import constellationLayout from "@data/constellation-layout.json";
import Layout from "@layouts/Layout.astro";
import { SITE_TIMEZONE } from "@lib/utils";

// Wiki index — concept-indexed synthesis. The constellation hero draws the
// corpus as hue-coded neighborhoods; the browse below is grouped by those
// same neighborhoods (see `neighborhoodGroups`) so the list reads as the
// structure the hero visualizes rather than a flat alphabetical wall. Each
// card carries the title, summary, source-count signal, and a freshness
// marker; the neighborhood surfaces through the section header + swatch.
const wiki = (await getCollection("wiki")).sort((a, b) => a.data.title.localeCompare(b.data.title));

// Last-compiled date for the hero meta cell — most recent compiled_at
// across the corpus. Distinct reading entries that contribute = total
// unique slugs across all `sources[]`.
const lastCompiledMs =
  wiki.length > 0 ? Math.max(...wiki.map((c) => c.data.compiled_at.getTime())) : null;
const readingSourceCount = new Set(wiki.flatMap((c) => c.data.sources)).size;
const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "short",
  year: "numeric",
  timeZone: SITE_TIMEZONE,
});
const lastCompiledFormatted = lastCompiledMs
  ? dateFormatter.format(new Date(lastCompiledMs))
  : null;

// Constellation summary numbers — moved out of the SVG so the caption can
// grid-align with the col-1 EditorialRule below. Mirrors the
// clusterGroups computation in ConstellationStrip (a "neighborhood" is a
// cluster with at least two members). Same Record<string, …> coercions
// the strip uses, since the JSON is typed with its literal keys.
const constellationNodes: { id: string }[] = constellationLayout.global.nodes;
const constellationClusters: { id: string }[] = constellationLayout.clusters;
const constellationClusterById: Record<string, string | null> = constellationLayout.clusterById;
const constellationNeighborhoodCount = constellationClusters.filter(
  (cl) => constellationNodes.filter((n) => constellationClusterById[n.id] === cl.id).length >= 2,
).length;
const constellationConceptCount = constellationNodes.length;
const constellationTieCount = constellationLayout.global.edges.length;

// ─── Neighborhood-grouped browse ────────────────────────────────────────
// Group the alphabetical concept list by the same clusters the hero renders
// (read straight off the generated layout, so browse + SVG never drift).
// Concepts with no cluster fall to a trailing "Other concepts" bucket.
// Groups lead with the densest neighborhoods; concepts stay alphabetical
// within a group. Degradation: if clustering yields no real groups, the
// template falls back to a single flat grid rather than render bare headers.
const neighborhoods: { id: string; title: string; short: string; hue: number }[] =
  constellationLayout.clusters;
const neighborhoodGroups = neighborhoods
  .map((cl) => ({
    ...cl,
    concepts: wiki.filter((c) => constellationClusterById[c.id] === cl.id),
  }))
  .filter((g) => g.concepts.length > 0)
  .sort((a, b) => b.concepts.length - a.concepts.length);
const otherConcepts = wiki.filter((c) => !constellationClusterById[c.id]);
const useGroupedBrowse = neighborhoodGroups.length > 0;

// Jump-nav items — styled like the site header's section nav (lowercase,
// underlined Link, gap-spaced). Labels are the lowercase cluster id (single
// words); the section headers below carry the fuller "Agents · LLMs" form.
const jumpItems = [
  ...neighborhoodGroups.map((g) => ({ id: g.id, label: g.id })),
  ...(otherConcepts.length > 0 ? [{ id: "other", label: "other" }] : []),
];

// Freshness — surface the active edge of the corpus without over-accenting.
// A concept qualifies when its newest source landed within FRESH_WINDOW_DAYS
// (the "this week" gate), but we mark only the FRESH_MAX most-recently-grown
// of those. Growth is bursty (a single pipeline run can touch a dozen
// concepts), so the cap keeps the terracotta marker a restrained minority and
// lets it shrink to nothing on a quiet week. Both knobs tune in one place.
const FRESH_WINDOW_DAYS = 7;
const FRESH_MAX = 6;
const freshCutoffMs = Date.now() - FRESH_WINDOW_DAYS * 24 * 60 * 60 * 1000;
const freshSlugs = new Set(
  wiki
    .flatMap((c) => {
      const t = c.data.last_source_added?.getTime();
      return t != null && t >= freshCutoffMs ? [{ id: c.id, t }] : [];
    })
    .sort((a, b) => b.t - a.t)
    .slice(0, FRESH_MAX)
    .map((x) => x.id),
);
const isFresh = (c: (typeof wiki)[number]) => freshSlugs.has(c.id);
---

<Layout
  title="Wiki"
  description="Concept-indexed synthesis articles compiled from my reading log."
>
  <div class="mx-auto max-w-5xl px-6 md:px-8">
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:Wiki"
    >
      

      {/*
        Hero — 2-row grid at md+. Column 1 holds the editorial rail:
          row 1: prose + meta cell, flex-col justify-between so the prose
                 anchors at the top and the meta cell at the bottom of the
                 row
          row 2: bottom rule
        Column 2 holds only the constellation; it spans row 1 and a caption
        in row 2, so the constellation's top aligns with the title and its
        caption aligns with the col-1 bottom rule. The hero opens straight
        into the title — no leading rule row, which previously left a dead
        `auto` row whose gap-y-3 gutter pushed the title down 12px. On mobile
        (no grid columns) items fall back to source order: content → bottom
        rule → const.
      */}
      <div
        class="grid grid-cols-1 items-stretch gap-x-8 gap-y-3 md:grid-cols-[minmax(0,1fr)_auto] md:gap-x-10 md:[grid-template-rows:1fr_auto]"
      >
        <div
          class="flex min-w-0 max-w-[62ch] flex-col justify-between gap-4 md:col-start-1 md:row-start-1"
        >
          <div class="flex flex-col gap-3">
            <h1 class="title-display text-xl font-normal tracking-tight text-black dark:text-white">
              Wiki
            </h1>
            <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
              Concept-indexed synthesis articles. Each article compiles across
              multiple sources from the <Link href="/reading">reading log</Link>;
              one article per concept that has at least two contributing
              sources.
            </p>
            <p class="font-mono text-xs text-black/55 dark:text-white/55">
              {readingSourceCount} source{readingSourceCount === 1 ? "" : "s"}
              {lastCompiledFormatted ? ` · compiled ${lastCompiledFormatted}` : ""}
            </p>
          </div>

          <p class="text-xs text-black/55 dark:text-white/55">
            Compiled by Claude
            {" · "}
            <Link href="/wiki/how-this-works">How this works →</Link>
          </p>
        </div>

        <EditorialRule compact class="md:col-start-1 md:row-start-2" />

        {
          wiki.length > 0 && (
            <div class="md:col-start-2 md:row-start-1">
              <ConstellationStrip />
            </div>
          )
        }

        {/* Caption sits in col 2 row 2 so it lines up horizontally with the
            col-1 EditorialRule. Same row → guaranteed alignment. */}
        <p
          class="font-mono text-xs text-black/55 dark:text-white/55 md:col-start-2 md:row-start-2"
        >
          {constellationNeighborhoodCount} neighborhoods
          {" · "}
          {constellationConceptCount} concepts
          {" · "}
          {constellationTieCount} ties
        </p>
      </div>

      {/* Jump-nav — a quiet sticky text line that anchors to each neighborhood
          section, so the browse is navigable without scrolling the full corpus
          (and gives the long mobile single-column a "skip ahead"). Pins just
          under the fixed site header; sections carry a matching scroll-margin
          so an anchored section lands below it. Same flat treatment as
          /reading's archive nav. */}
      {
        useGroupedBrowse && (
          <nav
            class="sticky top-24 z-30 flex flex-wrap items-baseline gap-x-5 gap-y-1 bg-[#f6f4ef]/75 py-3 text-sm backdrop-blur-xs dark:bg-[#18161a]/75"
            aria-label="Jump to neighborhood"
          >
            <span class="text-black/40 dark:text-white/45" aria-hidden="true">Jump</span>
            {jumpItems.map((it) => (
              <Link href={`#${it.id}`}>{it.label}</Link>
            ))}
          </nav>
        )
      }

      {
        wiki.length === 0 ? (
          <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
            Nothing here yet. Wiki articles materialise when at least two
            reading-log entries share a topic.
          </p>
        ) : useGroupedBrowse ? (
          <div class="space-y-10">
            {neighborhoodGroups.map((g) => (
              <section id={g.id} class="scroll-mt-12 space-y-4">
                <LabeledRule as="h2">
                  <span class="inline-flex items-center gap-2">
                    <span
                      class="wiki-swatch h-2 w-2 shrink-0 rounded-full"
                      style={`--hue: ${g.hue};`}
                      aria-hidden="true"
                    />
                    <span>{g.short}</span>
                    <span class="text-black/40 dark:text-white/40">{g.concepts.length}</span>
                  </span>
                </LabeledRule>
                <ul class="not-prose grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-x-6 gap-y-7">
                  {g.concepts.map((concept) => (
                    <WikiConceptCard concept={concept} fresh={isFresh(concept)} />
                  ))}
                </ul>
              </section>
            ))}
            {otherConcepts.length > 0 && (
              <section id="other" class="scroll-mt-12 space-y-4">
                <LabeledRule as="h2">
                  <span class="inline-flex items-center gap-2">
                    <span
                      class="wiki-swatch wiki-swatch--none h-2 w-2 shrink-0 rounded-full"
                      aria-hidden="true"
                    />
                    <span>Other concepts</span>
                    <span class="text-black/40 dark:text-white/40">{otherConcepts.length}</span>
                  </span>
                </LabeledRule>
                <ul class="not-prose grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-x-6 gap-y-7">
                  {otherConcepts.map((concept) => (
                    <WikiConceptCard concept={concept} fresh={isFresh(concept)} />
                  ))}
                </ul>
              </section>
            )}
          </div>
        ) : (
          <ul class="not-prose grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-x-6 gap-y-7">
            {wiki.map((concept) => (
              <WikiConceptCard concept={concept} fresh={isFresh(concept)} />
            ))}
          </ul>
        )
      }

      <EditorialRule />

      <p class="text-xs text-black/55 dark:text-white/55">
        <Link href="/reading">reading log →</Link>
      </p>
    </div>
  </div>
</Layout>

<style>
  /* Neighborhood header swatch — a small solid dot tinted to the cluster's
     hue so each browse section color-matches its region in the constellation
     hero above. Chroma stays low (ink temperature, not a rainbow), the same
     intent as the constellation regions in global.css; terracotta --accent
     stays reserved for emphasis. Hue arrives via the inline --hue var. */
  .wiki-swatch {
    background: oklch(0.66 0.12 var(--hue));
  }
  :global(.dark) .wiki-swatch {
    background: oklch(0.62 0.13 var(--hue));
  }
  /* Unclustered "Other" group — a neutral, hueless dot. */
  .wiki-swatch--none {
    background: oklch(0.68 0 0);
  }
  :global(.dark) .wiki-swatch--none {
    background: oklch(0.5 0 0);
  }
</style>
