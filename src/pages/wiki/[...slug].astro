---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Container from "@components/Container.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import Layout from "@layouts/Layout.astro";
import { SITE_TIMEZONE } from "@lib/utils";
import { buildWikiLinkGraph, resolveRelatedConcepts, type WikiLinkGraph } from "@lib/wiki-graph";

export async function getStaticPaths() {
  const concepts = await getCollection("wiki");
  const graph = buildWikiLinkGraph(concepts.map((c) => ({ id: c.id, body: c.body ?? "" })));
  const knownSlugs = new Set(concepts.map((c) => c.id));
  return concepts.map((concept) => ({
    params: { slug: concept.id },
    props: { concept, graph, knownSlugs },
  }));
}

type Props = {
  concept: CollectionEntry<"wiki">;
  graph: WikiLinkGraph;
  knownSlugs: Set<string>;
};
const { concept, graph, knownSlugs } = Astro.props;
const { Content } = await render(concept);

const reading = await getCollection("reading");
const sourceMap = new Map(reading.map((entry) => [entry.id, entry]));
const resolvedSources = concept.data.sources.map((slug) => ({
  slug,
  entry: sourceMap.get(slug),
}));
const sources = resolvedSources.filter(
  (s): s is { slug: string; entry: NonNullable<typeof s.entry> } => Boolean(s.entry),
);
const missingSources = resolvedSources.filter((s) => !s.entry).map((s) => s.slug);
if (missingSources.length > 0) {
  console.warn(
    `[wiki:${concept.id}] ${missingSources.length} missing source slug(s): ${missingSources.join(", ")}`,
  );
}

const { related: relatedConcepts, hallucinated } = resolveRelatedConcepts(
  graph,
  concept.id,
  concept.data.related_concepts,
  knownSlugs,
);
if (hallucinated.length > 0) {
  console.warn(
    `[wiki:${concept.id}] ${hallucinated.length} hallucinated related_concept(s): ${hallucinated.join(", ")}`,
  );
}

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "2-digit",
  month: "short",
  year: "numeric",
  timeZone: SITE_TIMEZONE,
});
---

<Layout
  title={`Wiki: ${concept.data.title}`}
  description={concept.data.summary}
>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:Wiki"
    >
      <LabeledRule>
        <Link href="/wiki/">Wiki</Link> / {concept.id}
      </LabeledRule>

      <div class="space-y-3">
        <h1 class="text-2xl font-semibold text-black dark:text-white">
          {concept.data.title}
        </h1>
        <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
          {concept.data.summary}
        </p>
        <p class="font-mono text-xs uppercase tracking-wider text-black/50 dark:text-white/60">
          Compiled {dateFormatter.format(concept.data.compiled_at)} from{" "}
          {sources.length} source{sources.length === 1 ? "" : "s"}{
            missingSources.length > 0
              ? ` (${missingSources.length} no longer in the index)`
              : ""
          }.
        </p>
      </div>

      <div class="prose dark:prose-invert max-w-none">
        <Content />
      </div>

      <section class="space-y-4">
        <h2
          class="font-mono text-xs uppercase tracking-wider text-black/50 dark:text-white/60"
        >
          Sources
        </h2>
        <ul class="not-prose flex flex-col gap-4 text-sm">
          {sources.map(({ slug, entry }) => (
            <li class="space-y-1">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <time
                  datetime={entry.data.added.toISOString()}
                  class="shrink-0 font-mono text-xs uppercase tracking-wider text-black/50 dark:text-white/60"
                  style="font-variant-numeric: tabular-nums;"
                >
                  {dateFormatter.format(entry.data.added)}
                </time>
                <Link href={entry.data.url} external>
                  {entry.data.title}
                </Link>
                {(entry.data.author || entry.data.source) && (
                  <span class="text-black/55 dark:text-white/60">
                    {[entry.data.author, entry.data.source].filter(Boolean).join(", ")}
                  </span>
                )}
              </div>
              <p class="text-sm leading-relaxed text-black/75 dark:text-white/75">
                {entry.data.summary}
              </p>
              <div class="font-mono text-[10px] uppercase tracking-widest text-black/40 dark:text-white/40">
                slug: {slug}
              </div>
            </li>
          ))}
        </ul>
      </section>

      {
        relatedConcepts.length > 0 && (
          <section class="space-y-4">
            <h2 class="font-mono text-xs uppercase tracking-wider text-black/50 dark:text-white/60">
              Related concepts
            </h2>
            <ul class="not-prose flex flex-wrap gap-3 text-sm">
              {relatedConcepts.map((slug) => (
                <li>
                  <Link href={`/wiki/${slug}/`}>{slug}</Link>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </div>
  </Container>
</Layout>
