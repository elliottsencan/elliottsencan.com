---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Breadcrumb from "@components/Breadcrumb.astro";
import Link from "@components/Link.astro";
import MetaLine from "@components/MetaLine.astro";
import PageBody from "@components/PageBody.astro";
import PageHero from "@components/PageHero.astro";
import ConstellationLocal from "@components/wiki/ConstellationLocal.astro";
import constellationLayout from "@data/constellation-layout.json";
import Layout from "@layouts/Layout.astro";
import { SITE_TIMEZONE } from "@lib/utils";
import { buildWikiLinkGraph, resolveRelatedConcepts, type WikiLinkGraph } from "@lib/wiki-graph";

export async function getStaticPaths() {
  const concepts = await getCollection("wiki");
  const graph = buildWikiLinkGraph(concepts.map((c) => ({ id: c.id, body: c.body ?? "" })));
  const knownSlugs = new Set(concepts.map((c) => c.id));
  // "Concept N / total" header flourish — N is the concept's position in
  // the same title ordering the index directory uses.
  const byTitle = [...concepts].sort((a, b) => a.data.title.localeCompare(b.data.title));
  const indexById = new Map(byTitle.map((c, i) => [c.id, i + 1]));
  return concepts.map((concept) => ({
    params: { slug: concept.id },
    props: {
      concept,
      graph,
      knownSlugs,
      conceptIndex: indexById.get(concept.id) ?? 0,
      conceptTotal: concepts.length,
    },
  }));
}

type Props = {
  concept: CollectionEntry<"wiki">;
  graph: WikiLinkGraph;
  knownSlugs: Set<string>;
  conceptIndex: number;
  conceptTotal: number;
};
const { concept, graph, knownSlugs, conceptIndex, conceptTotal } = Astro.props;
const { Content } = await render(concept);

// ─── Sources ─────────────────────────────────────────────────────────────
// Citation order = first appearance of each `/reading/<slug>` link in the
// raw markdown body, then any frontmatter sources that the body never cited
// (appended in declared order, with continuing numbers). The same map drives
// the right-margin rail and the inline-superscript injector below.

const READING_MD_RE = /\[[^\]]*\]\(\/reading\/([a-z0-9-]+(?:\/[a-z0-9-]+)*)\/?(?:[#?][^)]*)?\)/g;
const FENCED_MD_RE = /```[\s\S]*?```/g;
const INLINE_MD_RE = /`[^`\n]*`/g;

const numberBySlug = new Map<string, number>();
const sourceOrder: string[] = [];

const sanitizedBody = (concept.body ?? "").replace(FENCED_MD_RE, "").replace(INLINE_MD_RE, "");
for (const m of sanitizedBody.matchAll(READING_MD_RE)) {
  const slug = m[1];
  if (slug && !numberBySlug.has(slug)) {
    numberBySlug.set(slug, numberBySlug.size + 1);
    sourceOrder.push(slug);
  }
}
for (const slug of concept.data.sources) {
  if (!numberBySlug.has(slug)) {
    numberBySlug.set(slug, numberBySlug.size + 1);
    sourceOrder.push(slug);
  }
}

const reading = await getCollection("reading");
const sourceMap = new Map(reading.map((entry) => [entry.id, entry]));
const sources = sourceOrder
  .map((slug) => ({
    slug,
    number: numberBySlug.get(slug) ?? 0,
    entry: sourceMap.get(slug),
  }))
  .filter((s): s is { slug: string; number: number; entry: NonNullable<typeof s.entry> } =>
    Boolean(s.entry),
  );
const missingSources = sourceOrder.filter((slug) => !sourceMap.has(slug));
if (missingSources.length > 0) {
  console.warn(
    `[wiki:${concept.id}] ${missingSources.length} missing source slug(s): ${missingSources.join(", ")}`,
  );
}

// Source-heavy concepts collapse the rail behind a no-JS <details> expander
// past the first 8 entries. `sources` is citation-order (body-cited first),
// so the visible 8 are the ones the prose actually leans on.
const RAIL_VISIBLE = 8;
const railSources = sources.length > RAIL_VISIBLE ? sources.slice(0, RAIL_VISIBLE) : sources;
const railOverflow = sources.length > RAIL_VISIBLE ? sources.slice(RAIL_VISIBLE) : [];

// JSON map shipped to the inline post-processor that injects `<sup>`s after
// each `/reading/<slug>` link in the rendered body. Using slug → number
// keeps the script trivial and resilient to legacy entries.
const numberBySlugJson = JSON.stringify(Object.fromEntries(numberBySlug));

// ─── Related concepts ────────────────────────────────────────────────────

const { related: relatedConcepts, hallucinated } = resolveRelatedConcepts(
  graph,
  concept.id,
  concept.data.related_concepts,
  knownSlugs,
);
if (hallucinated.length > 0) {
  console.warn(
    `[wiki:${concept.id}] ${hallucinated.length} hallucinated related_concept(s): ${hallucinated.join(", ")}`,
  );
}

const conceptById = new Map((await getCollection("wiki")).map((c) => [c.id, c]));

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "2-digit",
  month: "short",
  year: "numeric",
  timeZone: SITE_TIMEZONE,
});

// Citations point at the contributing /reading/<slug> entries — search engines
// read this as "this synthesis cites these sources." Absolute URLs because
// schema.org `citation` items should be dereferenceable.
const citations = sources.map(({ slug }) => `https://elliottsencan.com/reading/${slug}/`);
const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Wiki", url: "/wiki/" },
  { name: concept.data.title, url: `/wiki/${concept.id}/` },
];

// ─── Constellation caption data ──────────────────────────────────────────
// The 3-row × 2-col hero grid mirrors /wiki — col 2 holds the local
// constellation in rows 1-2 with its caption (cluster · neighbors) sitting
// inside the well's bottom padding so figure + caption read as one object.
// The layout caps drawn neighbors at 14; when the cluster has more, the
// caption reads "<total> neighbors · <shown> shown".
type ConstellationCluster = { id: string; title: string; short: string; hue: number };
const constellationClusters: ConstellationCluster[] = constellationLayout.clusters;
const constellationClusterById: Record<string, string | null> = constellationLayout.clusterById;
const constellationLocal: Record<string, { nodes: { id: string }[]; neighborTotal?: number }> =
  constellationLayout.local;

const localData = constellationLocal[concept.id];
const hasLocal = !!localData && localData.nodes.length > 1;
const myClusterId = constellationClusterById[concept.id] ?? null;
const myCluster = myClusterId
  ? (constellationClusters.find((c) => c.id === myClusterId) ?? null)
  : null;
const neighborsShown = hasLocal ? localData.nodes.length - 1 : 0;
const neighborTotal = hasLocal ? (localData.neighborTotal ?? neighborsShown) : 0;
---

<Layout
  title={`Wiki: ${concept.data.title}`}
  description={concept.data.summary}
  ogType="article"
  schemaType="Article"
  publishedTime={concept.data.compiled_at}
  updatedTime={concept.data.last_source_added}
  citations={citations}
  breadcrumbs={breadcrumbs}
>
  <PageBody data-pagefind-body data-pagefind-filter="type:Wiki">
    {/*
      Header zone (B2) — no tinted band. The breadcrumb row pairs the
      back-nav with a "Concept N / total" mono flourish; PageHero sets
      title + standfirst + MetaLine against the unboxed local
      constellation and closes the zone with its dotted rule.

      NB: must NOT use bare <header> — global.css fixes-positions every
      <header> as site chrome (CLAUDE.md: "bare tags are reserved").
    */}
    <PageHero breadcrumb asideWidth="420px" asideAlign="center">
      <Fragment slot="breadcrumb">
        <div class="flex items-center gap-4">
          <div class="min-w-0 flex-1">
            <Breadcrumb parent={{ label: "Wiki", href: "/wiki/" }} />
          </div>
          {
            conceptIndex > 0 && (
              <span
                class="shrink-0 font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55"
                style="font-variant-numeric: tabular-nums;"
              >
                Concept {conceptIndex} / {conceptTotal}
              </span>
            )
          }
        </div>
      </Fragment>
      <Fragment slot="title">{concept.data.title}</Fragment>
      <Fragment slot="summary">{concept.data.summary}</Fragment>
      <MetaLine
        slot="meta"
        segments={[
          "Compiled by Claude",
          { date: concept.data.compiled_at },
          `${sources.length} source${sources.length === 1 ? "" : "s"}`,
          { text: "How this works →", href: "/wiki/how-this-works" },
        ]}
      />
      {
        hasLocal && (
          <div slot="aside" class="flex min-w-0 flex-col gap-2">
            <ConstellationLocal slug={concept.id} width={420} />
            <p class="m-0 flex flex-wrap justify-end gap-x-2.5 font-mono text-xs tracking-wider text-black/55 dark:text-white/55">
              {myCluster && (
                <>
                  <span>{myCluster.short}</span>
                  <span aria-hidden="true" class="text-black/25 dark:text-white/25">
                    &middot;
                  </span>
                </>
              )}
              <span>
                {neighborTotal} neighbor{neighborTotal === 1 ? "" : "s"}
              </span>
              {neighborTotal > neighborsShown && (
                <>
                  <span aria-hidden="true" class="text-black/25 dark:text-white/25">
                    &middot;
                  </span>
                  <span>{neighborsShown} shown</span>
                </>
              )}
            </p>
          </div>
        )
      }
    </PageHero>

    {/*
      Body row — prose on the left, sticky sources rail on the right. The
      rail collapses below the body on narrow screens.
      NB: must NOT use <article> — global.css applies `prose` (max-width:
      65ch) to every <article>, which can win over Tailwind utilities and
      collapse the body in this 2-col grid. The wiki-body class below
      carries the prose styling without the global side-effect.
    */}
    <div class="grid gap-10 md:grid-cols-[minmax(0,1fr)_300px] md:gap-14">
      <div id="wiki-body" class="wiki-body min-w-0">
        <Content />
      </div>

      <aside class="wiki-rail md:sticky md:top-28 md:self-start">
        <p class="m-0 font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
          Sources
        </p>
        <div role="presentation" aria-hidden="true" class="dot-rule mt-3 h-px w-full"></div>
        <ol class="not-prose m-0 flex list-none flex-col p-0 text-sm">
          {railSources.map(({ slug, number, entry }) => (
            <li class="rail-card" data-src={slug}>
              <span class="rail-num" data-src={slug} aria-hidden="true">
                {number}
              </span>
              <div class="flex min-w-0 flex-col gap-1">
                <a
                  href={entry.data.url}
                  target="_blank"
                  rel="noopener"
                  class="rail-title text-sm font-medium leading-[1.35] text-black underline decoration-black/10 underline-offset-[3px] hover:decoration-black/55 dark:text-white dark:decoration-white/15 dark:hover:decoration-white/55"
                >
                  {entry.data.title}
                </a>
                <span class="font-mono text-xs tracking-wide text-black/45 dark:text-white/45">
                  {(entry.data.author ?? entry.data.source) && (
                    <>
                      <span class="[overflow-wrap:anywhere]">
                        {entry.data.author ?? entry.data.source}
                      </span>
                      {" · "}
                    </>
                  )}
                  <span class="whitespace-nowrap">{dateFormatter.format(entry.data.added)}</span>
                </span>
              </div>
            </li>
          ))}
        </ol>
        {
          railOverflow.length > 0 ? (
            <details class="rail-more">
              <summary class="mt-2 w-fit cursor-pointer list-none font-mono text-xs tracking-wider text-black/55 hover:text-[color:var(--accent)] dark:text-white/55 [&::-webkit-details-marker]:hidden">
                +{railOverflow.length} more source{railOverflow.length === 1 ? "" : "s"}
              </summary>
              <ol class="not-prose m-0 flex list-none flex-col p-0 text-sm">
                {railOverflow.map(({ slug, number, entry }) => (
                  <li class="rail-card" data-src={slug}>
                    <span class="rail-num" data-src={slug} aria-hidden="true">
                      {number}
                    </span>
                    <div class="flex min-w-0 flex-col gap-1">
                      <a
                        href={entry.data.url}
                        target="_blank"
                        rel="noopener"
                        class="rail-title text-sm font-medium leading-[1.35] text-black underline decoration-black/10 underline-offset-[3px] hover:decoration-black/55 dark:text-white dark:decoration-white/15 dark:hover:decoration-white/55"
                      >
                        {entry.data.title}
                      </a>
                      <span class="font-mono text-xs tracking-wide text-black/45 dark:text-white/45">
                        {(entry.data.author ?? entry.data.source) && (
                          <>
                            <span class="[overflow-wrap:anywhere]">
                              {entry.data.author ?? entry.data.source}
                            </span>
                            {" · "}
                          </>
                        )}
                        <span class="whitespace-nowrap">
                          {dateFormatter.format(entry.data.added)}
                        </span>
                      </span>
                    </div>
                  </li>
                ))}
              </ol>
              <p class="mt-4">
                <a
                  href="/reading"
                  class="font-mono text-xs tracking-wider text-[color:var(--accent)] no-underline transition-colors duration-300 ease-in-out hover:underline focus-visible:underline"
                >
                  view in /reading →
                </a>
              </p>
            </details>
          ) : (
            <p class="mt-4">
              <a
                href="/reading"
                class="font-mono text-xs tracking-wider text-[color:var(--accent)] no-underline transition-colors duration-300 ease-in-out hover:underline focus-visible:underline"
              >
                view in /reading →
              </a>
            </p>
          )
        }
      </aside>
    </div>

    {/*
      Ambient related-concepts strip — sits below the body. Soft cards, not
      a list. Concept names link into their entry pages; summaries are
      truncated so the strip stays scannable.
    */}
    {
      relatedConcepts.length > 0 && (
        <section class="space-y-4">
          {/* Mono-caps label + dot rule — same label idiom as the rail's
              SOURCES heading and the index's group labels, fused with the
              LabeledRule dot-row so the chapter break stays. */}
          <div class="flex items-center gap-4">
            <h2 class="shrink-0 font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
              Related concepts
            </h2>
            <div role="presentation" aria-hidden="true" class="dot-rule h-px flex-1 py-2" />
          </div>
          <ul class="not-prose grid grid-cols-[repeat(auto-fill,minmax(210px,1fr))] gap-3">
            {relatedConcepts.map((slug) => {
              const rc = conceptById.get(slug);
              if (!rc) return null;
              const blurb = rc.data.summary.split(/[,;]/)[0].slice(0, 96);
              return (
                <li>
                  <a
                    href={`/wiki/${slug}/`}
                    class="group flex h-full flex-col gap-1.5 rounded-sm border border-black/5 bg-[color:var(--card)] px-3.5 py-3 no-underline dark:border-white/[0.06]"
                  >
                    <span class="font-heading text-sm font-medium leading-tight tracking-tight text-black transition-colors duration-300 ease-in-out group-hover:text-[color:var(--accent)] group-focus-visible:text-[color:var(--accent)] dark:text-white">
                      {/* NBSP joins the arrow to the title's last word so it
                          can't widow onto its own line. */}
                      {`${rc.data.title}\u00A0→`}
                    </span>
                    <span class="text-xs leading-relaxed text-black/55 dark:text-white/55">
                      {blurb}…
                    </span>
                    <span class="mt-auto pt-1 font-mono text-xs uppercase tracking-[0.18em] text-black/40 dark:text-white/40">
                      {rc.data.sources.length} sources
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      )
    }
  </PageBody>

  {/*
    Build-time-computed slug → citation-number map, consumed by the inline
    sup-injector below. Inlined as JSON so the script can read it without an
    extra fetch, and so the rail and body always agree on numbering.
  */}
  <script
    is:inline
    type="application/json"
    id="wiki-source-numbers"
    set:html={numberBySlugJson}
  />

  <script is:inline>
    /*
     * Two passes on page load:
     *
     *   1. Walk every `/reading/<slug>` link in the wiki body and inject a
     *      numbered <sup> after it, plus tag both link and sup with a
     *      `data-src="<slug>"` attribute. The numbers come from a build-
     *      time JSON map so they always match the right-margin rail.
     *
     *   2. Bind hover handlers across every `[data-src]` element on the
     *      page (rail card, rail chip, inline sup, inline link). Hovering
     *      any one of them adds an `is-active` class to every other element
     *      that shares the same slug — so the rail card and the inline
     *      citation light up together. Pure CSS can't do this kind of
     *      cross-tree value-aware match without per-slug rules; the JS is
     *      tiny and read-only.
     */
    (function () {
      function setActive(slug, on) {
        if (!slug) return;
        const escaped = window.CSS && CSS.escape ? CSS.escape(slug) : slug;
        const matches = document.querySelectorAll('[data-src="' + escaped + '"]');
        matches.forEach((el) => el.classList.toggle("is-active", on));
      }

      function bindSync(el) {
        if (el.dataset.syncBound === "1") return;
        el.dataset.syncBound = "1";
        const slug = el.getAttribute("data-src");
        el.addEventListener("mouseenter", () => setActive(slug, true));
        el.addEventListener("mouseleave", () => setActive(slug, false));
        el.addEventListener("focusin", () => setActive(slug, true));
        el.addEventListener("focusout", () => setActive(slug, false));
      }

      function run() {
        const data = document.getElementById("wiki-source-numbers");
        const body = document.getElementById("wiki-body");
        if (!data || !body) return;
        let map;
        try {
          map = JSON.parse(data.textContent || "{}");
        } catch {
          return;
        }

        // Pass 1 — inject numbered sups + tag the matching link.
        const links = body.querySelectorAll('a[href^="/reading/"]');
        links.forEach((a) => {
          const href = a.getAttribute("href") || "";
          const m = href.match(/^\/reading\/([a-z0-9-]+(?:\/[a-z0-9-]+)*)\/?(?:[#?].*)?$/);
          if (!m) return;
          const slug = m[1];
          const n = map[slug];
          if (typeof n !== "number") return;
          a.classList.add("wlink-source");
          a.setAttribute("data-src", slug);
          if (!a.nextElementSibling || !a.nextElementSibling.classList.contains("wlink-num")) {
            const sup = document.createElement("sup");
            sup.className = "wlink-num";
            sup.setAttribute("data-src", slug);
            sup.textContent = String(n);
            a.after(sup);
          }
        });

        // Pass 2 — bind bidirectional hover sync across every data-src node.
        document.querySelectorAll("[data-src]").forEach(bindSync);
      }
      run();
    })();
  </script>
</Layout>

<style is:global>
  /* Wiki body prose — same visual as the global article rule but scoped to
     a class so it doesn't collide with the 2-column grid track sizing. */
  .wiki-body {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.7;
    color: rgb(0 0 0 / 0.85);
  }
  .dark .wiki-body {
    color: rgb(255 255 255 / 0.85);
  }
  .wiki-body > * + * {
    margin-top: 1.1em;
  }
  .wiki-body p {
    margin: 0;
  }
  .wiki-body p + p {
    margin-top: 1.1em;
  }
  .wiki-body h2 {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1.25em;
    color: rgb(0 0 0);
    margin-top: 1.8em;
    margin-bottom: 0.4em;
    letter-spacing: -0.01em;
  }
  .dark .wiki-body h2 {
    color: rgb(255 255 255);
  }
  .wiki-body h3 {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1.1em;
    color: rgb(0 0 0);
    margin-top: 1.5em;
    margin-bottom: 0.3em;
  }
  .dark .wiki-body h3 {
    color: rgb(255 255 255);
  }
  .wiki-body strong {
    font-weight: 600;
    color: rgb(0 0 0);
  }
  .dark .wiki-body strong {
    color: rgb(255 255 255);
  }
  .wiki-body em {
    font-style: italic;
  }
  .wiki-body a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: rgb(0 0 0 / 0.25);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    transition:
      color 200ms ease-in-out,
      text-decoration-color 200ms ease-in-out;
  }
  .dark .wiki-body a {
    text-decoration-color: rgb(255 255 255 / 0.3);
  }
  .wiki-body a:hover {
    color: rgb(0 0 0);
    text-decoration-color: rgb(0 0 0 / 0.5);
  }
  .dark .wiki-body a:hover {
    color: rgb(255 255 255);
    text-decoration-color: rgb(255 255 255 / 0.5);
  }
  .wiki-body ul,
  .wiki-body ol {
    padding-left: 1.4em;
    margin: 0;
  }
  .wiki-body li + li {
    margin-top: 0.4em;
  }
  .wiki-body code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: rgb(0 0 0 / 0.06);
    padding: 1px 5px;
    border-radius: 2px;
  }
  .dark .wiki-body code {
    background: rgb(255 255 255 / 0.08);
  }
  .wiki-body blockquote {
    border-left: 2px solid rgb(0 0 0 / 0.2);
    padding-left: 1.2em;
    margin: 0;
    color: rgb(0 0 0 / 0.75);
  }
  .dark .wiki-body blockquote {
    border-left-color: rgb(255 255 255 / 0.2);
    color: rgb(255 255 255 / 0.75);
  }

  /* Inline citation superscripts — accent mono figures keyed to the
     right-margin rail (matches the rail's hanging citation numbers). */
  .wiki-body .wlink-num {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--accent);
    margin-left: 2px;
    vertical-align: super;
    line-height: 1;
    cursor: pointer;
    transition: opacity 120ms ease-in-out;
    font-feature-settings: normal;
  }
  .wiki-body .wlink-source {
    text-decoration-style: dotted;
  }

  /* Sources rail — unboxed. Hanging accent citation number in a fixed
     gutter, hairline separators between cards, no panel fill. */
  .wiki-rail .rail-card {
    display: grid;
    grid-template-columns: 26px minmax(0, 1fr);
    column-gap: 0.625rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgb(0 0 0 / 0.05);
    line-height: 1.25;
    cursor: default;
  }
  .dark .wiki-rail .rail-card {
    border-bottom-color: rgb(255 255 255 / 0.06);
  }
  .wiki-rail .rail-num {
    padding-top: 2px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 500;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    font-feature-settings: normal;
    transition: opacity 160ms ease-in-out;
    opacity: 0.85;
  }

  /* Bidirectional hover sync — the JS toggles `.is-active` on every
     element that shares a `data-src` value with the hovered one, so
     the rail card, hanging number, inline sup, and inline link all
     light up together. Pure-CSS sibling matching can't do this. */
  .wiki-rail .rail-card.is-active,
  .wiki-rail .rail-card:hover {
    background: color-mix(in oklch, var(--accent) 7%, transparent);
  }
  .wiki-rail .rail-card.is-active .rail-num,
  .wiki-rail .rail-card:hover .rail-num,
  .wiki-rail .rail-num.is-active {
    opacity: 1;
    font-weight: 700;
  }
  .wiki-rail .rail-card.is-active .rail-title {
    text-decoration-color: var(--accent);
  }
  .wiki-body .wlink-num.is-active,
  .wiki-body .wlink-num:hover {
    font-weight: 700;
  }
  .wiki-body .wlink-source.is-active {
    text-decoration-color: var(--accent);
  }
</style>
