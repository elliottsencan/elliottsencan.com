---
import { type CollectionEntry, getCollection } from "astro:content";
import Container from "@components/Container.astro";
import EditorialList from "@components/EditorialList.astro";
import EditorialListItem from "@components/EditorialListItem.astro";
import EditorialRule from "@components/EditorialRule.astro";
import HeroMeta from "@components/HeroMeta.astro";
import Link from "@components/Link.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import PageHero from "@components/PageHero.astro";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const all = (await getCollection("blog")).filter((p) => !p.data.draft);
  const years = new Set(all.map((p) => p.data.date.getFullYear().toString()));
  return [...years].map((year) => ({
    params: { year },
    props: {
      year,
      posts: all
        .filter((p) => p.data.date.getFullYear().toString() === year)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

type Props = { year: string; posts: CollectionEntry<"blog">[] };
const { year, posts } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout
  title={`Writing: ${year}`}
  description={`Writing from ${year} — ${posts.length} post${posts.length === 1 ? "" : "s"}.`}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Writing", url: "/writing/" },
    { name: year, url: `/writing/${year}/` },
  ]}
>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:Writing"
    >
      <PageHero breadcrumb>
        <Fragment slot="breadcrumb">
          <Breadcrumb parent={{ label: "Writing", href: "/writing/" }} current={year} />
        </Fragment>
        <Fragment slot="title">{year}</Fragment>
        <Fragment slot="summary">
          {posts.length} post{posts.length === 1 ? "" : "s"} from {year}.
        </Fragment>
        <HeroMeta
          slot="meta"
          count={posts.length}
          label={`${posts.length} post${posts.length === 1 ? "" : "s"}`}
        />
      </PageHero>

      <EditorialList>
        {
          posts.map((post) => (
            <EditorialListItem
              title={post.data.title}
              href={`/writing/${post.id}`}
              meta={dateFormatter.format(post.data.date)}
              metaDateTime={post.data.date.toISOString()}
            >
              {post.data.description}
            </EditorialListItem>
          ))
        }
      </EditorialList>

      <EditorialRule />

      <p class="text-xs text-black/55 dark:text-white/55">
        <Link href="/writing">back to /writing</Link>
      </p>
    </div>
  </Container>
</Layout>
