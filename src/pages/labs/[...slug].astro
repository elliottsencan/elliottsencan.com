---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Breadcrumb from "@components/Breadcrumb.astro";
import EditorialRule from "@components/EditorialRule.astro";
import Link from "@components/Link.astro";
import LabResult from "@components/labs/LabResult.astro";
import MetaLine from "@components/MetaLine.astro";
import PageBody from "@components/PageBody.astro";
import PageHero from "@components/PageHero.astro";
import Layout from "@layouts/Layout.astro";
import { loadLabData } from "@lib/lab-data";
import { SITE_TIMEZONE } from "@lib/utils";

// Individual lab cell — question → answer → evidence → receipts. The
// question (hypothesis) is the h1 under a mono accent label; the headline
// value counterweights it at instrument scale in the hero's right column.
// The chart sits in a full-width `--well` evidence band (see ResultCell),
// and the right rail keeps the operational dl plus a Receipts code block
// (the `pre` frontmatter snippet, moved out of the body).
//
// Mobile: every grid in this page is single-col at base and only switches
// to two at `md:`. SVG charts use viewBox so they fluid down without
// horizontal scroll.

export async function getStaticPaths() {
  const cells = await getCollection("labs");
  return cells.map((cell) => ({
    params: { slug: cell.id },
    props: { cell },
  }));
}

type Props = {
  cell: CollectionEntry<"labs">;
};

const { cell } = Astro.props;
const { Content } = await render(cell);
const data = await loadLabData(cell.data.dataPath);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  timeZone: SITE_TIMEZONE,
});

function isoDate(date: Date): string {
  const parts = dateFormatter.formatToParts(date);
  const y = parts.find((p) => p.type === "year")?.value ?? "";
  const m = parts.find((p) => p.type === "month")?.value ?? "";
  const d = parts.find((p) => p.type === "day")?.value ?? "";
  return `${y}-${m}-${d}`;
}

function statusLabel(status: string): string {
  return status === "draft" ? "first-run pending" : status;
}

const isNoData =
  data === null ||
  (typeof data === "object" &&
    data !== null &&
    (data as { status?: unknown }).status === "no-data");
const isPending = cell.data.status === "draft" || isNoData;
const isLive = cell.data.status === "live";

// Methodology is an optional frontmatter block — when present on a
// pending cell, LabResult renders it as the explicit "what will run"
// card instead of the quiet dashed baseline. See README for the schema
// patch.
const methodology = (
  cell.data as {
    methodology?: {
      steps?: string[];
      receipts?: { label: string; value: string }[];
      code?: string;
    };
  }
).methodology;
---

<Layout title={`Labs: ${cell.data.title}`} description={cell.data.tldr}>
  <PageBody data-pagefind-body data-pagefind-filter="type:Labs">
    {/* The question is the h1; the answer is the counter-weight. */}
    <PageHero breadcrumb size="statement" asideWidth="340px" asideAlign="end">
      <Fragment slot="breadcrumb">
        <Breadcrumb parent={{ label: "Labs", href: "/labs/" }} />
      </Fragment>
      <Fragment slot="eyebrow">The question</Fragment>
      <Fragment slot="title">{cell.data.hypothesis}</Fragment>
      <Fragment slot="summary">{cell.data.title} — {cell.data.tldr}</Fragment>
      <div slot="aside" class="md:pb-1 md:text-right">
        <span
          class:list={[
            "num-display block text-num-xl",
            isPending ? "text-black/40 dark:text-white/40" : "text-black dark:text-white",
          ]}
          style="overflow-wrap: anywhere;"
        >
          {cell.data.headlineMetric.value}
        </span>
        <span class="mt-3 block font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
          {cell.data.headlineMetric.label}
        </span>
      </div>
    </PageHero>

    {/* Evidence band — full-width well strip (chrome lives in ResultCell);
        the header slot is the mono caption row above the chart. */}
    <LabResult kind={cell.data.kind} data={data} size="full" methodology={methodology}>
      <div
        slot="header"
        class="mb-6 flex flex-wrap items-baseline justify-between gap-x-10 gap-y-2"
      >
        <span class="font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
          Evidence
        </span>
        <MetaLine mark={false} segments={["last run", { date: cell.data.lastRunDate }]} />
      </div>
    </LabResult>

    {/* Body row — prose on the left, operational rail + receipts right. */}
    <div class="grid gap-10 md:grid-cols-[minmax(0,1fr)_300px] md:gap-14">
      <div class="min-w-0">
        <div class="lab-body space-y-4">
          <Content />
          {cell.data.post && <p>{cell.data.post}</p>}
        </div>
      </div>

      <aside class="flex flex-col gap-5 md:sticky md:top-28 md:self-start">
        <dl class="flex flex-col gap-4">
          <div class="grid grid-cols-[110px_minmax(0,1fr)] items-baseline gap-4">
            <dt class="font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
              Status
            </dt>
            <dd
              class:list={[
                "m-0 font-mono text-xs",
                isLive ? "text-[color:var(--accent)]" : "text-black/55 dark:text-white/55",
              ]}
            >
              {statusLabel(cell.data.status)}
            </dd>
          </div>

          <div class="grid grid-cols-[110px_minmax(0,1fr)] items-baseline gap-4">
            <dt class="font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
              Published
            </dt>
            <dd class="m-0 font-mono text-xs text-black/65 dark:text-white/65">
              {isoDate(cell.data.publishedDate)}
            </dd>
          </div>

          <div class="grid grid-cols-[110px_minmax(0,1fr)] items-baseline gap-4">
            <dt class="font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
              Last run
            </dt>
            <dd class="m-0 font-mono text-xs text-black/65 dark:text-white/65">
              {isoDate(cell.data.lastRunDate)}
            </dd>
          </div>

          {
            cell.data.repoUrl && (
              <div class="grid grid-cols-[110px_minmax(0,1fr)] items-baseline gap-4">
                <dt class="font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
                  Repo
                </dt>
                <dd class="m-0 text-xs">
                  <Link href={cell.data.repoUrl} external>
                    source ↗
                  </Link>
                </dd>
              </div>
            )
          }

          {
            cell.data.blogPostSlug && (
              <div class="grid grid-cols-[110px_minmax(0,1fr)] items-baseline gap-4">
                <dt class="font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
                  Cited by
                </dt>
                <dd class="m-0 text-xs">
                  <Link href={`/writing/${cell.data.blogPostSlug}/`}>
                    {cell.data.blogPostSlug}
                  </Link>
                </dd>
              </div>
            )
          }

          {
            cell.data.tags.length > 0 && (
              <div class="grid grid-cols-[110px_minmax(0,1fr)] items-baseline gap-4">
                <dt class="font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
                  Tags
                </dt>
                <dd class="m-0 font-mono text-xs text-black/65 dark:text-white/65">
                  {cell.data.tags.join(" · ")}
                </dd>
              </div>
            )
          }
        </dl>

        {
          cell.data.pre && (
            <>
              <div role="presentation" aria-hidden="true" class="dot-rule my-1 h-px w-full py-2" />
              <span class="font-mono text-xs uppercase tracking-[0.18em] text-black/55 dark:text-white/55">
                Receipts
              </span>
              <pre class="m-0 overflow-x-auto whitespace-pre bg-black/5 px-4 py-3.5 font-mono text-xs leading-[1.7] text-black/65 dark:bg-white/5 dark:text-white/65">{cell.data.pre}</pre>
            </>
          )
        }
      </aside>
    </div>

    <EditorialRule />

    <p class="text-xs text-black/55 dark:text-white/55">
      <Link href="/labs">back to /labs</Link>
    </p>
  </PageBody>
</Layout>

<style is:global>
  .lab-body {
    font-family: var(--font-sans);
    line-height: 1.7;
    color: rgb(0 0 0 / 0.85);
  }
  .dark .lab-body {
    color: rgb(255 255 255 / 0.85);
  }
  .lab-body p {
    margin: 0;
  }
  .lab-body p + p {
    margin-top: 1.1em;
  }
  .lab-body ul {
    margin: 1.1em 0 0;
    padding-left: 1.25em;
    list-style: disc outside;
  }
  .lab-body li {
    margin-top: 0.5em;
    padding-left: 0.25em;
  }
  .lab-body li::marker {
    color: rgb(0 0 0 / 0.35);
  }
  .dark .lab-body li::marker {
    color: rgb(255 255 255 / 0.35);
  }
  .lab-body strong {
    font-weight: 600;
    color: rgb(0 0 0 / 0.95);
  }
  .dark .lab-body strong {
    color: rgb(255 255 255 / 0.95);
  }
  .lab-body a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: rgb(0 0 0 / 0.25);
    text-underline-offset: 4px;
  }
  .dark .lab-body a {
    text-decoration-color: rgb(255 255 255 / 0.3);
  }
  .lab-body code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 0.1em 0.35em;
    border-radius: 3px;
    background: rgb(0 0 0 / 0.05);
  }
  .dark .lab-body code {
    background: rgb(255 255 255 / 0.08);
  }
</style>
