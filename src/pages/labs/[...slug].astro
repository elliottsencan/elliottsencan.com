---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import Link from "@components/Link.astro";
import CodeCell from "@components/labs/CodeCell.astro";
import LabResult from "@components/labs/LabResult.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import PageHero from "@components/PageHero.astro";
import Layout from "@layouts/Layout.astro";
import { loadLabData } from "@lib/lab-data";
import { SITE_TIMEZONE } from "@lib/utils";

// Individual lab cell — keeps the prose + sticky right rail layout from
// the previous version. The only material change is the result card,
// which now renders the chart pair (DailyBars + CumulativeArea) for
// cost-shaped data and an explicit PendingMethodology card for cells
// still awaiting their first run.
//
// Mobile: every grid in this page (the body/rail split, the headline
// + chart block inside LabResult, the methodology card) is single-col
// at base and only switches to two at `md:`. SVG charts use viewBox so
// they fluid down without horizontal scroll.

export async function getStaticPaths() {
  const cells = await getCollection("labs");
  return cells.map((cell) => ({
    params: { slug: cell.id },
    props: { cell },
  }));
}

type Props = {
  cell: CollectionEntry<"labs">;
};

const { cell } = Astro.props;
const { Content } = await render(cell);
const data = await loadLabData(cell.data.dataPath);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  timeZone: SITE_TIMEZONE,
});

function isoDate(date: Date): string {
  const parts = dateFormatter.formatToParts(date);
  const y = parts.find((p) => p.type === "year")?.value ?? "";
  const m = parts.find((p) => p.type === "month")?.value ?? "";
  const d = parts.find((p) => p.type === "day")?.value ?? "";
  return `${y}-${m}-${d}`;
}

function statusLabel(status: string): string {
  return status === "draft" ? "first-run pending" : status;
}

const isNoData =
  data === null ||
  (typeof data === "object" &&
    data !== null &&
    (data as { status?: unknown }).status === "no-data");
const isPending = cell.data.status === "draft" || isNoData;
const isLive = cell.data.status === "live";

// Methodology is an optional frontmatter block — when present on a
// pending cell, LabResult renders it as the explicit "what will run"
// card instead of the quiet dashed baseline. See README for the schema
// patch.
const methodology = (
  cell.data as {
    methodology?: {
      steps?: string[];
      receipts?: { label: string; value: string }[];
      code?: string;
    };
  }
).methodology;
---

<Layout title={`Labs: ${cell.data.title}`} description={cell.data.tldr}>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:Labs"
    >
      <PageHero breadcrumb>
        <Fragment slot="breadcrumb">
          <Breadcrumb parent={{ label: "Labs", href: "/labs/" }} current={cell.id} />
        </Fragment>
        <Fragment slot="title">{cell.data.title}</Fragment>
        <Fragment slot="summary">{cell.data.tldr}</Fragment>
      </PageHero>

      {/* Hypothesis — labeled callout so it reads as the bet being
          tested, not just another paragraph. */}
      <div class="flex max-w-[62ch] flex-col gap-2">
        <span
          class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55"
        >
          The question
        </span>
        <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
          {cell.data.hypothesis}
        </p>
      </div>

      {/* Result card — the headline number + viz live inside ResultCell
          via LabResult's "header" slot. On mobile the metric stacks
          above the chart; on md+ they share a row (header sits above
          the chart, but the chart itself splits into the byDay pair). */}
      <LabResult kind={cell.data.kind} data={data} size="full" methodology={methodology}>
        <div
          slot="header"
          class="mb-5 flex flex-col items-baseline gap-1 md:flex-row md:flex-wrap md:gap-x-10 md:gap-y-2"
        >
          <div class="flex flex-col gap-1">
            <span
              class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55"
            >
              {cell.data.headlineMetric.label}
            </span>
            <span
              class:list={[
                "font-heading font-normal leading-none tracking-tight",
                isPending
                  ? "text-2xl text-black/40 dark:text-white/40"
                  : "text-3xl text-black md:text-[2.1rem] dark:text-white",
              ]}
              style="font-variant-numeric: tabular-nums;"
            >
              {cell.data.headlineMetric.value}
            </span>
          </div>
          {/* Optional secondary stats live in the chart `summary` block;
              they render in-card via StatGrid. We deliberately don't
              re-emit them here. */}
        </div>
      </LabResult>

      {/* Body row — prose + optional methodology code on the left, sticky
          operational rail on the right. Mirrors /wiki/[slug]. */}
      <div class="grid gap-8 md:grid-cols-[minmax(0,1fr)_220px] md:gap-12">
        <div class="min-w-0 space-y-6">
          <div class="lab-body space-y-4">
            <Content />
            {cell.data.post && <p>{cell.data.post}</p>}
          </div>
          {
            cell.data.pre && (
              <div class="flex flex-col gap-2">
                <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
                  How it works
                </span>
                <CodeCell lang="js">{cell.data.pre}</CodeCell>
              </div>
            )
          }
        </div>

        <aside class="md:sticky md:top-28 md:self-start">
          <dl class="flex flex-col gap-5">
            <div class="flex flex-col gap-1.5">
              <dt
                class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55"
              >
                Status
              </dt>
              <dd>
                <span
                  class:list={[
                    "inline-flex rounded-sm border border-black/10 px-2 py-0.5 font-mono text-xs uppercase tracking-widest dark:border-white/15",
                    isLive
                      ? "text-[color:var(--accent)]"
                      : "text-black/55 dark:text-white/55",
                  ]}
                >
                  {statusLabel(cell.data.status)}
                </span>
              </dd>
            </div>

            <div class="flex flex-col gap-1.5">
              <dt
                class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55"
              >
                Published
              </dt>
              <dd
                class="font-mono text-xs text-black/65 dark:text-white/65"
              >
                {isoDate(cell.data.publishedDate)}
              </dd>
            </div>

            <div class="flex flex-col gap-1.5">
              <dt
                class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55"
              >
                Last run
              </dt>
              <dd
                class="font-mono text-xs text-black/65 dark:text-white/65"
              >
                {isoDate(cell.data.lastRunDate)}
              </dd>
            </div>

            {
              cell.data.repoUrl && (
                <div class="flex flex-col gap-1.5">
                  <dt class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
                    Repo
                  </dt>
                  <dd class="text-xs">
                    <Link href={cell.data.repoUrl} external>
                      source ↗
                    </Link>
                  </dd>
                </div>
              )
            }

            {
              cell.data.blogPostSlug && (
                <div class="flex flex-col gap-1.5">
                  <dt class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
                    Cited by
                  </dt>
                  <dd class="text-xs">
                    <Link href={`/writing/${cell.data.blogPostSlug}/`}>
                      {cell.data.blogPostSlug}
                    </Link>
                  </dd>
                </div>
              )
            }

            {
              cell.data.tags.length > 0 && (
                <div class="flex flex-col gap-1.5">
                  <dt class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
                    Tags
                  </dt>
                  <dd>
                    <ul class="flex flex-wrap gap-1.5">
                      {cell.data.tags.map((t) => (
                        <li class="rounded bg-black/5 px-2 py-1 font-mono text-xs text-black/65 dark:bg-white/10 dark:text-white/65">
                          {t}
                        </li>
                      ))}
                    </ul>
                  </dd>
                </div>
              )
            }
          </dl>
        </aside>
      </div>

      <EditorialRule />

      <p class="text-xs text-black/55 dark:text-white/55">
        <Link href="/labs">back to /labs</Link>
      </p>
    </div>
  </Container>
</Layout>

<style is:global>
  .lab-body {
    font-family: var(--font-sans);
    line-height: 1.7;
    color: rgb(0 0 0 / 0.85);
  }
  .dark .lab-body {
    color: rgb(255 255 255 / 0.85);
  }
  .lab-body p {
    margin: 0;
  }
  .lab-body p + p {
    margin-top: 1.1em;
  }
  .lab-body ul {
    margin: 1.1em 0 0;
    padding-left: 1.25em;
    list-style: disc outside;
  }
  .lab-body li {
    margin-top: 0.5em;
    padding-left: 0.25em;
  }
  .lab-body li::marker {
    color: rgb(0 0 0 / 0.35);
  }
  .dark .lab-body li::marker {
    color: rgb(255 255 255 / 0.35);
  }
  .lab-body strong {
    font-weight: 600;
    color: rgb(0 0 0 / 0.95);
  }
  .dark .lab-body strong {
    color: rgb(255 255 255 / 0.95);
  }
  .lab-body a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: rgb(0 0 0 / 0.25);
    text-underline-offset: 4px;
  }
  .dark .lab-body a {
    text-decoration-color: rgb(255 255 255 / 0.3);
  }
  .lab-body code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 0.1em 0.35em;
    border-radius: 3px;
    background: rgb(0 0 0 / 0.05);
  }
  .dark .lab-body code {
    background: rgb(255 255 255 / 0.08);
  }
</style>
