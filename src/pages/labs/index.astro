---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import HeroMeta from "@components/HeroMeta.astro";
import Link from "@components/Link.astro";
import CodeCell from "@components/labs/CodeCell.astro";
import Sparkline from "@components/labs/Sparkline.astro";
import PageHero from "@components/PageHero.astro";
import Layout from "@layouts/Layout.astro";
import { loadLabData } from "@lib/lab-data";
import { SITE_TIMEZONE } from "@lib/utils";

// /labs — the measurement layer. Each cell stamps "what was the question,
// what's the number, what does it mean." The index lists every cell in
// reverse-chronological run order. Row chrome here matches /reading and
// /writing: title + slug + summary on the left, headline metric pinned to
// the right, status / when / tags below; sparkline (when the cell is a
// chart with data) drops into a full-width row at the bottom of the cell.
const cells = (await getCollection("labs")).sort(
  (a, b) => b.data.lastRunDate.valueOf() - a.data.lastRunDate.valueOf(),
);

const dataByCellId = new Map<string, unknown>();
for (const cell of cells) {
  const data = await loadLabData(cell.data.dataPath);
  dataByCellId.set(cell.id, data);
}

const liveCount = cells.filter((c) => c.data.status === "live").length;
const pendingCount = cells.filter((c) => c.data.status === "draft").length;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  timeZone: SITE_TIMEZONE,
});

const heroMetaFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "short",
  year: "numeric",
  timeZone: SITE_TIMEZONE,
});
const lastRun = cells[0]?.data.lastRunDate;
const heroMetaLabel = lastRun
  ? `${cells.length} ${cells.length === 1 ? "cell" : "cells"} · ${heroMetaFormatter.format(lastRun)}`
  : `${cells.length} ${cells.length === 1 ? "cell" : "cells"}`;

function formatLastRun(date: Date): string {
  // ISO-style YYYY-MM-DD reads as a build identifier, not a sentence.
  const parts = dateFormatter.formatToParts(date);
  const y = parts.find((p) => p.type === "year")?.value ?? "";
  const m = parts.find((p) => p.type === "month")?.value ?? "";
  const d = parts.find((p) => p.type === "day")?.value ?? "";
  return `${y}-${m}-${d}`;
}

function statusLabel(status: string): string {
  if (status === "draft") {
    return "first-run pending";
  }
  return status;
}
---

<Layout
  title="Labs"
  description="Observable-style cells holding the data behind my writing — cost breakdowns, eval runs, telemetry."
>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:Labs"
    >
      <PageHero>
        <Fragment slot="title">Labs</Fragment>
        <Fragment slot="summary">
          The measurement layer. Each cell is a self-contained measurement
          artifact tied to a real failure mode in the pipeline that compiles{" "}
          <Link href="/wiki">/wiki</Link>: where it costs too much, where its
          summaries drift from the source, where its synthesis crosses from
          useful to wrong.
        </Fragment>
        {
          cells.length > 0 && (
            <HeroMeta slot="meta" count={cells.length} label={heroMetaLabel} />
          )
        }
      </PageHero>

      <div class="space-y-3">
        <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
          Cells live in tiers. Tier 0 is structural: pure-function checks
          over the reading and wiki collections. Tier 1 is semantic:
          per-claim eval against the cited source. Tier 2 and up are
          synthesis quality, voice adherence, recompile stability.
        </p>
        <p class="text-sm leading-relaxed text-black/65 dark:text-white/65">
          Read a cell top-down: question, number, code that produced the
          number, one paragraph of commentary. Cells marked{" "}
          <span class="font-mono text-black/65 dark:text-white/65">
            first-run pending
          </span>{" "}
          have shipped methodology and are waiting on data. They count.
        </p>
      </div>

      {
        cells.length > 0 ? (
          <section data-pagefind-ignore class="space-y-0">
            <p class="pb-3 text-right font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
              {liveCount} live · {pendingCount} pending
            </p>
            <ul class="not-prose flex flex-col">
              {cells.map((cell, i) => {
                const data = dataByCellId.get(cell.id);
                const isPending = cell.data.status === "draft";
                const sparkValues =
                  cell.data.kind === "chart" &&
                  typeof data === "object" &&
                  data !== null &&
                  Array.isArray((data as { values?: unknown }).values)
                    ? (data as { values: number[] }).values
                    : null;
                return (
                  <li
                    class:list={[
                      "group relative grid grid-cols-1 items-baseline gap-x-8 gap-y-3 border-t border-black/10 py-6 md:grid-cols-[minmax(0,1fr)_auto_auto] dark:border-white/10",
                      i === cells.length - 1 &&
                        "border-b border-black/10 dark:border-white/10",
                    ]}
                  >
                    <div class="flex flex-col gap-1.5">
                      {/* Title carries the stretched-link pseudo: clicking
                          anywhere on the row routes to the cell's detail
                          page. The cited-by link below opts out via
                          relative z-10 so it remains independently clickable. */}
                      <Link
                        href={`/labs/${cell.id}/`}
                        class="font-heading text-base font-medium tracking-tight text-black no-underline group-hover:text-[color:var(--accent)] before:absolute before:inset-y-0 before:-inset-x-3 before:rounded-md before:transition-colors before:content-[''] hover:before:bg-black/[0.03] md:before:-inset-x-4 dark:text-white dark:hover:before:bg-white/[0.03]"
                      >
                        {cell.data.title}
                      </Link>
                      <span class="font-mono text-xs tracking-wider text-black/55 dark:text-white/55">
                        cell · {cell.id}
                      </span>
                      <p class="m-0 max-w-[38rem] text-sm leading-relaxed text-black/65 dark:text-white/65">
                        {cell.data.tldr}
                      </p>
                    </div>

                    <div class="flex min-w-[7rem] flex-col gap-1 md:items-end">
                      <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
                        {cell.data.headlineMetric.label}
                      </span>
                      <span
                        class:list={[
                          "font-heading font-medium leading-none tracking-tight",
                          isPending
                            ? "text-2xl text-black/40 dark:text-white/40"
                            : "text-3xl text-black dark:text-white md:text-[2.1rem]",
                        ]}
                        style="font-variant-numeric: tabular-nums;"
                      >
                        {cell.data.headlineMetric.value}
                      </span>
                    </div>

                    <div class="flex min-w-[9rem] flex-col gap-1.5 md:items-end">
                      <span
                        class:list={[
                          "font-mono text-xs uppercase tracking-widest",
                          cell.data.status === "live"
                            ? "text-[color:var(--accent)]"
                            : "text-black/55 dark:text-white/55",
                        ]}
                      >
                        {statusLabel(cell.data.status)}
                      </span>
                      <span class="font-mono text-xs text-black/55 dark:text-white/55">
                        {isPending
                          ? "methodology shipped"
                          : `last run · ${formatLastRun(cell.data.lastRunDate)}`}
                      </span>
                      <span class="flex flex-wrap gap-x-2 gap-y-0.5 md:justify-end">
                        {cell.data.tags.map((t) => (
                          <span class="font-mono text-xs text-black/55 dark:text-white/55">
                            ·{t}
                          </span>
                        ))}
                      </span>
                      {cell.data.blogPostSlug && (
                        <span class="font-mono text-xs text-black/55 dark:text-white/55">
                          cited by{" "}
                          <Link
                            href={`/writing/${cell.data.blogPostSlug}/`}
                            class="relative z-10 font-sans text-xs"
                          >
                            {cell.data.blogPostSlug}
                          </Link>
                        </span>
                      )}
                    </div>

                    {sparkValues && (
                      <div class="block w-full text-black/75 md:col-span-3 dark:text-white/75">
                        <Sparkline data={sparkValues} height={36} />
                      </div>
                    )}
                  </li>
                );
              })}
            </ul>
          </section>
        ) : (
          <div class="space-y-6">
            <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
              Nothing here yet. The labs surface ships ahead of its first
              populated cell so the IA is in place. Cells materialize when a
              post needs receipts — cost numbers, eval runs, p95 by route —
              and stay around so future posts can link forward to them.
            </p>
            <CodeCell lang="js">{`// the next cell will look something like this
const { post, run } = await loadCell({
  hypothesis: "Haiku 4.5 is good enough at link-summary",
  data: "eval-haiku-vs-sonnet.json",
});`}</CodeCell>
          </div>
        )
      }

      <EditorialRule />

      <p class="text-xs text-black/55 dark:text-white/55">
        <Link href="/wiki">wiki →</Link>
      </p>
    </div>
  </Container>
</Layout>
