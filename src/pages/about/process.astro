---
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import PageHero from "@components/PageHero.astro";
import Layout from "@layouts/Layout.astro";

// Each AI-assistance level is addressable by anchor so the badge on a writing
// post can deep-link straight to its definition (e.g. /about/process#light —
// see PostBadges.astro). The internal reference for the workflow described
// here is docs/content-workflow.md; keep the two in sync.
const levels = [
  {
    id: "none",
    label: "none",
    blurb: "No AI involvement at any stage — research, structure, or prose.",
  },
  {
    id: "light",
    label: "light",
    blurb:
      "AI used for narrow tasks like spellcheck, rephrasing a stuck sentence, or looking up a reference. Voice and argument are entirely mine.",
  },
  {
    id: "heavy",
    label: "heavy",
    blurb:
      "AI used across research, outlining, or editing passes. Voice and argument still mine, but AI materially shaped the path from idea to draft.",
  },
  {
    id: "full",
    label: "full",
    blurb:
      "AI produced substantial prose that I edited rather than wrote from scratch. Reserved for experiments; flagged honestly when used.",
  },
];
---

<Layout
  title="Process"
  description="How posts get made, and what AI assistance does and doesn't do in that process."
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "About", url: "/about/" },
    { name: "Process", url: "/about/process/" },
  ]}
>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:Process"
    >
      <PageHero breadcrumb>
        <Fragment slot="breadcrumb">
          <Link href="/about">About</Link> / Process
        </Fragment>
        <Fragment slot="title">Process</Fragment>
        <Fragment slot="summary">
          Every post on <Link href="/">writing</Link> carries a self-declared
          AI-assistance level — the ✱ badge under the title. This page is what
          those labels mean, and how posts actually get made.
        </Fragment>
      </PageHero>

      <section class="space-y-4">
        <LabeledRule>How a post gets made</LabeledRule>
        <div class="space-y-4 text-base leading-relaxed text-black/85 dark:text-white/85">
          <p>
            A post starts as a voice memo — ten to fifteen minutes, no script,
            talking through the ideas and the reasoning out loud. Whisper turns
            the memo into a raw transcript. Claude structures the transcript
            into an outline under tight constraints: preserve the original
            phrasing, group related points under short headings, flag every
            place I trailed off or contradicted myself, and fix nothing. The
            output is a scaffold, not a draft.
          </p>
          <p>
            I write the draft myself, from that scaffold, in my own words. The
            final pass is reading the post aloud — anything that sounds like AI
            wrote it gets cut or rewritten.
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <LabeledRule>Where AI fits</LabeledRule>
        <div class="space-y-4 text-base leading-relaxed text-black/85 dark:text-white/85">
          <p>
            Research and reference-chasing. Structuring a raw transcript into
            an outline. Editing passes on a finished draft — tightening a
            paragraph, cutting a filler clause. Code, both in posts and in the
            site itself. The common thread: AI operates on thinking that
            already happened.
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <LabeledRule>Where AI doesn't fit</LabeledRule>
        <div class="space-y-4 text-base leading-relaxed text-black/85 dark:text-white/85">
          <p>
            The argument, the voice, and the final prose. The point of writing
            here is to work out what I actually think — the thinking is the
            signal, and outsourcing it would defeat the exercise. So AI doesn't
            originate positions, doesn't generate paragraphs from nothing, and
            doesn't get the last read.
          </p>
        </div>
      </section>

      <section id="ai-assistance-levels" class="space-y-4 scroll-mt-24">
        <LabeledRule>AI-assistance levels</LabeledRule>
        <p class="text-sm text-black/70 dark:text-white/70">
          Every post on <Link href="/">writing</Link> is tagged with one of
          these — set honestly, and never under-flagged. The badge links back
          to the matching definition here; when a post has a note about what AI
          specifically did, it shows on hover.
        </p>
        <ul class="not-prose flex flex-col gap-4 text-sm">
          {
            levels.map((level) => (
              <li id={level.id} class="space-y-1 scroll-mt-24">
                <span class="font-medium text-black dark:text-white">
                  AI &middot; {level.label}
                </span>
                <p class="text-black/70 dark:text-white/70">{level.blurb}</p>
              </li>
            ))
          }
        </ul>
      </section>

      <EditorialRule />

      <p class="text-xs text-black/55 dark:text-white/55">
        <Link href="/about">back to /about</Link>
      </p>
    </div>
  </Container>
</Layout>
