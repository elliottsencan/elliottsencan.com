---
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import Link from "@components/Link.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import PageHero from "@components/PageHero.astro";
import { SITE } from "@consts";
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="Colophon"
  description="Typography, stack, and credits for this site."
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "About", url: "/about/" },
    { name: "Colophon", url: "/about/colophon/" },
  ]}
>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:About"
    >
      <PageHero breadcrumb>
        <Fragment slot="breadcrumb">
          <Breadcrumb parent={{ label: "About", href: "/about" }} current="Colophon" />
        </Fragment>
        <Fragment slot="title">Colophon</Fragment>
        <Fragment slot="summary">
          Set in <em>Neue Montreal</em> for headings and interface text,
          <em>Satoshi</em> for running copy, and <em>JetBrains Mono</em> for
          code and small typographic marks. All three self-hosted as WOFF2.
        </Fragment>
      </PageHero>

      <section class="space-y-6 text-base leading-relaxed text-black/85 dark:text-white/85">
        <p>
          Built with <Link href="https://astro.build/" external>Astro</Link>
          and
          <Link href="https://tailwindcss.com/" external>Tailwind CSS</Link>.
          Search by
          <Link href="https://pagefind.app/" external>Pagefind</Link>,
          indexed at build time. Hosted on Cloudflare Pages.
        </p>
        <p>
          Written in {SITE.LOCATION}. The footer activity rail is generated at
          build time from the GitHub GraphQL API.
        </p>
      </section>

      <EditorialRule />

      <p class="text-xs text-black/55 dark:text-white/55">
        <Link href="/about">back to /about</Link>
      </p>
    </div>
  </Container>
</Layout>
