---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import Link from "@components/Link.astro";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("nowArchive");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: entry,
  }));
}

type Props = CollectionEntry<"nowArchive">;

const entry = Astro.props;
const { Content } = await render(entry);

const archivedDate = entry.data.archivedDate;
const formatted = `${archivedDate.toLocaleString("en-US", { month: "long" })} ${archivedDate.getFullYear()}`;
const archivedISO = archivedDate.toISOString().slice(0, 10);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:About"
      data-pagefind-meta={`date:${archivedISO}`}
    >
      <div>
        <h1 class="sr-only">{entry.data.title}</h1>
        <p class="font-heading text-xs font-medium tracking-wider text-black/55 dark:text-white/55">
          Now &middot; Archived {formatted}
        </p>
      </div>

      <EditorialRule />

      <section
        class="prose prose-neutral dark:prose-invert max-w-none text-base leading-relaxed text-black/85 dark:text-white/85"
      >
        <Content />
      </section>

      <EditorialRule />

      <p class="text-xs text-black/55 dark:text-white/55">
        <Link href="/now">current now</Link>
        &nbsp;&middot;&nbsp;
        <Link href="/now/archive">all archived</Link>
      </p>
    </div>
  </Container>
</Layout>
