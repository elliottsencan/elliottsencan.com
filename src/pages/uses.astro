---
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import Layout from "@layouts/Layout.astro";
import { Code } from "astro-expressive-code/components";

// The /uses page, done the hacker-blog way: the configs ARE the answer. Each
// section is a real file path + an excerpt of what's in it. The "why" lives
// in inline comments, not in marketing prose.
//
// Expressive Code handles the editor-frame chrome, filename titlebar, copy
// button, and line numbers — all from the `title` prop plus global config in
// astro.config.mjs.
//
// Replace the TODO blocks below with actual excerpts from your dotfiles.
// Trim to the parts that are interesting / opinionated — nobody needs to see
// your entire .zshrc.

type ConfigBlock = {
  id: string;
  path: string;
  purpose?: string;
  lang: string;
  code: string;
};

const configs: ConfigBlock[] = [
  {
    id: "zshrc",
    path: "~/.zshrc",
    purpose: "Shell. The aliases and path tweaks I actually reach for.",
    lang: "bash",
    code: `# TODO — paste the interesting bits of your .zshrc here.
# Keep the aliases + PATH edits; strip anything generated by installers.

# export PATH="$HOME/.local/bin:$PATH"
# alias g=git
`,
  },
  {
    id: "terminal",
    path: "~/.config/ghostty/config",
    purpose: "Terminal emulator.",
    lang: "ini",
    code: `# TODO — replace with your actual terminal config (ghostty/wezterm/alacritty).
# font-family = ...
# font-size = 14
# theme = ...
`,
  },
  {
    id: "gitconfig",
    path: "~/.gitconfig",
    purpose: "Git defaults — the rebase-not-merge crowd.",
    lang: "ini",
    code: `# TODO — paste the opinionated bits.

# [pull]
#   rebase = true
# [rebase]
#   autosquash = true
# [alias]
#   lg = log --oneline --graph --decorate
`,
  },
  {
    id: "editor",
    path: "~/Library/Application Support/Code/User/settings.json",
    purpose: "Editor settings that actually matter — the rest is defaults.",
    lang: "json",
    code: `{
  "// TODO": "paste the settings you actually changed from defaults"
}
`,
  },
  {
    id: "brewfile",
    path: "~/Brewfile",
    purpose: "Everything installed via Homebrew. The source of truth for a fresh machine.",
    lang: "ruby",
    code: `# TODO — run \`brew bundle dump --force\` and paste the result.
# Trim fonts and casks you don't actually use.

# brew "git"
# brew "pnpm"
# brew "ripgrep"
# cask "ghostty"
`,
  },
  {
    id: "node",
    path: ".nvmrc",
    purpose: "Node version pinning. Project-level, not machine-level.",
    lang: "text",
    code: "22\n",
  },
  {
    id: "claude",
    path: "~/.claude/settings.json",
    purpose: "Claude Code config — the AI tool I actually use, not the one I tweet about.",
    lang: "json",
    code: `{
  "// TODO": "paste the non-secret parts of your Claude Code settings"
}
`,
  },
];
---

<Layout
  title="Uses"
  description="Tools, hardware, and workflow I actually use day to day — the configs, not the prose."
>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:Uses"
    >
      <div>
        <h1 class="sr-only">Uses</h1>
        <p
          class="font-mono text-xs uppercase tracking-wider text-black/55 dark:text-white/55"
          style="font-variant-numeric: tabular-nums;"
        >
          Uses
        </p>
      </div>

      <EditorialRule />

      <section class="space-y-4 text-base leading-relaxed text-black/85 dark:text-white/85">
        <p>
          {/* TODO: one-paragraph opener. The premise: if you want to know what
          I actually use, read the configs. The /uses convention (uses.tech),
          but done the hacker-blog way — files over marketing. */}
          TODO — opener.
        </p>
      </section>

      {
        configs.map((config) => (
          <>
            <EditorialRule />
            <section id={config.id} class="space-y-3 scroll-mt-24">
              {config.purpose && (
                <p class="text-sm text-black/60 dark:text-white/60">
                  {config.purpose}
                </p>
              )}
              <Code code={config.code} lang={config.lang} title={config.path} />
            </section>
          </>
        ))
      }

      <EditorialRule />

      <section class="space-y-4">
        <h2
          id="browser"
          class="font-mono text-xs uppercase tracking-wider text-black/60 dark:text-white/60"
        >
          Browser
        </h2>
        <ul class="not-prose flex flex-col gap-4 text-sm">
          <li class="space-y-1">
            <span class="font-medium text-black dark:text-white">TODO — browser of choice</span>
            <p class="text-black/70 dark:text-white/70">TODO — why.</p>
          </li>
          <li class="space-y-1">
            <span class="font-medium text-black dark:text-white">TODO — extensions that earn their keep</span>
            <p class="text-black/70 dark:text-white/70">TODO — one line each.</p>
          </li>
        </ul>
      </section>

      <EditorialRule />

      <section class="space-y-4">
        <h2
          id="hardware"
          class="font-mono text-xs uppercase tracking-wider text-black/60 dark:text-white/60"
        >
          Hardware
        </h2>
        <ul class="not-prose flex flex-col gap-4 text-sm">
          <li class="space-y-1">
            <span class="font-medium text-black dark:text-white">TODO — machine</span>
            <p class="text-black/70 dark:text-white/70">TODO.</p>
          </li>
          <li class="space-y-1">
            <span class="font-medium text-black dark:text-white">TODO — display</span>
            <p class="text-black/70 dark:text-white/70">TODO.</p>
          </li>
          <li class="space-y-1">
            <span class="font-medium text-black dark:text-white">TODO — keyboard</span>
            <p class="text-black/70 dark:text-white/70">TODO.</p>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</Layout>
