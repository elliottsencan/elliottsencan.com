---
import Container from "@components/Container.astro";
import EditorialList from "@components/EditorialList.astro";
import EditorialListItem from "@components/EditorialListItem.astro";
import EditorialRule from "@components/EditorialRule.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import PageHero from "@components/PageHero.astro";
import { SITE } from "@consts";
import Layout from "@layouts/Layout.astro";

// Career and project blurbs are authored inline rather than via content
// collections. This is a single page, the content changes rarely, and
// collection ceremony earns nothing here. Dates are stored as plain strings
// so the timeline reads in the order written; no coercion, no sorting.
// ServiceNow is split into two entries because the IC → EM transition is
// the load-bearing detail in the arc; collapsing it loses the signal.
const career = [
  {
    company: "StarLifter",
    role: "Staff Engineer",
    dates: "2026 — present",
    blurb:
      "The enterprise decision layer — agentic AI that turns live business context into governed action.",
    url: "https://www.starlifter.ai",
  },
  {
    company: "GrupBlox",
    role: "Principal Engineer",
    dates: "2024 — 2026",
    blurb: "AI agent architecture, developer tooling, and frontend platform.",
    url: "https://grupblox.com",
  },
  {
    company: "Transposit",
    role: "Staff Software Engineer",
    dates: "2022 — 2023",
    blurb: "Developer-facing automation for incident response.",
    url: "https://www.transposit.com",
  },
  {
    company: "ServiceNow",
    role: "Engineering Manager, Platform UX",
    dates: "2019 — 2022",
    blurb: "Led a 10-person team building core platform UI.",
    url: "https://www.servicenow.com",
  },
  {
    company: "ServiceNow",
    role: "Staff Software Engineer, Platform UX",
    dates: "2014 — 2019",
    blurb: "Render-pipeline performance and the prototype.js → Angular migration.",
    url: "https://www.servicenow.com",
  },
];

// Projects mirror the active set in Linear (status: In Progress or
// recently-Planned with a startedAt). When a project has a public
// surface — case study, repo, live URL — it links there; otherwise
// the title renders as plain text and the blurb does the work. The
// `status` field becomes the meta column on the editorial list and
// stands in for a date — projects don't have a single useful date the
// way blog posts and reading entries do.
const projectBlurbs: Array<{
  title: string;
  blurb: string;
  status: string;
  href?: string;
  external?: boolean;
}> = [
  {
    title: "Wiki synthesis pipeline",
    blurb:
      "Evaluated LLM pipeline that ingests reading, synthesizes per-concept wiki articles, and measures its own output.",
    status: "Live",
    href: "/projects/wiki-synthesis-pipeline",
  },
  {
    title: "herald-ui",
    blurb:
      "Open-source Angular library for AI chat interfaces — composable primitives inspired by assistant-ui.",
    status: "In flight",
    href: "https://github.com/herald-ui",
    external: true,
  },
  {
    title: "SSBD Platform v2.0",
    blurb:
      "Festival platform for Same Same But Different — backend-first, offline-resilient, mobile-led.",
    status: "Aug 2026",
  },
];
---

<Layout title="About" description={SITE.DESCRIPTION} includePersonSchema>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:About"
    >
      <PageHero>
        <Fragment slot="title">About</Fragment>
        <Fragment slot="summary">
          Hi, I'm Elliott, an engineer in San Diego. Currently at StarLifter;
          previously senior engineering roles at startups, and before that
          eight years at ServiceNow across IC and engineering-management
          tracks.
        </Fragment>
      </PageHero>

      <section class="space-y-4">
        <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
          This site is where I write about software engineering, architecture,
          and craft. If you want to see what I'm thinking about right now, the
          <Link href="/now">/now page</Link> is more current than this one.
        </p>
        <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
          Outside of software, I co-own
          <Link href="https://ssbdfest.com" external>Same Same But Different</Link>,
          a 7,500-person music festival in Lake Perris, CA, and produce music as
          Hollywood Principle (100M+ Spotify streams, video game placements).
        </p>
      </section>

      <section class="space-y-4">
        <LabeledRule>Career</LabeledRule>
        <EditorialList>
          {
            career.map((role) => (
              <EditorialListItem meta={role.dates}>
                <Fragment slot="title">
                  {role.role}
                  {" at "}
                  {role.url ? (
                    <Link href={role.url} external>
                      {role.company}
                    </Link>
                  ) : (
                    role.company
                  )}
                </Fragment>
                {role.blurb}
              </EditorialListItem>
            ))
          }
        </EditorialList>
      </section>


      <section class="space-y-4">
        <LabeledRule>Projects</LabeledRule>
        <EditorialList>
          {
            projectBlurbs.map((project) => (
              <EditorialListItem
                title={project.title}
                href={project.href}
                external={project.external}
                meta={project.status}
              >
                {project.blurb}
              </EditorialListItem>
            ))
          }
        </EditorialList>
      </section>

      <section class="space-y-4">
        <LabeledRule>Elsewhere</LabeledRule>
        <ul class="not-prose flex flex-col gap-2 text-sm">
          <li class="flex items-baseline gap-4">
            <span
              aria-hidden="true"
              class="shrink-0 text-xs text-black/50 dark:text-white/50"
            >
              &middot;
            </span>
            <span>
              <Link href="/about/colophon">colophon</Link>
              <span class="text-black/60 dark:text-white/60">
                {" — "}typography, stack, and credits.
              </span>
            </span>
          </li>
          <li class="flex items-baseline gap-4">
            <span
              aria-hidden="true"
              class="shrink-0 text-xs text-black/50 dark:text-white/50"
            >
              &middot;
            </span>
            <span>
              <Link href="/about/process">process</Link>
              <span class="text-black/60 dark:text-white/60">
                {" — "}writing workflow and what AI assistance means on each post.
              </span>
            </span>
          </li>
          <li class="flex items-baseline gap-4">
            <span
              aria-hidden="true"
              class="shrink-0 text-xs text-black/50 dark:text-white/50"
            >
              &middot;
            </span>
            <span>
              <Link href="/about/uses">uses</Link>
              <span class="text-black/60 dark:text-white/60">
                {" — "}tools, hardware, and workflow I actually reach for.
              </span>
            </span>
          </li>
        </ul>
      </section>

      <EditorialRule />

      <p class="text-xs text-black/55 dark:text-white/55">
        <Link href="/now">now →</Link>
      </p>
    </div>
  </Container>
</Layout>
