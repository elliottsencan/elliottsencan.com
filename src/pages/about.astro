---
import Container from "@components/Container.astro";
import EditorialRule from "@components/EditorialRule.astro";
import LabeledRule from "@components/LabeledRule.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";
import Layout from "@layouts/Layout.astro";

// Career and project blurbs are authored inline rather than via content
// collections. This is a single page, the content changes rarely, and
// collection ceremony earns nothing here. Dates are stored as plain strings
// so the timeline reads in the order written; no coercion, no sorting.
const career = [
  {
    company: "GrupBlox",
    role: "Engineer",
    dates: "2024 — present",
    blurb: "Developer tools and complex systems.",
    url: "https://grupblox.com",
  },
  {
    company: "ServiceNow",
    role: "Staff Software Engineer",
    dates: "2019 — 2024",
    blurb: "Platform and developer experience.",
    url: "https://www.servicenow.com",
  },
];

const projectBlurbs = [
  {
    title: "herald-ui",
    blurb:
      "A design system for teams that don't want to re-solve the same primitives every quarter.",
    href: "/projects",
  },
];
---

<Layout title="About" description={SITE.DESCRIPTION} includePersonSchema>
  <Container>
    <div
      class="space-y-10"
      data-pagefind-body
      data-pagefind-filter="type:About"
    >
      <LabeledRule>About</LabeledRule>

      <section class="space-y-4">
        <p class="font-sans text-lg italic leading-relaxed text-black dark:text-white">
          Elliott Sencan is an engineer in San Diego working on developer tools and
          complex systems. Currently at GrupBlox; previously staff at ServiceNow.
        </p>
        <p class="text-base leading-relaxed text-black/85 dark:text-white/85">
          This site is where I write about software engineering, architecture,
          and craft. If you want to see what I'm thinking about right now, the
          <Link href="/now">/now page</Link> is more current than this one.
        </p>
      </section>

      <section class="space-y-4">
        <LabeledRule>Career</LabeledRule>
        <ul class="not-prose flex flex-col gap-3 text-sm">
          {
            career.map((role) => (
              <li class="flex items-baseline gap-4">
                <span class="shrink-0 font-sans text-xs text-black/50 dark:text-white/60">
                  {role.dates}
                </span>
                <span>
                  <span class="font-heading font-medium text-black dark:text-white">
                    {role.role}
                    {" at "}
                    {role.url ? (
                      <Link href={role.url} external>
                        {role.company}
                      </Link>
                    ) : (
                      role.company
                    )}
                  </span>
                  {role.blurb && (
                    <span class="text-black/60 dark:text-white/60">
                      {" — "}
                      {role.blurb}
                    </span>
                  )}
                </span>
              </li>
            ))
          }
        </ul>
      </section>


      <section class="space-y-4">
        <LabeledRule>Projects</LabeledRule>
        <!-- <div class="flex items-baseline justify-between">
          
          <Link href="/projects">
            <span class="text-sm">All projects &rarr;</span>
          </Link>
        </div> -->
        <ul class="not-prose flex flex-col gap-3 text-sm">
          {
            projectBlurbs.map((project) => (
              <li class="flex items-baseline gap-4">
                <span
                  aria-hidden="true"
                  class="shrink-0 text-xs text-black/50 dark:text-white/50"
                >
                  &middot;
                </span>
                <span>
                  <Link
                    href={project.href}
                    class="font-heading font-medium text-black dark:text-white"
                  >
                    {project.title}
                  </Link>
                  <span class="text-black/60 dark:text-white/60">
                    {" — "}
                    {project.blurb}
                  </span>
                </span>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="space-y-4">
        <LabeledRule>Elsewhere</LabeledRule>
        <ul class="not-prose flex flex-col gap-2 text-sm">
          <li class="flex items-baseline gap-4">
            <span
              aria-hidden="true"
              class="shrink-0 text-xs text-black/50 dark:text-white/50"
            >
              &middot;
            </span>
            <span>
              <Link href="/about/colophon">colophon</Link>
              <span class="text-black/60 dark:text-white/60">
                {" — "}typography, stack, and credits.
              </span>
            </span>
          </li>
          <li class="flex items-baseline gap-4">
            <span
              aria-hidden="true"
              class="shrink-0 text-xs text-black/50 dark:text-white/50"
            >
              &middot;
            </span>
            <span>
              <Link href="/about/process">process</Link>
              <span class="text-black/60 dark:text-white/60">
                {" — "}writing workflow and what AI assistance means on each post.
              </span>
            </span>
          </li>
          <li class="flex items-baseline gap-4">
            <span
              aria-hidden="true"
              class="shrink-0 text-xs text-black/50 dark:text-white/50"
            >
              &middot;
            </span>
            <span>
              <Link href="/about/uses">uses</Link>
              <span class="text-black/60 dark:text-white/60">
                {" — "}tools, hardware, and workflow I actually reach for.
              </span>
            </span>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</Layout>
