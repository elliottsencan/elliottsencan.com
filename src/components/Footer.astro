---
import BackToTop from "@components/BackToTop.astro";
import Container from "@components/Container.astro";
import ContributionsGrid from "@components/ContributionsGrid.astro";
import ContributionsRail from "@components/ContributionsRail.astro";
import Link from "@components/Link.astro";
import { SITE, SOCIALS } from "@consts";
import { getContributions } from "@lib/github";

// Build-time fetch. Returns null on missing token / fetch failure — the
// contribution viz is simply omitted in that case, so the footer collapses
// cleanly and the build never fails because of this.
const contributions = await getContributions(SITE.GITHUB_LOGIN);

const githubProfileUrl = `https://github.com/${SITE.GITHUB_LOGIN}`;
---

<footer>
  <Container>
    <div class="relative">
      <div class="absolute -top-12 right-0">
        <BackToTop />
      </div>
    </div>
    {/* Single editorial line at every breakpoint. flex-wrap is a safety net
        for very narrow (<360 px) viewports — at 375 px+ the cluster and the
        26-week mobile grid share one row; below that the grid drops below. */}
    <div class="flex flex-row flex-wrap items-center justify-between gap-x-4 gap-y-2">
      <ul class="not-prose flex flex-wrap items-baseline gap-x-2 gap-y-1 text-xs">
        <li><span>&copy; {new Date().getFullYear()}</span></li>
        {
          SOCIALS.map((social) => (
            <li class="flex items-baseline gap-3">
              <span aria-hidden="true" class="text-black/40 dark:text-white/40">
                &middot;
              </span>
              <Link
                href={social.HREF}
                external
                aria-label={`${SITE.TITLE} on ${social.NAME}`}
              >
                {social.NAME}
              </Link>
            </li>
          ))
        }
        <li class="flex items-baseline gap-3">
          <span aria-hidden="true" class="text-black/40 dark:text-white/40">
            &middot;
          </span>
          <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.TITLE}`}>
            Email
          </Link>
        </li>
        <li class="flex items-baseline gap-3">
          <span aria-hidden="true" class="text-black/40 dark:text-white/40">
            &middot;
          </span>
          <Link href="/rss.xml" aria-label="RSS Feed">RSS</Link>
        </li>
      </ul>
      {
        contributions && (
          <a
            href={githubProfileUrl}
            target="_blank"
            rel="noopener"
            aria-label="GitHub profile — one year of contributions"
            class="block w-fit md:w-auto md:max-w-xs md:flex-1"
          >
            {/* Mobile: compact 7×26 grid at fixed intrinsic width — 26 weeks
                @ 2 px cells + 1 px gap = 77 px, leaving room for the four-
                item cluster on a single 375 px line. Desktop: the signature
                dot rail. Responsive swap is pure CSS, no client JS. */}
            <div class="md:hidden">
              <ContributionsGrid data={contributions} weeks={26} cellSize={2} gap={1} />
            </div>
            <div class="hidden md:block">
              <ContributionsRail data={contributions} />
            </div>
          </a>
        )
      }
    </div>
  </Container>
</footer>
