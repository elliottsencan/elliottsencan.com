---
import BackToTop from "@components/BackToTop.astro";
import Container from "@components/Container.astro";
import ContributionsRail from "@components/ContributionsRail.astro";
import Link from "@components/Link.astro";
import { SITE, SOCIALS } from "@consts";
import { getContributions } from "@lib/github";

// Build-time fetch. Returns null on missing token / fetch failure — the rail
// is simply omitted in that case, so the footer collapses cleanly and the
// build never fails because of this.
const contributions = await getContributions(SITE.GITHUB_LOGIN);

const githubProfileUrl = `https://github.com/${SITE.GITHUB_LOGIN}`;
---

<footer>
  <Container>
    <div class="relative">
      <div class="absolute -top-12 right-0">
        <BackToTop />
      </div>
    </div>
    <div class="flex flex-col-reverse gap-3 md:flex-row items-center md:justify-between md:gap-x-4">
      <ul class="not-prose flex flex-wrap items-baseline gap-x-2 gap-y-1 text-xs">
        <li><span>&copy; {new Date().getFullYear()}</span></li>
        {
          SOCIALS.map((social) => (
            <li class="flex items-baseline gap-3">
              <span aria-hidden="true" class="text-black/40 dark:text-white/40">
                &middot;
              </span>
              <Link
                href={social.HREF}
                external
                aria-label={`${SITE.TITLE} on ${social.NAME}`}
              >
                {social.NAME}
              </Link>
            </li>
          ))
        }
        <li class="flex items-baseline gap-3">
          <span aria-hidden="true" class="text-black/40 dark:text-white/40">
            &middot;
          </span>
          <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.TITLE}`}>
            Email
          </Link>
        </li>
        <li class="flex items-baseline gap-3">
          <span aria-hidden="true" class="text-black/40 dark:text-white/40">
            &middot;
          </span>
          <Link href="/rss.xml" aria-label="RSS Feed">RSS</Link>
        </li>
      </ul>
      {
        contributions && (
          <a
            href={githubProfileUrl}
            target="_blank"
            rel="noopener"
            aria-label="GitHub profile — one year of contributions"
            class="mx-auto block w-full max-w-xs md:mx-0 md:w-auto md:max-w-xs md:flex-1"
          >
            <ContributionsRail data={contributions} />
          </a>
        )
      }
    </div>
  </Container>
</footer>
