---
/**
 * Constellation rail — V2 "Cluster constellations" (per-concept).
 *
 * Hero widget on /wiki/[slug]. Renders the active concept and its 1-hop
 * neighborhood with tinted cluster regions, weight-scaled nodes, italic
 * region labels, and a breathe ring on the active node. Visual language
 * mirrors the strip so the two widgets read as the same system.
 *
 * Sizing: aspect-locked to the strip via @lib/constellationGeometry, so
 * the slug-page rail and the index strip render at identical pixel
 * dimensions when given the same `width`. Local content sits centered
 * within the wider strip-aspect viewBox.
 *
 * No hover focus protocol — `active` is always the page slug, set once at
 * render. Neighbors stay clickable for navigation.
 */
import layout from "@data/constellation-layout.json";
import {
  LOCAL_VH,
  LOCAL_VW,
  LOCAL_VX,
  LOCAL_VY,
  STRIP_DEFAULT_WIDTH,
  STRIP_VH,
  STRIP_VW,
} from "@lib/constellationGeometry";

type Props = {
  slug: string;
  width?: number;
};

const { slug, width = STRIP_DEFAULT_WIDTH } = Astro.props;

type LocalNode = { id: string; x: number; y: number };
type LocalEdge = {
  a: string;
  b: string;
  weight: number;
  via: { link: number; cocite: number };
  display: boolean;
};
type LocalLayout = { nodes: LocalNode[]; edges: LocalEdge[] };
type Cluster = { id: string; title: string; short: string; hue: number };

const localLayouts: Record<string, LocalLayout> = layout.local;
const titles: Record<string, string> = layout.titles;
const clusters: Cluster[] = layout.clusters;
const clusterById: Record<string, string | null> = layout.clusterById;

const local = localLayouts[slug];

// Weight lookup from the global layout — local nodes don't carry weights,
// but we want visual node weight to read consistently between the strip
// and the local rail (a heavy node should look heavy in both widgets).
const globalWeights = new Map<string, number>(layout.global.nodes.map((n) => [n.id, n.weight]));
const weightOf = (id: string) => globalWeights.get(id) ?? 1;

// Normalize against the full global field so cross-widget weights match.
const allWeights = layout.global.nodes.map((n) => n.weight);
const wMin = Math.min(...allWeights);
const wMax = Math.max(...allWeights);
const wNorm = (w: number) => (wMax === wMin ? 0.5 : (w - wMin) / (wMax - wMin));

// Same density-scaled radius formula as the strip — no-op below 80 concepts.
const densityScale = Math.max(0.5, Math.min(1, 80 / layout.global.nodes.length));
const nodeR = (w: number) => (2.2 + 4.6 * wNorm(w)) * densityScale;

// Group local nodes by cluster so we can draw a tinted region behind each
// cluster represented in the neighborhood, plus an italic region label
// at the cluster's centroid. The active concept's cluster gets a heavier
// label opacity (the local rail has no hover protocol to reveal others on
// demand, so we surface them all and just emphasize the active one).
type Group = Cluster & {
  nodes: LocalNode[];
  labelX: number;
  labelY: number;
};
const localGroups: Group[] = local
  ? (clusters
      .map((cl) => {
        const nodes = local.nodes.filter((n) => clusterById[n.id] === cl.id);
        if (nodes.length < 2) {
          return null;
        }
        const labelX = nodes.reduce((s, n) => s + n.x, 0) / nodes.length;
        const labelY = Math.min(...nodes.map((n) => n.y)) - 8;
        return { ...cl, nodes, labelX, labelY };
      })
      .filter((g) => g !== null) as Group[])
  : [];

const myCluster = clusterById[slug];

// ─── geometry helpers (mirror the strip; pad shrinks for the local view) ─
type Pt = { x: number; y: number };

function convexHull(points: Pt[]): Pt[] {
  if (points.length <= 1) {
    return points.slice();
  }
  const pts = points.slice().sort((p, q) => p.x - q.x || p.y - q.y);
  const cross = (o: Pt, a: Pt, b: Pt) => (a.x - o.x) * (b.y - o.y) - (a.y - o.y) * (b.x - o.x);
  const lower: Pt[] = [];
  for (const p of pts) {
    while (lower.length >= 2 && cross(lower[lower.length - 2], lower[lower.length - 1], p) <= 0) {
      lower.pop();
    }
    lower.push(p);
  }
  const upper: Pt[] = [];
  for (let i = pts.length - 1; i >= 0; i--) {
    const p = pts[i];
    while (upper.length >= 2 && cross(upper[upper.length - 2], upper[upper.length - 1], p) <= 0) {
      upper.pop();
    }
    upper.push(p);
  }
  return lower.slice(0, -1).concat(upper.slice(0, -1));
}

function inflateHull(hull: Pt[], pad: number): Pt[] {
  if (hull.length === 0) {
    return hull;
  }
  const cx = hull.reduce((s, p) => s + p.x, 0) / hull.length;
  const cy = hull.reduce((s, p) => s + p.y, 0) / hull.length;
  return hull.map((p) => {
    const dx = p.x - cx;
    const dy = p.y - cy;
    const d = Math.hypot(dx, dy) || 1;
    return { x: p.x + (dx / d) * pad, y: p.y + (dy / d) * pad };
  });
}

function smoothClosed(points: Pt[]): string {
  if (points.length < 3) {
    return "";
  }
  const n = points.length;
  let d = `M ${points[0].x} ${points[0].y}`;
  for (let i = 0; i < n; i++) {
    const p0 = points[(i - 1 + n) % n];
    const p1 = points[i];
    const p2 = points[(i + 1) % n];
    const p3 = points[(i + 2) % n];
    const t = 0.18;
    const c1x = p1.x + (p2.x - p0.x) * t;
    const c1y = p1.y + (p2.y - p0.y) * t;
    const c2x = p2.x - (p3.x - p1.x) * t;
    const c2y = p2.y - (p3.y - p1.y) * t;
    d += ` C ${c1x} ${c1y}, ${c2x} ${c2y}, ${p2.x} ${p2.y}`;
  }
  return `${d} Z`;
}

// Region path is empty for 2-node clusters (smoothClosed needs 3+ points)
// but the italic label still renders — see `localGroups` below.
const regionPaths = localGroups.map((g) => ({
  ...g,
  path: smoothClosed(inflateHull(convexHull(g.nodes.map((n) => ({ x: n.x, y: n.y }))), 14)),
}));

// Per-edge stroke width and opacity multiplier driven by relationship
// weight. Mirrors the strip; the local rail keeps the same visual language.
const edgeStrokeW = (w: number) => 0.4 + Math.min(w, 6) * 0.15;
const edgeOpacityMul = (w: number) => Math.min(1, w / 4);

// Edges incident to the active node always render (that's the whole point of
// the 1-hop neighborhood view); non-incident edges between two neighbors are
// gated by the same `display` flag as the strip so the field stays legible.
const visibleLocalEdges = local
  ? local.edges.filter((e) => e.a === slug || e.b === slug || e.display)
  : [];
---

{
  local && local.nodes.length > 1 && (
    <div
      class="constellation-local"
      style={`--cl-w: ${width}px; --cl-aspect: ${STRIP_VW} / ${STRIP_VH};`}
    >
      <svg
        class="constellation-local-svg"
        viewBox={`${LOCAL_VX} ${LOCAL_VY} ${LOCAL_VW} ${LOCAL_VH}`}
        width="100%"
        height="100%"
        preserveAspectRatio="xMidYMid meet"
        role="img"
        aria-label={`Neighborhood graph for ${titles[slug] ?? slug}`}
      >
        {/* Cluster regions — active concept's cluster is emphasized; 2-node
            clusters skip the path (smoothClosed needs 3+ points) but still
            get the italic label below. */}
        {regionPaths
          .filter((g) => g.path !== "")
          .map((g) => (
            <path
              class="region"
              data-cluster={g.id}
              data-active={g.id === myCluster ? "" : null}
              d={g.path}
              style={`--hue: ${g.hue};`}
            />
          ))}

        {/* Italic cluster names — drawn for every represented cluster (no
            hover protocol to reveal them on demand). The active concept's
            cluster gets heavier opacity so it reads as the focus. */}
        {regionPaths.map((g) => (
          <text
            class="cluster-name"
            data-cluster={g.id}
            data-active={g.id === myCluster ? "" : null}
            x={g.labelX}
            y={g.labelY}
            text-anchor="middle"
            font-family="var(--font-heading)"
            font-style="italic"
            font-size="11"
            letter-spacing="0.01em"
            fill="currentColor"
            vector-effect="non-scaling-stroke"
          >
            {g.short}
          </text>
        ))}

        {/* Edges — same-cluster as straight lines, cross-cluster as gentle
            quadratic Béziers so coincident pairs don't overlap pixel-for-pixel
            (mirrors the strip). Width and per-edge opacity come from inline
            CSS vars driven by weight; the .on selector below overrides those
            vars for active-incident. */}
        {visibleLocalEdges.map((e) => {
          const a = local.nodes.find((n) => n.id === e.a);
          const b = local.nodes.find((n) => n.id === e.b);
          if (!a || !b) return null;
          const onActive = e.a === slug || e.b === slug;
          const sameCluster =
            clusterById[e.a] === clusterById[e.b] && clusterById[e.a] != null;
          const cls = `edge ${sameCluster ? "same" : "cross"}${onActive ? " on" : ""}`;
          const styleVars = `--edge-w: ${edgeStrokeW(e.weight)}; --edge-o-mul: ${edgeOpacityMul(e.weight)};`;
          if (sameCluster) {
            return (
              <line
                class={cls}
                x1={a.x}
                y1={a.y}
                x2={b.x}
                y2={b.y}
                vector-effect="non-scaling-stroke"
                style={styleVars}
              />
            );
          }
          const dx = b.x - a.x;
          const dy = b.y - a.y;
          const dist = Math.hypot(dx, dy) || 1;
          const offset = -dist * 0.12;
          const cx = (a.x + b.x) / 2 + (-dy / dist) * offset;
          const cy = (a.y + b.y) / 2 + (dx / dist) * offset;
          return (
            <path
              class={cls}
              d={`M ${a.x} ${a.y} Q ${cx} ${cy} ${b.x} ${b.y}`}
              fill="none"
              stroke="currentColor"
              vector-effect="non-scaling-stroke"
              style={styleVars}
            />
          );
        })}

        {/* Nodes — weight-driven radius (looked up from the global field so
            sizes match the strip). Active is non-clickable (current page);
            neighbors link. */}
        {local.nodes.map((n) => {
          const isMe = n.id === slug;
          const r = nodeR(weightOf(n.id));
          const title = titles[n.id] ?? n.id;
          if (isMe) {
            return (
              <g class="node active" data-slug={n.id}>
                <title>{title}</title>
                <circle
                  class="breathe-ring"
                  cx={n.x}
                  cy={n.y}
                  r={r + 2}
                  fill="none"
                  stroke="var(--accent)"
                  stroke-width="0.7"
                  vector-effect="non-scaling-stroke"
                  style={`--r-start: ${r + 2}; --r-end: ${r + 8};`}
                />
                <circle class="dot" cx={n.x} cy={n.y} r={r} fill="var(--accent)" />
              </g>
            );
          }
          return (
            <a class="node neighbor" href={`/wiki/${n.id}/`} data-slug={n.id}>
              <title>{title}</title>
              <circle class="hit" cx={n.x} cy={n.y} r={r + 4} fill="transparent" />
              <circle class="dot" cx={n.x} cy={n.y} r={r} fill="currentColor" />
              <text
                class="label"
                x={n.x}
                y={n.y - r - 4}
                text-anchor="middle"
                font-family="var(--font-mono)"
                font-size="9"
                fill="currentColor"
              >
                {title}
              </text>
            </a>
          );
        })}
      </svg>
    </div>
  )
}

<style>
  /* Aspect-locked to the strip via @lib/constellationGeometry, so passing
     the same `width` to both widgets renders them at identical pixel
     sizes. Width strategy mirrors the strip: request --cl-w directly and
     cap at the parent's width on narrow viewports. The earlier
     `width: 100%; max-width: --cl-w` pattern collapses inside a CSS Grid
     `auto` track because the column resolves against min-content, which
     an aspect-ratio'd box can shrink to ~0. */
  .constellation-local {
    width: var(--cl-w);
    max-width: 100%;
    aspect-ratio: var(--cl-aspect);
    color: rgb(0 0 0 / 0.88);
  }
  :global(.dark) .constellation-local {
    color: rgb(255 255 255 / 0.88);
  }
  .constellation-local :global(.constellation-local-svg) {
    display: block;
    overflow: visible;
  }

  /* Cluster regions */
  .constellation-local :global(.region) {
    fill: oklch(0.84 0.06 var(--hue));
    opacity: 0.5;
    stroke: oklch(0.62 0.08 var(--hue));
    stroke-width: 1;
    stroke-opacity: 0.35;
    vector-effect: non-scaling-stroke;
  }
  :global(.dark) .constellation-local :global(.region) {
    fill: oklch(0.36 0.06 var(--hue));
    stroke: oklch(0.55 0.08 var(--hue));
    stroke-opacity: 0.45;
  }
  .constellation-local :global(.region[data-active]) {
    opacity: 1;
    stroke-opacity: 0.7;
  }
  :global(.dark) .constellation-local :global(.region[data-active]) {
    stroke-opacity: 0.8;
  }

  /* Italic cluster names — only the active concept's cluster shows. On
     heavy hubs the neighborhood touches all 5 clusters and their labels
     stack at near-identical y; showing one cluster name (the one tied to
     the caption) keeps the field legible. Paint-order halo so the italic
     reads cleanly over the region tint underneath. */
  .constellation-local :global(.cluster-name) {
    paint-order: stroke fill;
    stroke: #f6f4ef;
    stroke-width: 3px;
    stroke-linejoin: round;
    pointer-events: none;
    opacity: 0;
    font-feature-settings: "ss01" 1;
  }
  :global(.dark) .constellation-local :global(.cluster-name) {
    stroke: #18161a;
  }
  .constellation-local :global(.cluster-name[data-active]) {
    opacity: 0.75;
  }

  /* Edges — base opacities split same vs cross to match the strip; the
     .on rule below overrides for active-incident edges regardless of
     same/cross. Dark mode halves base opacity because currentColor
     resolves to near-white and reads heavier than the same alpha on the
     paper-toned light field. */
  .constellation-local :global(.edge) {
    stroke: currentColor;
  }
  .constellation-local :global(.edge.same) {
    stroke-width: var(--edge-w, 0.5);
    opacity: calc(0.22 * var(--edge-o-mul, 1));
  }
  .constellation-local :global(.edge.cross) {
    stroke-width: var(--edge-w, 0.3);
    opacity: calc(0.08 * var(--edge-o-mul, 1));
  }
  :global(.dark) .constellation-local :global(.edge.same) {
    opacity: calc(0.14 * var(--edge-o-mul, 1));
  }
  :global(.dark) .constellation-local :global(.edge.cross) {
    opacity: calc(0.06 * var(--edge-o-mul, 1));
  }
  /* Active-incident edges go to accent — fixed weight regardless of the
     per-edge var. Declared last so it overrides .same/.cross above. */
  .constellation-local :global(.edge.on),
  :global(.dark) .constellation-local :global(.edge.on) {
    stroke: var(--accent);
    stroke-width: 0.8;
    opacity: 0.55;
  }

  /* Neighbor nodes */
  .constellation-local :global(.node) {
    cursor: default;
  }
  .constellation-local :global(.node.neighbor) {
    cursor: pointer;
  }
  .constellation-local :global(.node.neighbor .dot) {
    opacity: 0.7;
    transition: opacity 150ms ease;
  }
  .constellation-local :global(.node.neighbor:hover .dot),
  .constellation-local :global(.node.neighbor:focus-visible .dot) {
    fill: var(--accent);
    opacity: 1;
  }
  .constellation-local :global(.node.active .dot) {
    filter: drop-shadow(0 0 4px color-mix(in oklch, var(--accent) 35%, transparent));
  }

  /* Hover-revealed labels — paint-order halo for legibility over edges. */
  .constellation-local :global(.node.neighbor .label) {
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease-in-out;
    paint-order: stroke fill;
    stroke: #f6f4ef;
    stroke-width: 4px;
    stroke-linejoin: round;
    fill: var(--accent);
    vector-effect: non-scaling-stroke;
  }
  :global(.dark) .constellation-local :global(.node.neighbor .label) {
    stroke: #18161a;
  }
  .constellation-local :global(.node.neighbor:hover .label),
  .constellation-local :global(.node.neighbor:focus-visible .label) {
    opacity: 1;
  }

  /* Active node breathe ring — same shape as the strip, slightly wider stroke */
  .constellation-local :global(.breathe-ring) {
    animation: constellation-local-breathe 2.6s linear infinite;
    opacity: 0.5;
  }
  @keyframes constellation-local-breathe {
    0%,
    100% {
      r: var(--r-start);
      opacity: 0.65;
    }
    50% {
      r: var(--r-end);
      opacity: 0.05;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .constellation-local :global(.breathe-ring) {
      display: none !important;
      animation: none !important;
    }
  }

  /* Mobile / coarse-pointer adjustments. Node labels stay hidden on mobile
     to match the strip — on hub concepts where the neighborhood touches
     20+ nodes the labels otherwise collide into an unreadable band. Touch
     readers tap a dot and navigate directly; the destination page header
     supplies the concept name. Cross-cluster non-incident edges hide too,
     matching the strip — the visual reads as accent-only relationships
     reaching across cluster regions. Hit targets grow on coarse pointer
     for forgiving taps without changing the visible dot size. */
  @media (max-width: 640px) {
    .constellation-local :global(.edge.cross:not(.on)) {
      display: none;
    }
  }
  @media (pointer: coarse) {
    .constellation-local :global(.hit) {
      r: 22;
    }
  }
</style>
