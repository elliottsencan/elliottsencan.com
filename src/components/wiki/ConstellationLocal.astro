---
/**
 * Constellation rail — V2 "Cluster constellations".
 *
 * Hero widget on /wiki/[slug]. Renders the active concept and its 1-hop
 * neighborhood as a 200×200 field with editorial corner ticks, a cluster
 * region behind the locals, an italic cluster name floated above, and a
 * single ambient breathe ring on the active node.
 *
 * Visual rules: design_handoff_constellation_v2/README.md §2.
 * Reference implementation: design_handoff_constellation_v2/source/v2.jsx
 * (the RailV2 export).
 *
 * No hover protocol — `active` is always the page slug, set once at render.
 */
import layout from "@data/constellation-layout.json";

type Props = {
  slug: string;
  size?: number;
};

const { slug, size = 220 } = Astro.props;

type LocalNode = { id: string; x: number; y: number };
type LocalEdge = { a: string; b: string };
type LocalLayout = { nodes: LocalNode[]; edges: LocalEdge[] };
type Cluster = { id: string; title: string; short: string; hue: number };

const localLayouts: Record<string, LocalLayout> = layout.local;
const titles: Record<string, string> = layout.titles;
const clusters: Cluster[] = layout.clusters;
const clusterById: Record<string, string | null> = layout.clusterById;

const local = localLayouts[slug];

// Group local nodes by cluster so we can draw a tinted region behind each
// cluster represented in the neighborhood. The active concept's own
// cluster gets full opacity; others fade.
type Group = Cluster & { nodes: LocalNode[] };
const localGroups: Group[] = local
  ? clusters
      .map((cl) => ({
        ...cl,
        nodes: local.nodes.filter((n) => clusterById[n.id] === cl.id),
      }))
      .filter((g) => g.nodes.length >= 2)
  : [];

const myCluster = clusterById[slug];
const myClusterMeta = myCluster ? clusters.find((c) => c.id === myCluster) : null;

// ─── geometry helpers (mirror the strip; pad shrinks for the local view) ─
type Pt = { x: number; y: number };

function convexHull(points: Pt[]): Pt[] {
  if (points.length <= 1) {
    return points.slice();
  }
  const pts = points.slice().sort((p, q) => p.x - q.x || p.y - q.y);
  const cross = (o: Pt, a: Pt, b: Pt) => (a.x - o.x) * (b.y - o.y) - (a.y - o.y) * (b.x - o.x);
  const lower: Pt[] = [];
  for (const p of pts) {
    while (lower.length >= 2 && cross(lower[lower.length - 2], lower[lower.length - 1], p) <= 0) {
      lower.pop();
    }
    lower.push(p);
  }
  const upper: Pt[] = [];
  for (let i = pts.length - 1; i >= 0; i--) {
    const p = pts[i];
    while (upper.length >= 2 && cross(upper[upper.length - 2], upper[upper.length - 1], p) <= 0) {
      upper.pop();
    }
    upper.push(p);
  }
  return lower.slice(0, -1).concat(upper.slice(0, -1));
}

function inflateHull(hull: Pt[], pad: number): Pt[] {
  if (hull.length === 0) {
    return hull;
  }
  const cx = hull.reduce((s, p) => s + p.x, 0) / hull.length;
  const cy = hull.reduce((s, p) => s + p.y, 0) / hull.length;
  return hull.map((p) => {
    const dx = p.x - cx;
    const dy = p.y - cy;
    const d = Math.hypot(dx, dy) || 1;
    return { x: p.x + (dx / d) * pad, y: p.y + (dy / d) * pad };
  });
}

function smoothClosed(points: Pt[]): string {
  if (points.length < 3) {
    return "";
  }
  const n = points.length;
  let d = `M ${points[0].x} ${points[0].y}`;
  for (let i = 0; i < n; i++) {
    const p0 = points[(i - 1 + n) % n];
    const p1 = points[i];
    const p2 = points[(i + 1) % n];
    const p3 = points[(i + 2) % n];
    const t = 0.18;
    const c1x = p1.x + (p2.x - p0.x) * t;
    const c1y = p1.y + (p2.y - p0.y) * t;
    const c2x = p2.x - (p3.x - p1.x) * t;
    const c2y = p2.y - (p3.y - p1.y) * t;
    d += ` C ${c1x} ${c1y}, ${c2x} ${c2y}, ${p2.x} ${p2.y}`;
  }
  return `${d} Z`;
}

const regionPaths = localGroups
  .map((g) => ({
    ...g,
    path: smoothClosed(inflateHull(convexHull(g.nodes.map((n) => ({ x: n.x, y: n.y }))), 14)),
  }))
  .filter((g) => g.path !== "");

// Active node radius for the breathe ring inline custom properties.
const ACTIVE_R = 5;
const NEIGHBOR_R = 2.6;
---

{
  local && local.nodes.length > 1 && (
    <div class="constellation-local" style={`width: ${size}px;`}>
      <svg
        class="constellation-local-svg"
        width={size}
        height={size + 16}
        viewBox="-10 -10 220 236"
        role="img"
        aria-label={`Neighborhood graph for ${titles[slug] ?? slug}`}
      >
        {/* Cluster regions — active's cluster at full opacity, others fade. */}
        {regionPaths.map((g) => (
          <path
            class="region"
            data-cluster={g.id}
            data-active={g.id === myCluster ? "" : null}
            d={g.path}
            stroke="none"
            style={`--hue: ${g.hue};`}
          />
        ))}

        {/* Editorial corner ticks at the corners of the 0..200 inner box. */}
        <g class="corner-ticks" stroke="currentColor" stroke-width="1" opacity="0.45">
          {/* top-left */}
          <line x1="0" y1="0" x2="9" y2="0" vector-effect="non-scaling-stroke" />
          <line x1="0" y1="0" x2="0" y2="9" vector-effect="non-scaling-stroke" />
          {/* top-right */}
          <line x1="200" y1="0" x2="191" y2="0" vector-effect="non-scaling-stroke" />
          <line x1="200" y1="0" x2="200" y2="9" vector-effect="non-scaling-stroke" />
          {/* bottom-left */}
          <line x1="0" y1="200" x2="9" y2="200" vector-effect="non-scaling-stroke" />
          <line x1="0" y1="200" x2="0" y2="191" vector-effect="non-scaling-stroke" />
          {/* bottom-right */}
          <line x1="200" y1="200" x2="191" y2="200" vector-effect="non-scaling-stroke" />
          <line x1="200" y1="200" x2="200" y2="191" vector-effect="non-scaling-stroke" />
        </g>

        {/* Top edge rule — gives the field its "lifted off the page" feel. */}
        <line
          class="top-rule"
          x1="0"
          y1="0"
          x2="200"
          y2="0"
          stroke="currentColor"
          stroke-width="1"
          opacity="0.5"
          vector-effect="non-scaling-stroke"
        />

        {/* Edges — incident to active go to accent. */}
        {local.edges.map((e) => {
          const a = local.nodes.find((n) => n.id === e.a);
          const b = local.nodes.find((n) => n.id === e.b);
          if (!a || !b) return null;
          const onActive = e.a === slug || e.b === slug;
          return (
            <line
              class={`edge ${onActive ? "on" : ""}`}
              x1={a.x}
              y1={a.y}
              x2={b.x}
              y2={b.y}
              vector-effect="non-scaling-stroke"
            />
          );
        })}

        {/* Nodes — active is non-clickable (current page); neighbors link. */}
        {local.nodes.map((n) => {
          const isMe = n.id === slug;
          const r = isMe ? ACTIVE_R : NEIGHBOR_R;
          const title = titles[n.id] ?? n.id;
          if (isMe) {
            return (
              <g class="node active" data-slug={n.id}>
                <title>{title}</title>
                <circle
                  class="breathe-ring"
                  cx={n.x}
                  cy={n.y}
                  r={r + 2}
                  fill="none"
                  stroke="var(--accent)"
                  stroke-width="0.7"
                  vector-effect="non-scaling-stroke"
                  style={`--r-start: ${r + 2}; --r-end: ${r + 8};`}
                />
                <circle class="dot" cx={n.x} cy={n.y} r={r} fill="var(--accent)" />
              </g>
            );
          }
          return (
            <a class="node neighbor" href={`/wiki/${n.id}/`} data-slug={n.id}>
              <title>{title}</title>
              <circle class="hit" cx={n.x} cy={n.y} r={r + 4} fill="transparent" />
              <circle class="dot" cx={n.x} cy={n.y} r={r} fill="currentColor" />
              <text
                class="label"
                x={n.x}
                y={n.y - r - 4}
                text-anchor="middle"
                font-family="var(--font-mono)"
                font-size="10"
                fill="currentColor"
                vector-effect="non-scaling-stroke"
              >
                {title}
              </text>
            </a>
          );
        })}

        {/* Cluster name floated above the field. */}
        {myClusterMeta && (
          <text
            class="cluster-name"
            x={100}
            y={-2}
            text-anchor="middle"
            font-family="var(--font-heading)"
            font-style="italic"
            font-size="11"
            fill="currentColor"
            opacity="0.6"
          >
            {myClusterMeta.short}
          </text>
        )}

        <text
          class="footer-caption"
          x="0"
          y="220"
          font-family="var(--font-mono)"
          font-size="10"
          fill="currentColor"
          opacity="0.55"
        >
          {local.nodes.length - 1} neighbors
        </text>
      </svg>
    </div>
  )
}

<style>
  .constellation-local {
    color: rgb(0 0 0 / 0.88);
  }
  :global(.dark) .constellation-local {
    color: rgb(255 255 255 / 0.88);
  }
  .constellation-local :global(.constellation-local-svg) {
    display: block;
    overflow: visible;
  }

  /* Cluster regions */
  .constellation-local :global(.region) {
    fill: oklch(0.86 0.04 var(--hue));
    opacity: 0.5;
  }
  :global(.dark) .constellation-local :global(.region) {
    fill: oklch(0.34 0.04 var(--hue));
  }
  .constellation-local :global(.region[data-active]) {
    opacity: 1;
  }

  /* Cluster name halo so it stays legible over the region tint. */
  .constellation-local :global(.cluster-name) {
    paint-order: stroke fill;
    stroke: #f6f4ef;
    stroke-width: 4px;
    stroke-linejoin: round;
    pointer-events: none;
    transition: opacity 150ms ease;
  }
  :global(.dark) .constellation-local :global(.cluster-name) {
    stroke: #18161a;
  }
  /* When a neighbor is being inspected, the active concept's cluster label
     steps aside so the neighbor's own label has the field. */
  .constellation-local :global(.constellation-local-svg:has(.node.neighbor:hover)) :global(.cluster-name),
  .constellation-local :global(.constellation-local-svg:has(.node.neighbor:focus-visible)) :global(.cluster-name) {
    opacity: 0;
  }

  /* Edges — base opacity dropped in dark mode to match the strip; near-white
     currentColor on a near-black field reads heavier than the same alpha
     would on a paper-toned field. */
  .constellation-local :global(.edge) {
    stroke: currentColor;
    stroke-width: 0.4;
    opacity: 0.18;
  }
  :global(.dark) .constellation-local :global(.edge) {
    opacity: 0.1;
  }
  .constellation-local :global(.edge.on),
  :global(.dark) .constellation-local :global(.edge.on) {
    stroke: var(--accent);
    stroke-width: 0.8;
    opacity: 0.55;
  }

  /* Neighbor nodes */
  .constellation-local :global(.node) {
    cursor: default;
  }
  .constellation-local :global(.node.neighbor) {
    cursor: pointer;
  }
  .constellation-local :global(.node.neighbor .dot) {
    opacity: 0.7;
    transition: opacity 150ms ease;
  }
  .constellation-local :global(.node.neighbor:hover .dot),
  .constellation-local :global(.node.neighbor:focus-visible .dot) {
    fill: var(--accent);
    opacity: 1;
  }

  /* Hover-revealed labels — same paint-order halo treatment as the strip. */
  .constellation-local :global(.node.neighbor .label) {
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease-in-out;
    paint-order: stroke fill;
    stroke: #f6f4ef;
    stroke-width: 4px;
    stroke-linejoin: round;
    fill: var(--accent);
  }
  :global(.dark) .constellation-local :global(.node.neighbor .label) {
    stroke: #18161a;
  }
  .constellation-local :global(.node.neighbor:hover .label),
  .constellation-local :global(.node.neighbor:focus-visible .label) {
    opacity: 1;
  }

  /* Active node breathe ring — same shape as the strip, slightly wider stroke */
  .constellation-local :global(.breathe-ring) {
    animation: constellation-local-breathe 2.6s linear infinite;
    opacity: 0.5;
  }
  @keyframes constellation-local-breathe {
    0%,
    100% {
      r: var(--r-start);
      opacity: 0.65;
    }
    50% {
      r: var(--r-end);
      opacity: 0.05;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .constellation-local :global(.breathe-ring) {
      display: none !important;
      animation: none !important;
    }
  }
</style>
