---
/**
 * Constellation strip — wayfinding accent for /wiki.
 *
 * Renders the pre-solved wiki layout (built into src/data/constellation-
 * layout.json by `pnpm constellation`) as a static SVG. Nodes link to their
 * concepts; node radius scales with source count; edges connect concepts
 * that share a source or cite each other. Hover labels are pure CSS.
 *
 * The widget is intentionally small (~320 × 140 by default) and tucked into
 * the upper-right corner of the wiki hero. Content reads first; the
 * constellation is wayfinding, not the centerpiece.
 */
import layout from "@data/constellation-layout.json";

type Props = {
  width?: number;
  height?: number;
  activeSlug?: string;
};

const { width = 320, height = 140, activeSlug } = Astro.props;

// Layout was solved against a 1024 × 220 canvas; the SVG scales to fit any
// width via `viewBox` + `preserveAspectRatio="xMidYMid meet"` so we don't
// have to re-solve at the consumer's dimensions.
const VIEWBOX_W = 1024;
const VIEWBOX_H = 220;

type LayoutNode = { id: string; x: number; y: number; weight: number };
type LayoutEdge = { a: string; b: string };

const nodes: LayoutNode[] = layout.global.nodes;
const edges: LayoutEdge[] = layout.global.edges;
const titles: Record<string, string> = layout.titles;
const positionsById = new Map(nodes.map((n) => [n.id, n]));
const maxWeight = nodes.reduce((m, n) => Math.max(m, n.weight), 1);
---

<div class="constellation-strip relative" style={`width: ${width}px; max-width: 100%;`}>
  <svg
    viewBox={`0 0 ${VIEWBOX_W} ${VIEWBOX_H}`}
    width={width}
    height={height}
    preserveAspectRatio="xMidYMid meet"
    style="display: block; width: 100%; height: auto;"
    role="img"
    aria-label={`Wiki concept graph: ${nodes.length} concepts`}
  >
    {
      edges.map((e) => {
        const a = positionsById.get(e.a);
        const b = positionsById.get(e.b);
        if (!a || !b) return null;
        const isActive = activeSlug === e.a || activeSlug === e.b;
        return (
          <line
            x1={a.x}
            y1={a.y}
            x2={b.x}
            y2={b.y}
            stroke={isActive ? "var(--accent)" : "currentColor"}
            stroke-width={isActive ? 0.8 : 0.5}
            opacity={isActive ? 0.55 : 0.18}
          />
        );
      })
    }
    {
      nodes.map((n) => {
        const r = 2 + (n.weight / maxWeight) * 4;
        const isActive = n.id === activeSlug;
        const title = titles[n.id] ?? n.id;
        return (
          <a class="constellation-node" href={`/wiki/${n.id}/`}>
            <title>{title}</title>
            {/* Bigger transparent hit-target */}
            <circle cx={n.x} cy={n.y} r={r + 4} fill="transparent" />
            <circle
              class="dot"
              cx={n.x}
              cy={n.y}
              r={r}
              fill={isActive ? "var(--accent)" : "currentColor"}
              opacity={isActive ? 1 : 0.55}
            />
            <text
              class="label"
              x={n.x}
              y={n.y - r - 6}
              text-anchor="middle"
              font-family="var(--font-mono)"
              font-size="10"
              fill="currentColor"
            >
              {title}
            </text>
          </a>
        );
      })
    }
  </svg>
</div>

<style>
  .constellation-strip {
    color: rgb(0 0 0 / 0.85);
  }
  :global(.dark) .constellation-strip {
    color: rgb(255 255 255 / 0.85);
  }
  /* Hover labels — pure CSS, no JS. */
  .constellation-strip :global(.constellation-node) .label {
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease-in-out;
  }
  .constellation-strip :global(.constellation-node):hover .label,
  .constellation-strip :global(.constellation-node):focus-visible .label {
    opacity: 1;
  }
  .constellation-strip :global(.constellation-node):hover .dot,
  .constellation-strip :global(.constellation-node):focus-visible .dot {
    fill: var(--accent);
    opacity: 1;
  }
  .constellation-strip :global(.constellation-node) {
    cursor: pointer;
  }
</style>
