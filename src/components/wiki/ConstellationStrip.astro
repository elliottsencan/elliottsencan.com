---
/**
 * Constellation strip — V2 "Cluster constellations".
 *
 * Hero widget on /wiki. Renders the pre-solved layout
 * (`src/data/constellation-layout.json` produced by `pnpm constellation`)
 * as a static SVG with five hand-curated cluster regions, weight-scaled
 * nodes, and a hover/focus protocol that lights up the focused node, its
 * 1-hop neighborhood, and its cluster region.
 *
 * Visual rules: design_handoff_constellation_v2/README.md §1.
 *
 * Hover/focus is implemented via data-attribute toggles on the SVG root —
 * CSS attribute selectors do all the visual transitions; the inline IIFE
 * only updates the attrs.
 *
 * Sizing: container is fully fluid. Pass desktop intent via `width`; the
 * height is derived from the layout's natural viewBox aspect so the strip
 * fills the container with no internal whitespace. All SVG font sizes are
 * in viewBox user-units, so labels scale with the field.
 */
import layout from "@data/constellation-layout.json";
import {
  STRIP_DEFAULT_WIDTH,
  STRIP_VH,
  STRIP_VW,
  STRIP_VX,
  STRIP_VY,
} from "@lib/constellationGeometry";

type Props = {
  width?: number;
  activeSlug?: string;
};

const { width = STRIP_DEFAULT_WIDTH, activeSlug } = Astro.props;

type LayoutNode = { id: string; x: number; y: number; weight: number };
type LayoutEdge = {
  a: string;
  b: string;
  weight: number;
  via: { link: number; cocite: number };
  display: boolean;
};
type Cluster = { id: string; title: string; short: string; hue: number };

const nodes: LayoutNode[] = layout.global.nodes;
const edges: LayoutEdge[] = layout.global.edges;
const titles: Record<string, string> = layout.titles;
const clusters: Cluster[] = layout.clusters;
const clusterById: Record<string, string | null> = layout.clusterById;

// viewBox derivation lives in @lib/constellationGeometry so the local rail
// can mirror it and both widgets render at identical pixel sizes when
// passed the same `width`.
const VX = STRIP_VX;
const VY = STRIP_VY;
const VW = STRIP_VW;
const VH = STRIP_VH;

// ─── weight normalization ────────────────────────────────────────────────
const weights = nodes.map((n) => n.weight);
const wMin = Math.min(...weights);
const wMax = Math.max(...weights);
const wNorm = (w: number) => (wMax === wMin ? 0.5 : (w - wMin) / (wMax - wMin));

// Density-aware radius scale — no-op below 80 concepts, shrinks smoothly
// above. Keeps the strip legible as the corpus grows past the current 41.
// Base sizes are tuned to match the visual prominence of nodes in the local
// rail (active r=5, neighbor r=2.6), so the global field reads with similar
// node weight per square viewBox unit.
const N = nodes.length;
const densityScale = Math.max(0.5, Math.min(1, 80 / N));
const nodeR = (w: number) => (2.2 + 4.6 * wNorm(w)) * densityScale;

// ─── adjacency (1-hop neighborhood per node) ─────────────────────────────
// Built from displayed edges only — neighbor highlighting reflects what the
// reader can actually see, so we don't surface invisible relationships when
// hovering a node.
const visibleEdges = edges.filter((e) => e.display);
const adj = new Map<string, Set<string>>();
for (const n of nodes) {
  adj.set(n.id, new Set());
}
for (const e of visibleEdges) {
  adj.get(e.a)?.add(e.b);
  adj.get(e.b)?.add(e.a);
}

// Per-edge stroke width and opacity multiplier driven by weight. Strong ties
// (link-backed or weight ≥ 4) read first; weak co-citation pairs fade.
const edgeStrokeW = (w: number) => 0.4 + Math.min(w, 6) * 0.15;
const edgeOpacityMul = (w: number) => Math.min(1, w / 4);

// ─── cluster region geometry (convex hull → inflate → cardinal-spline) ──
type Pt = { x: number; y: number };

function convexHull(points: Pt[]): Pt[] {
  if (points.length <= 1) {
    return points.slice();
  }
  const pts = points.slice().sort((p, q) => p.x - q.x || p.y - q.y);
  const cross = (o: Pt, a: Pt, b: Pt) => (a.x - o.x) * (b.y - o.y) - (a.y - o.y) * (b.x - o.x);
  const lower: Pt[] = [];
  for (const p of pts) {
    while (lower.length >= 2 && cross(lower[lower.length - 2], lower[lower.length - 1], p) <= 0) {
      lower.pop();
    }
    lower.push(p);
  }
  const upper: Pt[] = [];
  for (let i = pts.length - 1; i >= 0; i--) {
    const p = pts[i];
    while (upper.length >= 2 && cross(upper[upper.length - 2], upper[upper.length - 1], p) <= 0) {
      upper.pop();
    }
    upper.push(p);
  }
  return lower.slice(0, -1).concat(upper.slice(0, -1));
}

function inflateHull(hull: Pt[], pad: number): Pt[] {
  if (hull.length === 0) {
    return hull;
  }
  const cx = hull.reduce((s, p) => s + p.x, 0) / hull.length;
  const cy = hull.reduce((s, p) => s + p.y, 0) / hull.length;
  return hull.map((p) => {
    const dx = p.x - cx;
    const dy = p.y - cy;
    const d = Math.hypot(dx, dy) || 1;
    return { x: p.x + (dx / d) * pad, y: p.y + (dy / d) * pad };
  });
}

function smoothClosed(points: Pt[]): string {
  if (points.length < 3) {
    return "";
  }
  const n = points.length;
  let d = `M ${points[0].x} ${points[0].y}`;
  for (let i = 0; i < n; i++) {
    const p0 = points[(i - 1 + n) % n];
    const p1 = points[i];
    const p2 = points[(i + 1) % n];
    const p3 = points[(i + 2) % n];
    const t = 0.18;
    const c1x = p1.x + (p2.x - p0.x) * t;
    const c1y = p1.y + (p2.y - p0.y) * t;
    const c2x = p2.x - (p3.x - p1.x) * t;
    const c2y = p2.y - (p3.y - p1.y) * t;
    d += ` C ${c1x} ${c1y}, ${c2x} ${c2y}, ${p2.x} ${p2.y}`;
  }
  return `${d} Z`;
}

const clusterGroups = clusters
  .map((cl) => {
    const members = nodes.filter((n) => clusterById[n.id] === cl.id);
    if (members.length < 2) {
      return null;
    }
    const hull = convexHull(members.map((n) => ({ x: n.x, y: n.y })));
    const path = smoothClosed(inflateHull(hull, 22));
    // Centroid x, top edge y (minus pad) — drives the focus-only italic label.
    const labelX = members.reduce((s, n) => s + n.x, 0) / members.length;
    const top = Math.min(...members.map((n) => n.y));
    return { ...cl, path, labelX, labelY: top - 12 };
  })
  .filter((g): g is NonNullable<typeof g> => g !== null);

const nodeById = new Map(nodes.map((n) => [n.id, n]));
---

<div
  class="constellation-well"
  style={`--cs-w: ${width}px; --cs-aspect: ${VW} / ${VH};`}
>
  <div class="constellation-strip">
    <svg
      id="constellation-strip"
    viewBox={`${VX} ${VY} ${VW} ${VH}`}
    width="100%"
    height="100%"
    preserveAspectRatio="xMidYMid meet"
    role="img"
    aria-label={`Wiki concept graph: ${nodes.length} concepts in ${clusterGroups.length} neighborhoods`}
    data-active-slug={activeSlug ?? ""}
  >
    {/* Cluster regions — drawn first so everything else stacks above. */}
    {
      clusterGroups.map((g) => (
        <path
          class="region"
          data-cluster={g.id}
          data-hue={g.hue}
          d={g.path}
          style={`--hue: ${g.hue};`}
        />
      ))
    }

    {/* Cluster names — italic, opacity 0 by default; only the focused
        cluster's label fades in. font-size is in viewBox user-units. */}
    {
      clusterGroups.map((g) => (
        <text
          class="cluster-name"
          data-cluster={g.id}
          x={g.labelX}
          y={g.labelY}
          text-anchor="middle"
          font-family="var(--font-heading)"
          font-style="italic"
          font-size="22"
          letter-spacing="0.01em"
          fill="currentColor"
          vector-effect="non-scaling-stroke"
        >
          {g.short}
        </text>
      ))
    }

    {/* Edges — same-cluster as straight lines, cross-cluster as gentle
        quadratic Beziers so coincident pairs don't overlap pixel-for-pixel
        and the visual reads as relationships passing through neighborhoods.
        Width and opacity per edge come from weight via CSS variables; the
        focus-state rules below override those vars for incident edges. */}
    {
      visibleEdges.map((e) => {
        const a = nodeById.get(e.a);
        const b = nodeById.get(e.b);
        if (!a || !b) return null;
        const sameCluster = clusterById[e.a] === clusterById[e.b] && clusterById[e.a] != null;
        const styleVars = `--edge-w: ${edgeStrokeW(e.weight)}; --edge-o-mul: ${edgeOpacityMul(e.weight)};`;
        if (sameCluster) {
          return (
            <line
              class="edge same"
              data-a={e.a}
              data-b={e.b}
              x1={a.x}
              y1={a.y}
              x2={b.x}
              y2={b.y}
              stroke="currentColor"
              vector-effect="non-scaling-stroke"
              style={styleVars}
            />
          );
        }
        const dx = b.x - a.x;
        const dy = b.y - a.y;
        const dist = Math.hypot(dx, dy) || 1;
        const offset = -dist * 0.12;
        const cx = (a.x + b.x) / 2 + (-dy / dist) * offset;
        const cy = (a.y + b.y) / 2 + (dx / dist) * offset;
        return (
          <path
            class="edge cross"
            data-a={e.a}
            data-b={e.b}
            d={`M ${a.x} ${a.y} Q ${cx} ${cy} ${b.x} ${b.y}`}
            fill="none"
            stroke="currentColor"
            vector-effect="non-scaling-stroke"
            style={styleVars}
          />
        );
      })
    }

    {/* Nodes — wrapped in <a> for keyboard tab order + click navigation. */}
    {
      nodes.map((n) => {
        const r = nodeR(n.weight);
        const title = titles[n.id] ?? n.id;
        const cid = clusterById[n.id] ?? "";
        const neighbors = [...(adj.get(n.id) ?? [])].join(" ");
        return (
          <a
            class="node"
            href={`/wiki/${n.id}/`}
            data-slug={n.id}
            data-cluster={cid}
            data-neighbors={neighbors}
            style={`--node-r: ${r};`}
          >
            <title>{title}</title>
            {/* Wider transparent hit-target than the visible dot. */}
            <circle class="hit" cx={n.x} cy={n.y} r={r + 10} fill="transparent" />
            {/* Breathe ring — animated only when this node is the focus. */}
            <circle
              class="breathe-ring"
              cx={n.x}
              cy={n.y}
              r={r + 2}
              fill="none"
              stroke="var(--accent)"
              stroke-width="0.6"
              vector-effect="non-scaling-stroke"
              style={`--r-start: ${r + 2}; --r-end: ${r + 7};`}
            />
            <circle class="dot" cx={n.x} cy={n.y} r={r} fill="currentColor" />
            <text
              class="label"
              x={n.x}
              y={n.y - r - 5}
              text-anchor="middle"
              font-family="var(--font-mono)"
              font-size="14"
              fill="currentColor"
            >
              {title}
            </text>
          </a>
        );
      })
    }
    </svg>
  </div>
</div>

<style is:global>
  /* ─── Sizing ─────────────────────────────────────────────────────────
     The strip requests `--cs-w` directly and caps at the parent's width
     on narrow viewports. We flipped from `width: 100%; max-width: --cs-w`
     because in a CSS Grid `auto` track that pattern resolves against
     min-content, which an aspect-ratio'd box can shrink to ~0 — so
     bumping --cs-w in @lib/constellationGeometry didn't actually widen
     the column. With `width: --cs-w; max-width: 100%`, the auto track
     sees a definite track size and the col-1 prose makes room. The SVG
     inside fills 100%/100%; viewBox + preserveAspectRatio handle the
     geometry. All SVG fonts and stroke widths sit in viewBox user-units,
     so they scale with the field — no JS, no media query, no SSG-time
     scale math. */
  /* The "well" — a flat tonal step off the page canvas (--well vs --canvas)
     that gives the constellation visual weight and reads it as a contained
     object. Depth via tone only, no border/shadow (matches the token's own
     design intent in global.css). The well owns the footprint (width +
     padding) so the inner aspect-locked box fills it without shifting the
     grid column. Overflow stays visible so hover labels aren't clipped at
     the surface edge. Mirrors .constellation-well in ConstellationLocal. */
  .constellation-well {
    width: var(--cs-w);
    max-width: 100%;
    box-sizing: border-box;
    padding: 1.25rem;
    background: var(--well);
    border-radius: 0.5rem;
  }

  .constellation-strip {
    width: 100%;
    max-width: 100%;
    aspect-ratio: var(--cs-aspect);
    color: rgb(0 0 0 / 0.88);
  }
  .dark .constellation-strip {
    color: rgb(255 255 255 / 0.88);
  }

  /* ─── Cluster regions ───────────────────────────────────────────────── */
  /* Opacity matches the local rail (0.5 base / 1.0 active) — consistent
     color weight between global and per-concept views. */
  #constellation-strip .region {
    fill: oklch(0.84 0.06 var(--hue));
    opacity: 0.5;
    stroke: oklch(0.62 0.08 var(--hue));
    stroke-width: 1;
    stroke-opacity: 0.35;
    vector-effect: non-scaling-stroke;
    transition:
      fill 200ms ease,
      opacity 200ms ease,
      stroke-opacity 200ms ease;
  }
  .dark #constellation-strip .region {
    fill: oklch(0.36 0.06 var(--hue));
    stroke: oklch(0.55 0.08 var(--hue));
    stroke-opacity: 0.45;
  }
  /* Focused cluster swaps to higher chroma at full opacity. */
  #constellation-strip .region[data-on] {
    fill: oklch(0.76 0.10 var(--hue));
    opacity: 1;
    stroke-opacity: 0.7;
  }
  .dark #constellation-strip .region[data-on] {
    fill: oklch(0.44 0.10 var(--hue));
    stroke-opacity: 0.8;
  }

  /* ─── Cluster names (focus-only italic labels) ──────────────────────── */
  /* Pre-rendered for all clusters but invisible by default; only the
     focused cluster's label fades in. Paper-stroke halo separates the
     italic from the region fill underneath. */
  #constellation-strip .cluster-name {
    paint-order: stroke fill;
    stroke: var(--well);
    stroke-width: 4px;
    stroke-linejoin: round;
    pointer-events: none;
    opacity: 0;
    font-feature-settings: "ss01" 1;
    transition: opacity 180ms ease;
  }
  #constellation-strip .cluster-name[data-on] {
    opacity: 0.75;
  }

  /* ─── Edges ─────────────────────────────────────────────────────────── */
  /* Width and per-edge opacity multiplier come from inline CSS vars set per
     edge (driven by relationship weight in the producer). Base opacity sits
     just below mesh so the field reads as ground; dark mode halves again
     because currentColor resolves to near-white in dark and reads heavier
     than the same value in light. */
  #constellation-strip .edge.same {
    stroke-width: var(--edge-w, 0.5);
    opacity: calc(0.22 * var(--edge-o-mul, 1));
  }
  #constellation-strip .edge.cross {
    stroke-width: var(--edge-w, 0.3);
    opacity: calc(0.08 * var(--edge-o-mul, 1));
  }
  .dark #constellation-strip .edge.same {
    opacity: calc(0.14 * var(--edge-o-mul, 1));
  }
  .dark #constellation-strip .edge.cross {
    opacity: calc(0.06 * var(--edge-o-mul, 1));
  }
  /* When focus is active, dim non-incident edges hard. */
  #constellation-strip[data-focus] .edge {
    opacity: 0.04;
  }
  .dark #constellation-strip[data-focus] .edge {
    opacity: 0.03;
  }
  /* Incident edges go to accent — fixed weight regardless of per-edge var. */
  #constellation-strip[data-focus] .edge[data-on],
  .dark #constellation-strip[data-focus] .edge[data-on] {
    stroke: var(--accent);
    stroke-width: 0.9;
    opacity: 0.55;
  }

  /* ─── Nodes ─────────────────────────────────────────────────────────── */
  #constellation-strip .node {
    cursor: pointer;
  }
  #constellation-strip .node .dot {
    opacity: 0.75;
    transition: opacity 150ms ease;
  }
  /* When focus is active: dim non-focus, non-neighbor nodes. */
  #constellation-strip[data-focus] .node:not([data-focus-self]):not([data-neighbor]) .dot {
    opacity: 0.18;
  }
  #constellation-strip .node[data-focus-self] .dot {
    fill: var(--accent);
    opacity: 1;
    filter: drop-shadow(0 0 4px color-mix(in oklch, var(--accent) 35%, transparent));
  }

  /* ─── Breathe ring (focus only) ─────────────────────────────────────── */
  #constellation-strip .breathe-ring {
    display: none;
  }
  #constellation-strip .node[data-focus-self] .breathe-ring {
    display: inline;
    animation: constellation-breathe 2.6s linear infinite;
  }
  @keyframes constellation-breathe {
    0%,
    100% {
      r: var(--r-start);
      opacity: 0.65;
    }
    50% {
      r: var(--r-end);
      opacity: 0.05;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #constellation-strip .breathe-ring {
      display: none !important;
      animation: none !important;
    }
  }

  /* ─── Hover labels ──────────────────────────────────────────────────── */
  #constellation-strip .label {
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease-in-out;
    paint-order: stroke fill;
    stroke: var(--well);
    stroke-width: 5px;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }
  /* Only the actively-focused node ever shows its label — neighbors are
     identified by the highlighted edges and the cluster region focus, not
     by their text. This keeps the field legible at any node degree. */
  #constellation-strip .node[data-focus-self] .label {
    opacity: 1;
    fill: var(--accent);
    letter-spacing: 0.04em;
  }
  /* No-JS fallback: hover reveals the label for the hovered node. */
  #constellation-strip:not([data-focus]) .node:hover .label,
  #constellation-strip:not([data-focus]) .node:focus-visible .label {
    opacity: 1;
  }
  #constellation-strip:not([data-focus]) .node:hover .dot,
  #constellation-strip:not([data-focus]) .node:focus-visible .dot {
    fill: var(--accent);
    opacity: 1;
  }

  /* ─── Mobile / coarse-pointer adjustments ───────────────────────────────
     Touch readers can't hover and taps follow links directly (no
     tap-to-preview gesture), so we surface the structural cues that are
     focus-only on desktop (italic neighborhood names) and trim the visual
     noise that needs the hover protocol to be legible (cross-cluster
     Béziers). Hit targets enlarge on coarse pointer for forgiving taps. */
  @media (max-width: 640px) {
    #constellation-strip .cluster-name {
      opacity: 0.45;
    }
    #constellation-strip .cluster-name[data-on] {
      opacity: 0.85;
    }
    /* Hide non-focus-incident cross-cluster edges; focus-state's
       [data-on] override above keeps incident ones visible in accent. */
    #constellation-strip .edge.cross:not([data-on]) {
      display: none;
    }
  }
  @media (pointer: coarse) {
    #constellation-strip .hit {
      r: 22;
    }
  }
</style>

<script>
  // Hover/focus protocol — toggles data attributes the CSS above keys off.
  // Intentionally tiny: no framework, no signal library; the SVG is the
  // state container.
  (() => {
    const svg = document.getElementById("constellation-strip");
    if (!svg) return;

    const nodes = Array.from(svg.querySelectorAll<SVGElement>(".node"));
    const edges = Array.from(svg.querySelectorAll<SVGElement>(".edge"));
    // Includes .cluster-name so the focus-only italic label lights up
    // alongside its region — both key off matching data-cluster.
    const regions = Array.from(
      svg.querySelectorAll<SVGElement>(".region, .cluster-name"),
    );

    const setFocus = (slug: string | null) => {
      // Clear toggleable state up front — covers slug→slug transitions
      // cleanly without stale attributes leaking through.
      for (const n of nodes) {
        n.removeAttribute("data-focus-self");
        n.removeAttribute("data-neighbor");
      }
      for (const e of edges) e.removeAttribute("data-on");
      for (const r of regions) r.removeAttribute("data-on");

      if (!slug) {
        svg.removeAttribute("data-focus");
        return;
      }
      const focusEl = nodes.find((n) => n.dataset.slug === slug);
      if (!focusEl) return;
      const neighborSet = new Set(
        (focusEl.dataset.neighbors ?? "").split(/\s+/).filter(Boolean),
      );
      const cluster = focusEl.dataset.cluster ?? "";

      svg.setAttribute("data-focus", slug);

      for (const n of nodes) {
        const id = n.dataset.slug ?? "";
        if (id === slug) n.setAttribute("data-focus-self", "");
        if (neighborSet.has(id)) n.setAttribute("data-neighbor", "");
      }
      for (const e of edges) {
        const a = e.getAttribute("data-a");
        const b = e.getAttribute("data-b");
        if (a === slug || b === slug) e.setAttribute("data-on", "");
      }
      for (const r of regions) {
        const cid = r.getAttribute("data-cluster");
        if (cid && cid === cluster) r.setAttribute("data-on", "");
      }
    };

    // Pointer/keyboard focus only — taps on touch devices follow the link
    // directly. Touch readers get the structural mobile fallbacks (italic
    // cluster names at low opacity, cross-cluster edges hidden) without
    // any tap-to-preview gesture.
    for (const n of nodes) {
      const slug = n.dataset.slug ?? null;
      n.addEventListener("mouseenter", () => setFocus(slug));
      n.addEventListener("focusin", () => setFocus(slug));
    }
    svg.addEventListener("mouseleave", () => setFocus(null));
    svg.addEventListener("focusout", (e) => {
      const next = e.relatedTarget as Node | null;
      if (!next || !svg.contains(next)) setFocus(null);
    });

    // If an `activeSlug` prop is set, surface it as the initial focus so
    // entry-page strips (none today, but the prop is part of the API) light
    // up that node on first paint without requiring a hover.
    const initialActive = svg.getAttribute("data-active-slug");
    if (initialActive) setFocus(initialActive);
  })();
</script>
