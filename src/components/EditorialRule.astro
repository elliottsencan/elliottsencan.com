---
/**
 * Thin horizontal dot-grid rule — the site's strongest visual signature.
 *
 * The dot pattern is painted by `::before` and `::after` pseudo-elements
 * defined on `.dot-rule` in global.css (one baseline, one cursor-halo
 * overlay). The element itself is a transparent host so the overlay
 * composites cleanly without being multiplied down by a parent opacity.
 *
 * `py-2` gives a 16px interactive band around the 1px dot line so the
 * cursor-tracking mousemove has a realistic hover zone. The default `my-8`
 * matches the original visual rhythm between major page sections; pass
 * `compact` to drop the margins so the rule can sit inside a hero cell or
 * other tight context where the surrounding flex/grid spacing already
 * provides breathing room. The `class` passthrough lets callers stitch
 * the rule into a grid via `col-start-…` / `row-start-…` placement.
 *
 * Decorative — hidden from assistive tech.
 */
type Props = {
  compact?: boolean;
  class?: string;
};
const { compact = false, class: className = "" } = Astro.props;
---

<div
  role="presentation"
  aria-hidden="true"
  class:list={["dot-rule h-px w-full py-2", compact ? "my-0" : "my-8", className]}
>
</div>
