---
import "../styles/global.css";
import { PERSON, SCHEMA_IDS, SITE } from "@consts";

interface Props {
  title: string;
  description: string;
  image?: string;
  /** Defaults to "website". Posts pass "article" to unlock article:* meta + BlogPosting schema. */
  ogType?: "website" | "article";
  /**
   * Overrides the computed `<link rel="canonical">` URL — used when a post
   * is syndicated from another site (set via the `canonical` frontmatter field
   * on the blog collection).
   */
  canonical?: string | URL;
  publishedTime?: Date;
  updatedTime?: Date;
  tags?: string[];
  author?: string;
  /** BlogPosting for blog posts, Article for project/case-study pages. Ignored when ogType="website". */
  schemaType?: "BlogPosting" | "Article";
  /** Emit the Person JSON-LD block. Intended only for the homepage and /about. */
  includePersonSchema?: boolean;
  /**
   * Path crumbs from root → current page. When present, a BreadcrumbList
   * JSON-LD block is emitted; Google renders these directly in SERPs.
   */
  breadcrumbs?: Array<{ name: string; url: string | URL }>;
  /**
   * Source URL for /reading entries. Emitted as `Article.isBasedOn` so search
   * engines understand the page is a summary of an external source.
   */
  basedOn?: string;
  /**
   * Cited /reading entry URLs for /wiki entries. Emitted as `Article.citation`
   * so search engines see the synthesis-from-multiple-sources relationship.
   */
  citations?: string[];
}

const {
  title,
  description,
  image = "/favicon.ico",
  ogType = "website",
  canonical,
  publishedTime,
  updatedTime,
  tags,
  author,
  schemaType = "BlogPosting",
  includePersonSchema = false,
  breadcrumbs,
  basedOn,
  citations,
} = Astro.props;

const canonicalURL = canonical
  ? new URL(canonical.toString(), Astro.site)
  : new URL(Astro.url.pathname, Astro.site);

const imageURL = new URL(image, Astro.site);
const siteURL = Astro.site?.toString() ?? "/";

// ---- JSON-LD ----
// Inline as `<script type="application/ld+json">` blocks; no client-side JS.

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": SCHEMA_IDS.WEBSITE,
  name: SITE.TITLE,
  url: siteURL,
  description: SITE.DESCRIPTION,
};

const personSchema = includePersonSchema
  ? {
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": SCHEMA_IDS.PERSON,
      name: PERSON.NAME,
      url: siteURL,
      jobTitle: PERSON.JOB_TITLE,
      email: `mailto:${SITE.EMAIL}`,
      homeLocation: { "@type": "Place", name: SITE.LOCATION },
      sameAs: PERSON.SAME_AS,
    }
  : null;

// `Article.author` references the Person via @id when the author is the site
// owner — search engines resolve the reference to the homepage's Person block
// rather than treating each article's inline author as a separate entity.
// Falls back to an inline Person for guest authors.
const articleAuthor =
  !author || author === PERSON.NAME
    ? { "@id": SCHEMA_IDS.PERSON }
    : { "@type": "Person", name: author };

// Only emit Article schema when we have enough signal: ogType=article AND a publish date.
// Without a date the schema is invalid anyway, so skipping it keeps validators clean.
const articleSchema =
  ogType === "article" && publishedTime
    ? {
        "@context": "https://schema.org",
        "@type": schemaType,
        headline: title,
        description,
        datePublished: publishedTime.toISOString(),
        ...(updatedTime && { dateModified: updatedTime.toISOString() }),
        author: articleAuthor,
        image: imageURL.toString(),
        ...(tags?.length && { keywords: tags.join(", ") }),
        ...(basedOn && {
          isBasedOn: { "@type": "WebPage", url: basedOn },
        }),
        ...(citations?.length && {
          citation: citations.map((url) => ({ "@type": "WebPage", url })),
        }),
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": canonicalURL.toString(),
        },
      }
    : null;

const breadcrumbSchema = breadcrumbs?.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbs.map((crumb, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: crumb.name,
        item: new URL(crumb.url.toString(), Astro.site).toString(),
      })),
    }
  : null;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<!-- Favicons. SVG is the primary asset for modern browsers and respects
     prefers-color-scheme (see public/favicon.svg). PNG/ICO rasters bake
     the dark scheme; regenerate via `pnpm favicons` when favicon.svg
     changes. -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Font preloads -->
<link rel="preload" href="/fonts/Newsreader-latin.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/Fraunces-latin.woff2" as="font" type="font/woff2" crossorigin />
<link
  rel="preload"
  href="/fonts/PPNeueMontreal-Medium.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<meta name="generator" content={Astro.generator} />

<!-- Mobile browser UI chrome matches the canvas color in each mode. Kept in
     sync with html { background-color } in global.css. -->
<meta name="theme-color" content="#f6f4ef" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#18161a" media="(prefers-color-scheme: dark)" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Intro animations (signature draw, contributions rail reveal): play
     once per browser session. First page in a tab plays them; subsequent
     navigations within the same tab skip via the sessionStorage flag. New
     tab / reload / fresh window starts a new session and replays. -->
<script is:inline>
  if (sessionStorage.getItem("introPlayed")) {
    document.documentElement.classList.add("intro-played");
  } else {
    sessionStorage.setItem("introPlayed", "1");
  }
</script>

<!-- Primary Meta Tags.
     `<title>` carries the site suffix for the browser tab; og:title, twitter:title,
     and JSON-LD `headline` stay raw because OG exposes site name separately via
     `og:site_name` and adding the suffix twice makes social previews uglier. -->
<title>{title} | {SITE.TITLE}</title>
<meta name="title" content={`${title} | ${SITE.TITLE}`} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content={SITE.TITLE} />

{
  ogType === "article" && (
    <>
      {publishedTime && (
        <meta property="article:published_time" content={publishedTime.toISOString()} />
      )}
      {updatedTime && (
        <meta property="article:modified_time" content={updatedTime.toISOString()} />
      )}
      <meta property="article:author" content={author ?? PERSON.NAME} />
      {tags?.map((tag) => <meta property="article:tag" content={tag} />)}
    </>
  )
}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

<!-- JSON-LD structured data. `is:inline` is required because these are pure
     data payloads (no TypeScript, no bundling) — Astro otherwise warns. -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
{personSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />}
{articleSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
{breadcrumbSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

<script is:inline>
  function init() {
    preloadTheme();
    onScroll();
    updateThemeIcon();

    const backToTop = document.getElementById("back-to-top");
    backToTop?.addEventListener("click", (event) => scrollToTop(event));

    const backToPrev = document.getElementById("back-to-prev");
    backToPrev?.addEventListener("click", () => window.history.back());

    const themeCycleButton = document.getElementById("theme-cycle");
    themeCycleButton?.addEventListener("click", () => {
      const current = localStorage.getItem("theme") || "system";
      const next =
        current === "system" ? "light" : current === "light" ? "dark" : "system";
      localStorage.setItem("theme", next);
      const dark =
        next === "dark" ||
        (next === "system" &&
          window.matchMedia("(prefers-color-scheme: dark)").matches);
      toggleTheme(dark);
      updateThemeIcon();
    });

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", (event) => {
        if (localStorage.theme === "system") {
          toggleTheme(event.matches);
        }
      });

    document.addEventListener("scroll", onScroll);

    initNavMenu();
  }

  // Mobile section menu (a native <details> in the header). Native handles
  // open/close on the ☰ summary; here we add the conventional dismissals:
  // close when a link is chosen, on Escape, and on a tap outside the menu.
  function initNavMenu() {
    const navMenu = document.getElementById("nav-menu");
    if (!navMenu) return;

    for (const link of navMenu.querySelectorAll(".nav-panel a")) {
      link.addEventListener("click", () => navMenu.removeAttribute("open"));
    }

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") navMenu.removeAttribute("open");
    });

    document.addEventListener("pointerdown", (event) => {
      if (navMenu.hasAttribute("open") && !navMenu.contains(event.target)) {
        navMenu.removeAttribute("open");
      }
    });
  }

  // The icon tracks the user-selected mode (system/light/dark), not the
  // resolved color scheme — so "auto" stays recognizable even when the OS
  // is currently dark. aria-label announces what clicking next will do;
  // the native title tooltip shows the current mode for sighted users
  // hovering the glyph (the half-circle "auto" icon isn't self-evident).
  function updateThemeIcon() {
    const theme = localStorage.getItem("theme") || "system";
    const button = document.getElementById("theme-cycle");
    if (!button) return;
    const currentLabel = theme === "system" ? "Auto" : theme === "light" ? "Light" : "Dark";
    const next = theme === "system" ? "light" : theme === "light" ? "dark" : "auto";
    button.setAttribute("aria-label", `Switch theme to ${next}`);
    button.setAttribute("title", `Theme: ${currentLabel}`);
    for (const icon of button.querySelectorAll("[data-icon]")) {
      icon.classList.toggle("hidden", icon.dataset.icon !== theme);
    }
  }

  function onScroll() {
    const root = document.documentElement;
    const y = window.scrollY;
    if (y > 0) {
      root.classList.add("scrolled");
    } else {
      root.classList.remove("scrolled");
    }
    // `scrolled-deep` keys visibility for chrome that's only useful once
    // the reader is genuinely far into the page — currently `back-to-top`.
    // Threshold is ~80% of the viewport height, so on a typical phone or
    // laptop the button surfaces after the reader has clearly committed to
    // scrolling, not on the first flick.
    if (y > window.innerHeight * 0.8) {
      root.classList.add("scrolled-deep");
    } else {
      root.classList.remove("scrolled-deep");
    }
  }

  function scrollToTop(event) {
    event.preventDefault();
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
  }

  function applyTheme(dark) {
    if (dark) {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }
  }

  // User-initiated or system-preference change. Delegate the crossfade
  // to the browser's View Transitions API so the animation happens at
  // the compositor level in a single snapshot-to-snapshot fade, which
  // sidesteps all the per-element `transition-colors` / `transition-all`
  // utilities on the page trying to animate the same inherited `color`
  // at different cascade depths (which produces visible flicker).
  //
  // The `theme-transition` class on <html> does two jobs while the
  // transition is in flight (see global.css): suppresses CSS transitions
  // so the new snapshot captures the true final colors (preventing the
  // post-transition pop on links and the footer), and lengthens the
  // pseudo-element crossfade for a more graceful feel.
  //
  // Fallback: instant apply on unsupported browsers or when the user
  // prefers reduced motion.
  function toggleTheme(dark) {
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (document.startViewTransition && !reduceMotion) {
      document.documentElement.classList.add("theme-transition");
      const transition = document.startViewTransition(() => applyTheme(dark));
      transition.finished.finally(() => {
        document.documentElement.classList.remove("theme-transition");
      });
    } else {
      applyTheme(dark);
    }
  }

  // Pre-paint: apply the theme instantly to avoid a flash from the SSR
  // default. Inject a transient rule that kills all transitions, flip the
  // class, force a reflow, then remove the rule.
  function preloadTheme() {
    const css = document.createElement("style");
    css.appendChild(
      document.createTextNode(
        `*,*::before,*::after{transition:none !important}`,
      ),
    );
    document.head.appendChild(css);

    const userTheme = localStorage.theme;
    if (userTheme === "light" || userTheme === "dark") {
      applyTheme(userTheme === "dark");
    } else {
      applyTheme(window.matchMedia("(prefers-color-scheme: dark)").matches);
    }

    window.getComputedStyle(css).opacity;
    document.head.removeChild(css);
  }

  document.addEventListener("DOMContentLoaded", () => init());
  preloadTheme();
</script>

<script is:inline define:vars={{ email: SITE.EMAIL }}>
  if (!window.__eeLoggedHoodPeek) {
    window.__eeLoggedHoodPeek = true;
    const logo = [
      " ____    _____   ____        ____    _____  __     __",
      "|___ \\  |_   _| / ___|      |  _ \\  | ____| \\ \\   / /",
      "  __) |   | |   \\___ \\      | | | | |  _|    \\ \\ / / ",
      " / __/    | |    ___) |  _  | |_| | | |___    \\ V /  ",
      "|_____|   |_|   |____/  (_) |____/  |_____|    \\_/   ",
    ].join("\n");
    const fire = () => {
      console.log(logo);
      console.log(
        "looking under the hood? I can tell you all about it. Email me here: " + email
      );
    };
    const schedule = window.requestIdleCallback || ((cb) => setTimeout(cb, 300));
    if (document.readyState === "complete") {
      schedule(fire);
    } else {
      window.addEventListener("load", () => schedule(fire), { once: true });
    }
  }
</script>
