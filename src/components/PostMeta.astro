---
/**
 * Dateline for a blog post: published date, reading time, last-updated.
 *
 * The full edit trail is rendered inline at the bottom of the post via
 * `<RevisionHistory />`, so the header stays a compact "when + how long" glance.
 */
import type { CollectionEntry } from "astro:content";
import { readingTime } from "@lib/utils";

type Props = {
  post: CollectionEntry<"blog">;
};

const { post } = Astro.props;

// UTC pinning prevents dates from shifting by one when the build machine runs
// in a non-UTC timezone — frontmatter dates like `2026-03-23` parse as UTC
// midnight, which becomes Mar 22 in Pacific time without it.
const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
  timeZone: "UTC",
});

const publishedFormatted = dateFormatter.format(post.data.date);
const updatedFormatted = post.data.updated ? dateFormatter.format(post.data.updated) : null;

const readingTimeFormatted = readingTime(post.body ?? "");
---

<div class="flex flex-wrap items-center gap-x-3 gap-y-2 font-sans text-xs text-black/55 dark:text-white/55">
  <span>Published {publishedFormatted}</span>

  {post.body && (
    <>
      <span aria-hidden="true" class="text-black/30 dark:text-white/30">&middot;</span>
      <span>{readingTimeFormatted}</span>
    </>
  )}

  {updatedFormatted && (
    <>
      <span aria-hidden="true" class="text-black/30 dark:text-white/30">&middot;</span>
      <span>Updated {updatedFormatted}</span>
    </>
  )}
</div>
