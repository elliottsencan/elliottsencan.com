---
// Quiet mono meta segment used inside PageHero — quantifies the surface in
// one line. The old accent-bordered chip with its saturation-ramped dot row
// is gone (the redesign folds counts into plain text segments); `count` is
// kept in the API for callers but no longer paints dots.

type Props = {
  count?: number;
  label: string;
};

const { label } = Astro.props;
---

<p class="font-mono text-xs text-black/55 dark:text-white/55">
  <span class="whitespace-nowrap tracking-wider">{label}</span>
</p>
