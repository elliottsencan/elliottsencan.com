---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import SignatureLogo from "./SignatureLogo.astro";
---

<header transition:persist>
  <Container>
    {/* Header layout: signature anchored left, nav stays on the same row at
        every breakpoint and scrolls horizontally if its content overflows.
        The right-edge mask fades the trailing nav item so the row signals
        scroll affordance without showing a scrollbar (which would clash
        with the editorial chrome). The previous layout used flex-wrap, so
        on narrow phones the nav broke into a second row of two-three
        items each — looked accidental rather than intentional. */}
    <div class="flex items-center justify-between gap-3">
      <Link href="/" underline={false} class="shrink-0">
        <SignatureLogo />
      </Link>
      <nav
        class="header-nav flex min-w-0 flex-1 items-center justify-end gap-x-3.5 overflow-x-auto whitespace-nowrap text-sm sm:gap-x-5"
      >
        <Link href="/now">now</Link>
        <Link href="/reading">reading</Link>
        <Link href="/wiki">wiki</Link>
        <Link href="/labs">labs</Link>
        <Link href="/about">about</Link>
        <a
          href="/search"
          aria-label="Search"
          class="inline-flex items-center text-black/75 transition-colors duration-300 ease-in-out hover:text-black focus-visible:text-black dark:text-white/75 dark:hover:text-white dark:focus-visible:text-white"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5"
          >
            <circle cx="10.5" cy="10.5" r="6.5" />
            <line x1="15.5" y1="15.5" x2="21" y2="21" />
          </svg>
        </a>
        <button
          id="theme-cycle"
          aria-label="Switch theme"
          title="Theme: Auto"
          class="inline-flex cursor-pointer items-center text-black/75 transition-colors duration-300 ease-in-out hover:text-black focus-visible:text-black dark:text-white/75 dark:hover:text-white dark:focus-visible:text-white"
        >
          <!-- Auto (system): circle outline with right half filled. The user-
               selected mode — shown regardless of what the OS resolves to. -->
          <svg
            data-icon="system"
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            class="size-5"
          >
            <circle cx="12" cy="12" r="9" />
            <path d="M12 3 a9 9 0 0 1 0 18 z" fill="currentColor" stroke="none" />
          </svg>
          <!-- Light: sun. -->
          <svg
            data-icon="light"
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="hidden size-5"
          >
            <circle cx="12" cy="12" r="4" />
            <line x1="12" y1="2.5" x2="12" y2="4.5" />
            <line x1="12" y1="19.5" x2="12" y2="21.5" />
            <line x1="2.5" y1="12" x2="4.5" y2="12" />
            <line x1="19.5" y1="12" x2="21.5" y2="12" />
            <line x1="5.3" y1="5.3" x2="6.7" y2="6.7" />
            <line x1="17.3" y1="17.3" x2="18.7" y2="18.7" />
            <line x1="5.3" y1="18.7" x2="6.7" y2="17.3" />
            <line x1="17.3" y1="6.7" x2="18.7" y2="5.3" />
          </svg>
          <!-- Dark: crescent moon. -->
          <svg
            data-icon="dark"
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="hidden size-5"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
          </svg>
        </button>
      </nav>
    </div>
  </Container>
</header>

<style>
  /* Hide the horizontal-scroll scrollbar — the right-edge fade carries the
     scroll affordance instead. Touch swipe still works on mobile, and
     keyboard users still get arrow-key scrolling on the focused nav. */
  .header-nav {
    scrollbar-width: none;
    -ms-overflow-style: none;
    /* Soft fade on the trailing edge so the last visible item dissolves
       rather than ending in a hard cut. mask is content-only; clipping
       happens via overflow-x: auto on the same element. */
    mask-image: linear-gradient(
      to right,
      black 0,
      black calc(100% - 1.5rem),
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      black 0,
      black calc(100% - 1.5rem),
      transparent 100%
    );
  }
  .header-nav::-webkit-scrollbar {
    display: none;
  }
</style>
