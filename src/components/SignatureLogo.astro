<style>
  .signature-logo {
    display: block;
    height: clamp(2rem, 1.5rem + 1.5vw, 2.75rem);
    width: auto;
    /* tightened viewBox is 3660 × 833 (~4.4:1) — height drives layout */
    /* Explicit color so fill is fully opaque during the draw; the 75% rest
       state comes from our own opacity, not from the Link's text-foo/75
       alpha. This matches the other nav items visually while letting us
       pop to full opacity during the draw animation. */
    color: #000;
    opacity: 0.9;
    transition: opacity 250ms ease-out;
    animation: sig-fade 2.3s linear 150ms;
  }

  :global(html.dark) .signature-logo {
    color: #fff;
  }

  /* Hold opacity at 1 through the draw, then settle to rest. With the 2.3s
     duration and 150ms delay, the 89% split puts the fade start at ~2.2s,
     just after stroke-2 ends at 2.0s — the fade begins right as the pen
     lifts on "Sencan". */
  @keyframes sig-fade {
    0%,
    89% {
      opacity: 1;
    }
    100% {
      opacity: 0.9;
    }
  }

  /* Hover: restore full opacity, matching the emphasis behavior of the
     other nav items. Works after the draw animation completes because the
     animation has no forwards fill — opacity reverts to this rule's base. */
  :global(a:hover) .signature-logo,
  :global(a:focus-visible) .signature-logo {
    opacity: 1;
  }

  /* Two-stroke reveal: "Elliott" draws, brief pen-lift, then "Sencan".
     Linear timing reads as natural pen speed; eased curves front-load the
     motion and feel rushed even at longer durations. */
  .sig-stroke {
    animation-fill-mode: forwards;
    animation-timing-function: linear;
  }

  .sig-stroke-1 {
    animation-name: sig-reveal;
    animation-duration: 850ms;
    animation-delay: 150ms;
  }

  .sig-stroke-2 {
    animation-name: sig-reveal;
    animation-duration: 850ms;
    animation-delay: 1150ms; /* stroke-1 end (150ms + 850ms = 1000ms) + 150ms pen-lift */
  }

  @keyframes sig-reveal {
    from {
      stroke-dashoffset: 1;
    }
    to {
      stroke-dashoffset: 0;
    }
  }

  /* Once-per-session skip rule lives in global.css (html.intro-played .sig-stroke)
     so it can target across the scoped style boundary without :global() quirks. */

  @media (prefers-reduced-motion: reduce) {
    .sig-stroke {
      animation: none;
      stroke-dashoffset: 0;
    }
  }
</style>