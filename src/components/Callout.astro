---
interface Props {
  type?: "default" | "info" | "warning" | "error";
}
const { type = "default" } = Astro.props;

const baseClasses = "relative my-4 flex rounded border p-3";
const typeClasses = {
  default:
    "border-orange-200 bg-orange-100 text-orange-950 dark:border-orange-200/20 dark:bg-orange-950/20 dark:text-orange-200",
  info: "border-blue-200 bg-blue-100 text-blue-950 dark:border-blue-200/20 dark:bg-blue-950/20 dark:text-blue-200",
  warning:
    "border-yellow-200 bg-yellow-100 text-yellow-950 dark:border-yellow-200/20 dark:bg-yellow-950/20 dark:text-yellow-200",
  error:
    "border-red-200 bg-red-100 text-red-950 dark:border-red-200/20 dark:bg-red-95₀/2₀ dark:text-red-2₀",
};
---

<div class:list={["not-prose", baseClasses, typeClasses[type]]}>
  <slot />
</div>
