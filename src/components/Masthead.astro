---
import { SITE } from "@consts";
import LabeledRule from "@components/LabeledRule.astro";

// Build-time stamp — regenerates on every deploy, signalling the site is alive.
const buildDate = new Date();
const editionDate = new Intl.DateTimeFormat("en-US", {
  day: "2-digit",
  month: "short",
  year: "numeric",
})
  .format(buildDate)
  .toUpperCase();

const location = SITE.LOCATION.toUpperCase();
---

<!--
  The site nav (Header.astro) already renders the site title. Repeating it here
  as a big visible h1 creates a redundancy that reads as template scaffolding.
  Instead: keep an sr-only h1 for semantics, and show the editorial dateline —
  location + build date — as the left label of a label-on-rule row. The
  dot-grid rule flows from the dateline to the right edge of the column,
  anchoring the top of the page.

  The sr-only h1 lives outside LabeledRule so LabeledRule's h1 slot is free
  to carry the visible dateline text (as a <p>) without conflicting on the
  page's heading semantics.
-->
<div>
  <h1 class="sr-only">{SITE.TITLE}</h1>
  <LabeledRule as="p">
    Currently in {location} &middot; {editionDate}
  </LabeledRule>
</div>
