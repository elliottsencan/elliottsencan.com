---
import { formatLongDate } from "@lib/format";

// One canonical "how / when was this made" chip. Used everywhere a
// compiled / summarized / last-run / updated timestamp appears so provenance
// reads identically across the site (homepage trail, /wiki, /reading, /labs,
// /now, posts). Shape mirrors the PostBadges chip family.
//
//   ✱ {action} · {long date}            (· How this works → when link=true)
//
// The ✱ machine-mark (terracotta accent) flags machine authorship — omit it
// for human-authored items via machine={false}. The date is always a long
// human date ("3 May 2026"), never ISO.
//
// whitespace-nowrap keeps each segment intact while flex-wrap + max-w-full
// let the chip break *between* segments — the link variant is wider than a
// 390px phone viewport and would otherwise force page-level overflow. Each
// "·" is grouped with the segment it introduces so a wrap never strands a
// separator at the end of a line.

type Props = {
  action: "Compiled by Claude" | "Summarized by Claude" | "Last run" | "Updated";
  date: Date;
  machine?: boolean;
  link?: boolean;
};

const { action, date, machine = true, link = false } = Astro.props;
---

<span
  class="inline-flex w-fit max-w-full flex-wrap items-center gap-x-1.5 gap-y-0.5 whitespace-nowrap rounded-sm bg-black/5 px-2.5 py-1 font-mono text-xs text-black/55 dark:bg-white/5 dark:text-white/55"
>
  {
    machine && (
      <span aria-hidden="true" class="text-[color:var(--accent)]">
        &#x2731;
      </span>
    )
  }
  <span>{action}</span>
  <span class="inline-flex items-center gap-x-1.5 whitespace-nowrap">
    <span aria-hidden="true">&middot;</span>
    <time
      datetime={date.toISOString()}
      class="tabular-nums text-black/75 dark:text-white/75"
      style="font-variant-numeric: tabular-nums;"
    >
      {formatLongDate(date)}
    </time>
  </span>
  {
    link && (
      <span class="inline-flex items-center gap-x-1.5 whitespace-nowrap">
        <span aria-hidden="true">&middot;</span>
        <a
          href="/wiki/how-this-works"
          class="text-[color:var(--accent)] no-underline transition-colors duration-300 ease-in-out hover:underline focus-visible:underline"
        >
          How this works &rarr;
        </a>
      </span>
    )
  }
</span>
