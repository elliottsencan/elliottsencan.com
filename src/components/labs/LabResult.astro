---
/**
 * Result dispatcher — picks the viz primitive based on the cell's `kind`
 * and the shape of the loaded JSON measurements. Two notable upgrades
 * over the original sparkline-only chart path:
 *
 *   1. The `chart` kind now prefers the richer `by_day` array (one
 *      entry per Pacific date) over the flat `values` array. When the
 *      sidecar carries `by_day`, the dispatcher pairs a DailyBars
 *      (with spike highlighting) with a CumulativeArea (cumulative vs
 *      budget) so the headline reads "total + shape," not just shape.
 *      Falls back to Sparkline when `by_day` isn't there.
 *
 *   2. The "awaiting data" state now opts into a PendingMethodology
 *      card when the cell's frontmatter includes a `methodology` block
 *      (steps + receipts + optional code stub). Cells without that
 *      block still get the quiet dashed baseline.
 */
import Barchart from "./Barchart.astro";
import CalendarHeatmap from "./CalendarHeatmap.astro";
import ComparisonBars from "./ComparisonBars.astro";
import CumulativeArea from "./CumulativeArea.astro";
import DailyBars from "./DailyBars.astro";
import LabTable from "./LabTable.astro";
import PendingMethodology from "./PendingMethodology.astro";
import ResultCell from "./ResultCell.astro";
import Scatter from "./Scatter.astro";
import Sparkline from "./Sparkline.astro";
import StatGrid from "./StatGrid.astro";
import WikiSweep from "./WikiSweep.astro";

type Props = {
  kind?: "chart" | "table" | "barchart" | "stat" | "calendar" | "scatter" | "comparison" | "sweep";
  data: unknown;
  /** Visualization detail level — controls heights for charts/scatters. */
  size?: "compact" | "full";
  /** Optional fallback methodology when the sidecar is a `no-data` stub. */
  methodology?: {
    steps?: string[];
    receipts?: { label: string; value: string }[];
    code?: string;
  };
};

const { kind, data, size = "full", methodology } = Astro.props;

const isObject = (v: unknown): v is Record<string, unknown> =>
  typeof v === "object" && v !== null && !Array.isArray(v);

// Pre-data state — the worker writes `{ status: "no-data", message }` at
// `dataPath` until first run. Treat that (and a missing file) as the
// pending state.
const noDataMessage =
  data === null
    ? "Data file not found."
    : isObject(data) && data.status === "no-data" && typeof data.message === "string"
      ? data.message
      : null;
const isNoData = data === null || noDataMessage !== null;

// Optional summary block lifted from aggregator output.
type SummaryStats = { stats: { label: string; value: string }[] };
function isSummary(v: unknown): v is SummaryStats {
  return isObject(v) && Array.isArray((v as { stats?: unknown }).stats);
}

// ── chart kind ──
// Prefer `by_day` (cost-style daily series with counts) when present.
type Day = { date: string; cost_usd: number; count: number };
function isDay(v: unknown): v is Day {
  return (
    isObject(v) &&
    typeof v.date === "string" &&
    typeof v.cost_usd === "number" &&
    typeof v.count === "number"
  );
}

const chartData =
  kind === "chart" && isObject(data) && Array.isArray(data.values)
    ? {
        values: data.values as number[],
        annotation: isObject(data.annotation)
          ? (data.annotation as { at: number; label: string })
          : undefined,
        summary: isSummary(data.summary) ? data.summary : null,
        byDay:
          Array.isArray((data as { by_day?: unknown }).by_day) &&
          ((data as { by_day: unknown[] }).by_day as unknown[]).every(isDay)
            ? (data as { by_day: Day[] }).by_day
            : null,
        budget:
          typeof (data as { budget?: unknown }).budget === "number"
            ? (data as { budget: number }).budget
            : null,
      }
    : null;

const tableData =
  kind === "table" && isObject(data) && Array.isArray(data.headers) && Array.isArray(data.rows)
    ? {
        headers: data.headers as string[],
        rows: data.rows as string[][],
      }
    : null;

const barData =
  kind === "barchart" && isObject(data) && Array.isArray(data.bars)
    ? { bars: data.bars as { route: string; ms: number }[] }
    : null;

const statData =
  kind === "stat" && isObject(data) && Array.isArray(data.stats)
    ? { stats: data.stats as { label: string; value: string }[] }
    : null;

const calendarData =
  kind === "calendar" && isObject(data) && Array.isArray(data.months)
    ? {
        months: data.months as number[],
        startLabel: typeof data.startLabel === "string" ? data.startLabel : undefined,
        endLabel: typeof data.endLabel === "string" ? data.endLabel : undefined,
      }
    : null;

const scatterData =
  kind === "scatter" && isObject(data) && Array.isArray(data.points)
    ? {
        points: data.points as { x: number; y: number }[],
        xLabel: typeof data.xLabel === "string" ? data.xLabel : undefined,
        yLabel: typeof data.yLabel === "string" ? data.yLabel : undefined,
      }
    : null;

// ── comparison kind (unchanged shape; renderer is what changed) ──
type ComparisonMetric = {
  label: string;
  with_priors: number;
  without_priors: number | null;
  format: "percent" | "int" | "decimal";
  better?: "higher" | "lower";
  caption?: string;
  single?: boolean;
};
type ComparisonSample = {
  label: string;
  with_priors: number;
  without_priors: number;
};
type ComparisonLegend = { left: string; right: string };

function isMetric(v: unknown): v is ComparisonMetric {
  if (!isObject(v)) {
    return false;
  }
  const fmt = (v as { format?: unknown }).format;
  return (
    typeof (v as { label?: unknown }).label === "string" &&
    typeof (v as { with_priors?: unknown }).with_priors === "number" &&
    (typeof (v as { without_priors?: unknown }).without_priors === "number" ||
      (v as { without_priors?: unknown }).without_priors === null ||
      (v as { without_priors?: unknown }).without_priors === undefined) &&
    (fmt === "percent" || fmt === "int" || fmt === "decimal")
  );
}
function isSample(v: unknown): v is ComparisonSample {
  return (
    isObject(v) &&
    typeof (v as { label?: unknown }).label === "string" &&
    typeof (v as { with_priors?: unknown }).with_priors === "number" &&
    typeof (v as { without_priors?: unknown }).without_priors === "number"
  );
}

const comparisonRaw =
  kind === "comparison" && isObject(data) && isObject(data.comparison)
    ? (data.comparison as Record<string, unknown>)
    : null;
const comparisonData = comparisonRaw
  ? {
      metrics: Array.isArray(comparisonRaw.metrics)
        ? (comparisonRaw.metrics as unknown[]).filter(isMetric)
        : [],
      samples: Array.isArray(comparisonRaw.samples)
        ? (comparisonRaw.samples as unknown[]).filter(isSample)
        : [],
      legend:
        isObject(comparisonRaw.legend) &&
        typeof (comparisonRaw.legend as { left?: unknown }).left === "string" &&
        typeof (comparisonRaw.legend as { right?: unknown }).right === "string"
          ? (comparisonRaw.legend as ComparisonLegend)
          : undefined,
      stripLabel:
        typeof comparisonRaw.stripLabel === "string" ? comparisonRaw.stripLabel : undefined,
    }
  : null;

const hasComparison =
  comparisonData !== null &&
  (comparisonData.metrics.length > 0 || comparisonData.samples.length > 0);

// ── sweep kind (wiki-surface relevance lab) ──
// Threshold sweep + per-prompt rows. Validated here so WikiSweep can stay
// a pure presenter; element-level checks mirror isMetric/isSample/isDay.
type SweepPoint = {
  threshold: number;
  precision_at_1: number;
  recall_at_3: number;
  false_positive_rate: number;
};
type PromptRow = {
  prompt: string;
  relevant: string[];
  off_topic: boolean;
  results: { slug: string; score: number }[];
};
function isSweepPoint(v: unknown): v is SweepPoint {
  return (
    isObject(v) &&
    typeof v.threshold === "number" &&
    typeof v.precision_at_1 === "number" &&
    typeof v.recall_at_3 === "number" &&
    typeof v.false_positive_rate === "number"
  );
}
function isPromptRow(v: unknown): v is PromptRow {
  return (
    isObject(v) &&
    typeof v.prompt === "string" &&
    Array.isArray(v.relevant) &&
    typeof v.off_topic === "boolean" &&
    Array.isArray(v.results)
  );
}

const sweepData =
  kind === "sweep" &&
  isObject(data) &&
  Array.isArray(data.sweep) &&
  data.sweep.every(isSweepPoint) &&
  Array.isArray(data.per_prompt) &&
  data.per_prompt.every(isPromptRow) &&
  typeof data.recommended_threshold === "number"
    ? {
        sweep: data.sweep as SweepPoint[],
        perPrompt: data.per_prompt as PromptRow[],
        recommendedThreshold: data.recommended_threshold as number,
        nOnTopic: typeof data.n_on_topic === "number" ? (data.n_on_topic as number) : 0,
        nOffTopic: typeof data.n_off_topic === "number" ? (data.n_off_topic as number) : 0,
      }
    : null;

const matched =
  chartData ??
  tableData ??
  barData ??
  statData ??
  calendarData ??
  scatterData ??
  sweepData ??
  (hasComparison ? comparisonData : null);

const sparkHeight = size === "compact" ? 60 : 120;
const scatterHeight = size === "compact" ? 100 : 180;
const dailyHeight = size === "compact" ? 130 : 200;
const cumHeight = size === "compact" ? 130 : 200;
---

<ResultCell>
  <slot name="header" slot="header" />

  {/* ── Pending state ── */}
  {isNoData && methodology && (
    <PendingMethodology
      message={noDataMessage ?? "Awaiting first run."}
      steps={methodology.steps}
      receipts={methodology.receipts}
      code={methodology.code}
    />
  )}
  {isNoData && !methodology && (
    <div class="space-y-3 text-black/55 dark:text-white/55">
      <Sparkline data={[]} height={sparkHeight} />
      <p class="text-center font-mono text-xs tracking-wide">
        {noDataMessage ?? "Awaiting first run."}
      </p>
    </div>
  )}

  {/* ── Chart: prefer the byDay-paired layout when we have it ── */}
  {!isNoData && chartData && chartData.byDay && chartData.byDay.length > 0 && (
    <div class="flex flex-col gap-8">
      {chartData.summary && size === "full" && (
        <StatGrid stats={chartData.summary.stats} />
      )}
      <div class="grid grid-cols-1 gap-6 md:grid-cols-[minmax(0,1.5fr)_minmax(0,1fr)] md:gap-10">
        <div class="flex flex-col gap-2">
          <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
            Cumulative · vs budget
          </span>
          <CumulativeArea
            data={chartData.byDay.map((d) => ({
              date: d.date,
              cost_usd: d.cost_usd,
            }))}
            height={cumHeight}
            budget={chartData.budget ?? undefined}
            budgetLabel={
              chartData.budget !== null
                ? `budget · $${chartData.budget.toFixed(2)}/mo`
                : undefined
            }
          />
        </div>
        <div class="flex flex-col gap-2">
          <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
            Daily · spikes marked
          </span>
          <DailyBars data={chartData.byDay} height={dailyHeight} />
        </div>
      </div>
    </div>
  )}
  {!isNoData && chartData && (!chartData.byDay || chartData.byDay.length === 0) && (
    <div class="space-y-4">
      {chartData.summary && size === "full" && (
        <StatGrid stats={chartData.summary.stats} />
      )}
      <Sparkline
        data={chartData.values}
        annotation={chartData.annotation}
        height={sparkHeight}
      />
    </div>
  )}

  {tableData && <LabTable headers={tableData.headers} rows={tableData.rows} />}
  {barData && <Barchart bars={barData.bars} />}
  {statData && <StatGrid stats={statData.stats} />}
  {
    calendarData && (
      <CalendarHeatmap
        months={calendarData.months}
        startLabel={calendarData.startLabel}
        endLabel={calendarData.endLabel}
      />
    )
  }
  {
    scatterData && (
      <Scatter
        points={scatterData.points}
        xLabel={scatterData.xLabel}
        yLabel={scatterData.yLabel}
        height={scatterHeight}
      />
    )
  }
  {
    hasComparison && comparisonData && (
      <ComparisonBars
        metrics={comparisonData.metrics}
        samples={comparisonData.samples}
        legend={comparisonData.legend}
        stripLabel={comparisonData.stripLabel}
      />
    )
  }
  {
    sweepData && (
      <WikiSweep
        sweep={sweepData.sweep}
        perPrompt={sweepData.perPrompt}
        recommendedThreshold={sweepData.recommendedThreshold}
        nOnTopic={sweepData.nOnTopic}
        nOffTopic={sweepData.nOffTopic}
      />
    )
  }
  {
    !isNoData && !matched && (
      <pre class="m-0 overflow-x-auto font-mono text-xs leading-relaxed text-black/85 dark:text-white/85">
        {JSON.stringify(data, null, 2)}
      </pre>
    )
  }
</ResultCell>
