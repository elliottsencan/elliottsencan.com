---
/**
 * Citation-faithfulness cell — the visualization behind the Tier 1 eval.
 * Pure presenter (all aggregation happens here at build time); shares the
 * editorial vocabulary of the other lab primitives: SVG/CSS only,
 * `var(--accent)`, mono uppercase labels, tabular-nums, no animation, no
 * texture. Four stacked regions:
 *
 *   1. Stat row — claims judged, supported share, disagreements, and the
 *      Haiku-vs-Sonnet cost split (the cheap-vs-pricey bet the hypothesis
 *      rides on). Complements the page header, which already leads with the
 *      headline judge-agreement number.
 *   2. Verdict distribution — one stacked bar over every judged claim from
 *      both judges: supported / partial / unsupported. Answers "does the
 *      source back the claim."
 *   3. Judge agreement — over the claims both judges scored, the disagree
 *      cases are listed with each judge's verdict side by side. Answers
 *      "does cheap Haiku agree with pricier Sonnet."
 *   4. Per-article strip — one row per wiki article: each judge's claim
 *      count + accuracy, the agreement tally, and a partial-judge flag when
 *      a judge run didn't finish. Sorted disagreements-first so the
 *      interesting articles read at the top.
 */
import type { CitationFaithfulnessSidecar, JudgeModel } from "@lib/schemas/content";

type Props = { data: CitationFaithfulnessSidecar };
const { data } = Astro.props;

const HAIKU: JudgeModel = "claude-haiku-4-5";
const SONNET: JudgeModel = "claude-sonnet-4-6";
const SHORT: Record<string, string> = {
  "claude-haiku-4-5": "Haiku",
  "claude-sonnet-4-6": "Sonnet",
};

// ── Strip markdown from claim text so the strip reads as prose, not source.
// Claims arrive with `[label](/reading/...)`, `**bold**`, `_em_`, `` `code` ``.
function plainClaim(s: string): string {
  return s
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1") // links → label
    .replace(/\*\*([^*]+)\*\*/g, "$1")
    .replace(/`([^`]+)`/g, "$1")
    .replace(/(^|[^a-zA-Z0-9])_([^_]+)_/g, "$1$2")
    .trim();
}

// ── Aggregates ──
let comparable = 0;
let agree = 0;
let disagree = 0;
let supported = 0;
let partial = 0;
let unsupported = 0;
let judged = 0;

type VerdictPair = {
  claim: string;
  source: string;
  haiku: { verdict: string; justification: string };
  sonnet: { verdict: string; justification: string };
};

type ArticleRow = {
  slug: string;
  perJudge: Record<string, { count: number; accuracy: number; partial: boolean } | null>;
  comparable: number;
  agree: number;
  disagree: number;
  disagreements: VerdictPair[];
};

const rows: ArticleRow[] = [];
const allDisagreements: VerdictPair[] = [];

for (const article of data.articles) {
  const ja = article.judge_agreement;
  if (ja) {
    comparable += ja.total_claims;
    agree += ja.agree;
    disagree += ja.disagree;
  }

  const byModel: Record<string, (typeof article.judges)[number] | undefined> = {};
  for (const judge of article.judges) {
    byModel[judge.judge_model] = judge;
    for (const claim of judge.claims) {
      judged += 1;
      if (claim.verdict === "supported") {
        supported += 1;
      } else if (claim.verdict === "partial") {
        partial += 1;
      } else {
        unsupported += 1;
      }
    }
  }

  // Pair claims the two judges share (key = claim text + cited source) to
  // surface the specific disagreements behind the agreement count.
  const h = byModel[HAIKU];
  const s = byModel[SONNET];
  const disagreements: VerdictPair[] = [];
  if (h && s) {
    const sMap = new Map(s.claims.map((c) => [`${c.claim_text}::${c.cited_source_slug}`, c]));
    for (const hc of h.claims) {
      const sc = sMap.get(`${hc.claim_text}::${hc.cited_source_slug}`);
      if (sc && sc.verdict !== hc.verdict) {
        const pair: VerdictPair = {
          claim: plainClaim(hc.claim_text),
          source: hc.cited_source_slug,
          haiku: { verdict: hc.verdict, justification: hc.justification },
          sonnet: { verdict: sc.verdict, justification: sc.justification },
        };
        disagreements.push(pair);
        allDisagreements.push(pair);
      }
    }
  }

  const judgeCell = (m: JudgeModel) => {
    const j = byModel[m];
    if (!j) {
      return null;
    }
    return {
      count: j.claims.length,
      accuracy: j.summary.accuracy_pct,
      partial: j.partial === true,
    };
  };

  rows.push({
    slug: article.wiki_slug,
    perJudge: { [HAIKU]: judgeCell(HAIKU), [SONNET]: judgeCell(SONNET) },
    comparable: ja?.total_claims ?? 0,
    agree: ja?.agree ?? 0,
    disagree: ja?.disagree ?? 0,
    disagreements,
  });
}

// Disagreements first, then by comparable-claim volume, then the rest.
rows.sort(
  (a, b) => b.disagree - a.disagree || b.comparable - a.comparable || a.slug.localeCompare(b.slug),
);

const agreePct = comparable > 0 ? Math.round((agree / comparable) * 100) : 0;
const supportedPct = judged > 0 ? Math.round((supported / judged) * 100) : 0;

const haikuCost = data.totals.total_cost_usd_by_judge[HAIKU] ?? 0;
const sonnetCost = data.totals.total_cost_usd_by_judge[SONNET] ?? 0;

const fmtCost = (v: number) => `$${v.toFixed(2)}`;
const pct = (n: number, d: number) => (d > 0 ? (n / d) * 100 : 0);

// Verdict bar segments. Supported = accent; partial = muted; unsupported =
// strongest-contrast neutral (reads as the heavy tail without a new palette
// token). Widths share the judged-claim denominator.
const segments = [
  { key: "supported", label: "supported", count: supported, cls: "bg-[color:var(--accent)]" },
  { key: "partial", label: "partial", count: partial, cls: "bg-black/35 dark:bg-white/30" },
  {
    key: "unsupported",
    label: "unsupported",
    count: unsupported,
    cls: "bg-black/70 dark:bg-white/65",
  },
];

const stats = [
  { label: "Claims judged", value: String(judged) },
  { label: "Supported", value: `${supportedPct}%` },
  { label: "Disagreements", value: `${disagree} / ${comparable}` },
];

// Chip palette for a single verdict, used in the disagreement list.
function verdictChip(v: string): string {
  if (v === "supported") {
    return "border-[color:var(--accent)]/40 text-[color:var(--accent)]";
  }
  if (v === "partial") {
    return "border-black/20 text-black/60 dark:border-white/25 dark:text-white/60";
  }
  return "border-black/40 text-black/80 dark:border-white/40 dark:text-white/80";
}
---

<div class="flex flex-col gap-8 text-black/85 md:gap-10 dark:text-white/85">
  {/* ── Region 1: stat row ── */}
  <div class="flex flex-col gap-5">
    <div
      class="grid gap-x-4 gap-y-5"
      style="grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));"
    >
      {
        stats.map((s) => (
          <div class="flex flex-col gap-1">
            <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
              {s.label}
            </span>
            <span
              class="font-heading text-3xl font-medium tracking-tight text-black dark:text-white"
              style="font-variant-numeric: tabular-nums;"
            >
              {s.value}
            </span>
          </div>
        ))
      }
      <div class="flex flex-col gap-1">
        <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
          Cost · Haiku / Sonnet
        </span>
        <span
          class="font-heading text-3xl font-medium tracking-tight text-black dark:text-white"
          style="font-variant-numeric: tabular-nums;"
        >
          {fmtCost(haikuCost)}<span class="text-black/35 dark:text-white/35"> / </span>{
            fmtCost(sonnetCost)
          }
        </span>
      </div>
    </div>
  </div>

  {/* ── Region 2: verdict distribution ── */}
  <div class="flex flex-col gap-3 border-t border-black/10 pt-6 dark:border-white/10">
    <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
      <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
        Verdict mix · every judged claim
      </span>
      <div
        class="flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-[0.65rem] uppercase tracking-widest"
      >
        {
          segments.map((seg) => (
            <span class="flex items-center gap-1.5 text-black/65 dark:text-white/65">
              <span class:list={["inline-block h-[2px] w-4", seg.cls]} />
              {seg.label} · {seg.count}
            </span>
          ))
        }
      </div>
    </div>
    <div
      class="flex h-3 w-full overflow-hidden rounded-sm bg-black/[0.04] dark:bg-white/[0.06]"
    >
      {
        segments.map(
          (seg) =>
            seg.count > 0 && (
              <div
                class:list={[seg.cls]}
                style={`width: ${pct(seg.count, judged)}%;`}
                title={`${seg.label}: ${seg.count}`}
              />
            ),
        )
      }
    </div>
    <p class="font-mono text-[0.7rem] text-black/55 dark:text-white/55">
      {supportedPct}% of {judged} claims supported · paraphrase counts, inference past the source doesn't.
    </p>
  </div>

  {/* ── Region 3: judge agreement ── */}
  <div class="flex flex-col gap-4 border-t border-black/10 pt-6 dark:border-white/10">
    <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
      <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
        Judge agreement · Haiku vs Sonnet
      </span>
      <span class="font-mono text-[0.7rem] text-black/55 dark:text-white/55">
        {agree} agree · {disagree} disagree · {comparable} comparable claims ({agreePct}%)
      </span>
    </div>

    {
      allDisagreements.length > 0 ? (
        <div class="flex flex-col gap-2">
          {allDisagreements.map((d) => (
            <div class="flex flex-col gap-2 border-l-2 border-black/10 py-2 pl-4 dark:border-white/15">
              <p class="text-sm leading-snug text-black/80 dark:text-white/80">
                {d.claim}
              </p>
              <div class="flex flex-wrap items-center gap-2">
                {[
                  { who: SHORT[HAIKU], v: d.haiku.verdict },
                  { who: SHORT[SONNET], v: d.sonnet.verdict },
                ].map((j) => (
                  <span
                    class:list={[
                      "inline-flex items-center gap-1.5 rounded-sm border px-2 py-0.5 font-mono text-[0.65rem] uppercase tracking-widest",
                      verdictChip(j.v),
                    ]}
                  >
                    <span class="text-black/45 dark:text-white/45">{j.who}</span>
                    {j.v}
                  </span>
                ))}
                <a
                  href={`/reading/${d.source}/`}
                  class="font-mono text-[0.65rem] text-black/45 underline decoration-black/20 underline-offset-2 hover:text-[color:var(--accent)] dark:text-white/45 dark:decoration-white/20"
                >
                  source ↗
                </a>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="font-mono text-[0.7rem] text-black/55 dark:text-white/55">
          0 disagreements across {comparable} comparable claims — the two judges
          returned the same verdict every time.
        </p>
      )
    }
  </div>

  {/* ── Region 4: per-article strip ── */}
  <div class="flex flex-col gap-3 border-t border-black/10 pt-6 dark:border-white/10">
    <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
      Per-article · {data.articles.length} wiki concepts
    </span>
    <div class="flex flex-col">
      {
        rows.map((r, i) => (
          <div
            class:list={[
              "grid grid-cols-[minmax(0,1fr)_auto] items-baseline gap-x-4 gap-y-1 border-t border-black/[0.06] py-2.5 md:grid-cols-[minmax(0,1.6fr)_minmax(0,1fr)_auto] dark:border-white/[0.08]",
              i === 0 && "border-t-0",
            ]}
          >
            <a
              href={`/wiki/${r.slug}/`}
              class="truncate font-mono text-[0.8rem] text-black/80 hover:text-[color:var(--accent)] dark:text-white/80"
              title={r.slug}
            >
              {r.slug}
            </a>

            <div class="flex flex-wrap items-center gap-x-4 gap-y-0.5 font-mono text-[0.65rem] text-black/55 dark:text-white/55">
              {[HAIKU, SONNET].map((m) => {
                const cell = r.perJudge[m];
                return (
                  <span class="inline-flex items-center gap-1.5">
                    <span class="text-black/40 uppercase tracking-widest dark:text-white/40">
                      {SHORT[m]}
                    </span>
                    {cell ? (
                      <span style="font-variant-numeric: tabular-nums;">
                        {cell.count} · {Math.round(cell.accuracy)}%
                        {cell.partial && (
                          <span class="text-black/40 dark:text-white/40"> · partial</span>
                        )}
                      </span>
                    ) : (
                      <span class="text-black/30 dark:text-white/30">—</span>
                    )}
                  </span>
                );
              })}
            </div>

            <span
              class:list={[
                "justify-self-end font-mono text-[0.65rem] uppercase tracking-widest",
                r.disagree > 0
                  ? "text-[color:var(--accent)]"
                  : "text-black/40 dark:text-white/40",
              ]}
              style="font-variant-numeric: tabular-nums;"
            >
              {r.comparable === 0
                ? "no overlap"
                : r.disagree > 0
                  ? `${r.disagree} split`
                  : `${r.agree} agree`}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</div>
