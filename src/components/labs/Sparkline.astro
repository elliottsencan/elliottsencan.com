---
/**
 * Sparkline — single-series line chart with optional annotation marker.
 *
 * Two variants:
 *   - "area" (default): line + soft area fill + dotted point markers.
 *     Used inside lab cells where the chart is the evidence.
 *   - "line": clean polyline at 0.7 opacity with a single accent dot on
 *     the last point — the instrument-row treatment from the redesign
 *     boards (labs index rows, home trail rows).
 *
 * Sparse-data handling: the chart kind feeds whatever bucket array the
 * aggregator emits (often very few points early on). With 0 points the
 * SVG renders an "awaiting data" hairline; with 1 point a centered dot;
 * with 2+ points a normal line. Dot radius scales inversely with point
 * count so a 4-point series reads as a sequence of stations rather than
 * dust.
 */
type Annotation = { at: number; label: string };
type Props = {
  data: number[];
  annotation?: Annotation;
  height?: number;
  width?: number;
  variant?: "area" | "line";
  /**
   * Motion-layer draw-in: the line traces itself when a [data-observe]
   * ancestor scrolls into view, then the accent end-dot fades in. Charts
   * move because they depict time. Requires variant="line" and an ancestor
   * carrying data-observe; without JS the chart renders fully drawn.
   */
  draw?: boolean;
};

const { data, annotation, height = 80, width = 600, variant = "area", draw = false } = Astro.props;

const n = data.length;
const max = n > 0 ? Math.max(...data) : 0;
const min = n > 0 ? Math.min(...data) : 0;
const range = max - min || 1;
const yFor = (v: number) => height - ((v - min) / range) * (height - 16) - 8;

// 1-point case: pin the lone dot to horizontal center so it reads as a
// "single observation" rather than a stray pixel at the left edge.
const xFor = (i: number) => {
  if (n <= 1) {
    return width / 2;
  }
  return (i * width) / (n - 1);
};

const points = data.map((v, i) => [xFor(i), yFor(v)] as const);
const linePath = points
  .map(([x, y], i) => `${i === 0 ? "M" : "L"} ${x.toFixed(1)} ${y.toFixed(1)}`)
  .join(" ");
// Only draw the area fill when there's actually a span — a 1-point area
// degenerates into a triangular wedge that reads as a glitch.
const areaPath =
  variant === "area" && n >= 2 ? `${linePath} L ${width} ${height} L 0 ${height} Z` : null;
const annotationPoint = annotation ? points[annotation.at] : null;
const lastPoint = points[points.length - 1];

// Dot radius scales inversely with density so sparse series read as
// distinct observations and dense series stay restrained.
const dotR = n === 1 ? 4 : n <= 4 ? 2.6 : n <= 12 ? 2 : 1.6;
---

<svg
  width="100%"
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  preserveAspectRatio="none"
  style="display: block;"
  role="img"
>
  {n === 0 && (
    <line
      x1="0"
      y1={height / 2}
      x2={width}
      y2={height / 2}
      stroke="currentColor"
      stroke-width="0.6"
      stroke-dasharray="4 4"
      opacity="0.25"
    />
  )}
  {areaPath && <path d={areaPath} fill="currentColor" opacity="0.06" />}
  {n >= 2 && (
    <path
      class={draw && variant === "line" ? "spark-path" : undefined}
      pathLength={draw && variant === "line" ? 1 : undefined}
      d={linePath}
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      opacity={variant === "line" ? 0.7 : 1}
    />
  )}
  {
    variant === "area" &&
      points.map(([x, y], i) => (
        <circle
          cx={x}
          cy={y}
          r={dotR}
          fill="currentColor"
          opacity={annotation && i === annotation.at ? 1 : n <= 4 ? 0.9 : 0.4}
        />
      ))
  }
  {variant === "line" && lastPoint && (
    <circle
      class={draw ? "spark-dot" : undefined}
      cx={lastPoint[0]}
      cy={lastPoint[1]}
      r="3"
      fill="var(--accent)"
    />
  )}
  {
    annotation && annotationPoint && (
      <g>
        <line
          x1={annotationPoint[0]}
          y1={annotationPoint[1] - 4}
          x2={annotationPoint[0]}
          y2={8}
          stroke="var(--accent)"
          stroke-width="1"
          stroke-dasharray="2 2"
        />
        <text
          x={annotationPoint[0] + 6}
          y={14}
          font-family="var(--font-mono)"
          font-size="10"
          fill="var(--accent)"
        >
          {annotation.label}
        </text>
      </g>
    )
  }
</svg>
