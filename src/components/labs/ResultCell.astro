---
/**
 * Result cell — paper surface, holds one of the viz primitives or a
 * `<pre>` JSON dump. Wraps the result and shows the cell `kind` label in
 * the upper-right corner.
 */
type Props = {
  label?: string;
};

const { label } = Astro.props;
---

<div class="relative rounded-sm border border-black/10 bg-[#f6f4ef] p-4 dark:border-white/10 dark:bg-[#18161a]">
  {
    label && (
      <div
        class="absolute right-3 top-2 font-mono text-[10px] uppercase tracking-widest text-black/40 dark:text-white/40"
        aria-hidden="true"
      >
        {label}
      </div>
    )
  }
  <slot />
</div>
