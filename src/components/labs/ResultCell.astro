---
/**
 * Result cell — paper surface, holds one of the viz primitives. The
 * optional `header` slot anchors the headline metric inside the same
 * bordered card as the viz so the number and the picture read as one unit.
 */
---

<div
  class="rounded-sm border border-black/10 bg-[#f6f4ef] p-5 md:p-6 dark:border-white/10 dark:bg-[#18161a]"
>
  <slot name="header" />
  <slot />
</div>
