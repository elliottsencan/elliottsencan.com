---
/**
 * Stat grid — large headline numbers with mono labels above. Used for
 * dashboard-style summaries.
 */
type Props = {
  stats: { label: string; value: string }[];
};

const { stats } = Astro.props;
---

<div
  class="grid gap-x-4 gap-y-5"
  style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));"
>
  {
    stats.map((s) => (
      <div class="flex flex-col gap-1">
        <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
          {s.label}
        </span>
        <span
          class="font-heading text-3xl font-medium tracking-tight text-black dark:text-white"
          style="font-variant-numeric: tabular-nums slashed-zero;"
        >
          {s.value}
        </span>
      </div>
    ))
  }
</div>
