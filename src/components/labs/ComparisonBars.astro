---
/**
 * Comparison bars — paired horizontal bars for A/B-shaped eval cells.
 *
 * Two regions:
 *
 *   1. Top: 2-3 paired-bar rows. Each row has a label, a "with" bar, a
 *      "without" bar, and a numeric value at the far right. The bars
 *      share an axis (0..max within the row) so the visual ratio reads
 *      as the delta between cells.
 *   2. Bottom: per-sample strip. One row per sample, paired thin bars
 *      for the same A/B comparison. Sorted so the easy wins land first
 *      and the regressions land last (reveals which entries hold up
 *      under each condition and which collapse).
 *
 * The "better" hint controls accent placement — the winning side picks
 * up `text-[color:var(--accent)]`. When `single: true`, only one value
 * is shown (used for symmetric metrics like Jaccard where pairing makes
 * no sense). Format controls the value renderer.
 */

type Format = "percent" | "int" | "decimal";

type Metric = {
  label: string;
  with_priors: number;
  without_priors: number | null;
  format: Format;
  /** Which side reads as "the wanted outcome". Controls accent color. */
  better?: "higher" | "lower";
  /** Inline caption shown under the label, mono small. */
  caption?: string;
  /** When true, render only the `with_priors` value (e.g. Jaccard). */
  single?: boolean;
};

type Sample = {
  label: string;
  with_priors: number;
  without_priors: number;
};

type Props = {
  metrics: Metric[];
  samples: Sample[];
  /** Header labels for the two cells. */
  legend?: { left: string; right: string };
  /** Optional caption above the per-sample strip. */
  stripLabel?: string;
};

const {
  metrics,
  samples,
  legend = { left: "WITH PRIORS", right: "WITHOUT PRIORS" },
  stripLabel,
} = Astro.props;

function fmt(value: number | null, format: Format): string {
  if (value === null) {
    return "—";
  }
  if (format === "percent") {
    return `${(value * 100).toFixed(1)}%`;
  }
  if (format === "int") {
    return String(Math.round(value));
  }
  return value.toFixed(2);
}

function winner(m: Metric): "left" | "right" | null {
  if (m.single || m.without_priors === null || !m.better) {
    return null;
  }
  if (m.with_priors === m.without_priors) {
    return null;
  }
  const leftWins =
    m.better === "higher" ? m.with_priors > m.without_priors : m.with_priors < m.without_priors;
  return leftWins ? "left" : "right";
}

// Per-row bar scale: 0..max within the row so the visual delta matches the
// numeric delta. For percent metrics, cap at 1 so 100% reads as a full bar
// rather than getting stretched if both values are well below 1.
function rowMax(m: Metric): number {
  if (m.format === "percent") {
    return 1;
  }
  const candidates = [m.with_priors, m.without_priors ?? 0];
  return Math.max(...candidates) || 1;
}

// Stable sort for the per-sample strip: rows where the WITH cell wins most
// land first (positive delta), even rows in the middle, regressions at the
// end. Within ties, alphabetical for determinism.
const sortedSamples = [...samples].sort((a, b) => {
  const da = a.with_priors - a.without_priors;
  const db = b.with_priors - b.without_priors;
  if (db !== da) {
    return db - da;
  }
  return a.label.localeCompare(b.label);
});
---

<div class="flex flex-col gap-7">
  {/* Legend strip — quiet, just labels the two columns of bars below. */}
  <div
    class="flex items-center gap-3 font-mono text-[0.65rem] uppercase tracking-widest text-black/55 dark:text-white/55"
  >
    <span class="inline-flex items-center gap-1.5">
      <span class="inline-block h-2 w-2 rounded-sm bg-black/85 dark:bg-white/85"></span>
      {legend.left}
    </span>
    <span class="inline-flex items-center gap-1.5">
      <span
        class="inline-block h-2 w-2 rounded-sm bg-black/25 dark:bg-white/25"
      ></span>
      {legend.right}
    </span>
  </div>

  {/* Top: headline paired-bar rows. */}
  <div class="flex flex-col gap-5">
    {
      metrics.map((m) => {
        const max = rowMax(m);
        const w = (m.with_priors / max) * 100;
        const wo =
          m.without_priors === null ? 0 : (m.without_priors / max) * 100;
        const win = winner(m);
        return (
          <div class="flex flex-col gap-1.5">
            <div class="flex items-baseline justify-between gap-3">
              <span class="font-mono text-xs uppercase tracking-widest text-black/65 dark:text-white/65">
                {m.label}
              </span>
              {m.caption && (
                <span class="font-mono text-[0.65rem] tracking-wide text-black/45 dark:text-white/45">
                  {m.caption}
                </span>
              )}
            </div>

            {/* WITH row */}
            <div class="flex items-center gap-3">
              <div class="relative h-4 flex-1 bg-black/5 dark:bg-white/8">
                <div
                  class="h-full bg-black/85 dark:bg-white/85"
                  style={`width: ${w}%;`}
                />
              </div>
              <span
                class:list={[
                  "w-16 shrink-0 text-right font-mono text-xs",
                  win === "left"
                    ? "text-[color:var(--accent)]"
                    : "text-black dark:text-white",
                ]}
                style="font-variant-numeric: tabular-nums;"
              >
                {fmt(m.with_priors, m.format)}
              </span>
            </div>

            {/* WITHOUT row — omitted entirely if single */}
            {!m.single && (
              <div class="flex items-center gap-3">
                <div class="relative h-4 flex-1 bg-black/5 dark:bg-white/8">
                  <div
                    class="h-full bg-black/30 dark:bg-white/30"
                    style={`width: ${wo}%;`}
                  />
                </div>
                <span
                  class:list={[
                    "w-16 shrink-0 text-right font-mono text-xs",
                    win === "right"
                      ? "text-[color:var(--accent)]"
                      : "text-black/65 dark:text-white/65",
                  ]}
                  style="font-variant-numeric: tabular-nums;"
                >
                  {fmt(m.without_priors, m.format)}
                </span>
              </div>
            )}
          </div>
        );
      })
    }
  </div>

  {/* Bottom: per-sample strip. Two thin paired bars per row. */}
  {
    sortedSamples.length > 0 && (
      <div class="flex flex-col gap-2 border-t border-black/10 pt-5 dark:border-white/10">
        <div class="flex items-baseline justify-between">
          <span class="font-mono text-xs uppercase tracking-widest text-black/65 dark:text-white/65">
            {stripLabel ?? `Per-sample recovery (n=${sortedSamples.length})`}
          </span>
          <span class="font-mono text-[0.65rem] tracking-wide text-black/45 dark:text-white/45">
            sorted by delta, best first
          </span>
        </div>
        <div class="flex flex-col gap-1.5">
          {sortedSamples.map((s) => {
            const w = s.with_priors * 100;
            const wo = s.without_priors * 100;
            return (
              <div class="grid grid-cols-[minmax(0,1fr)_minmax(140px,1fr)_auto] items-center gap-3">
                <span
                  class="truncate font-mono text-[0.7rem] text-black/65 dark:text-white/65"
                  title={s.label}
                >
                  {s.label}
                </span>
                <div class="flex flex-col gap-0.5">
                  <div class="relative h-1.5 bg-black/5 dark:bg-white/8">
                    <div
                      class="h-full bg-black/85 dark:bg-white/85"
                      style={`width: ${w}%;`}
                    />
                  </div>
                  <div class="relative h-1.5 bg-black/5 dark:bg-white/8">
                    <div
                      class="h-full bg-black/30 dark:bg-white/30"
                      style={`width: ${wo}%;`}
                    />
                  </div>
                </div>
                <span
                  class="shrink-0 font-mono text-[0.65rem] tabular-nums text-black/55 dark:text-white/55"
                  style="font-variant-numeric: tabular-nums;"
                >
                  {Math.round(w)}/{Math.round(wo)}
                </span>
              </div>
            );
          })}
        </div>
      </div>
    )
  }
</div>
