---
/**
 * Comparison bars — paired horizontal bars for A/B-shaped eval cells.
 *
 * Two regions:
 *
 *   1. Top: paired-bar rows, one per headline metric. Each row has a
 *      fixed-width label on the left, two stacked thin bars in the
 *      middle (with-priors above, without-priors below), and the two
 *      numeric values stacked at the right. Bars share an axis (0..max
 *      within the row) so the visual ratio matches the numeric delta.
 *      The "winning" side picks up `var(--accent)` as a bar fill —
 *      same accent the rest of the site uses for forward-link badges.
 *   2. Bottom: per-sample strip. One row per sample, with a single
 *      delta bar anchored to a vertical mid-rule. Bar extends right
 *      and tints accent when priors helped, extends left and stays
 *      muted when priors hurt. The two raw recovery numbers trail at
 *      the right as small mono text — they're the receipt, not the
 *      headline. Sorted so the biggest priors-on wins land first and
 *      the regressions land last.
 *
 * Color vocabulary: bars use opacity-modulated foreground for the
 * losing/null state (`bg-black/55 dark:bg-white/40`) and `var(--accent)`
 * for the winning state. No bespoke hues — dark and light mode behavior
 * follows automatically off the existing tokens.
 */

type Format = "percent" | "int" | "decimal";

type Metric = {
  label: string;
  with_priors: number;
  without_priors: number | null;
  format: Format;
  /** Which side reads as "the wanted outcome". Controls accent placement. */
  better?: "higher" | "lower";
  /** Inline caption shown under the label, mono small. Use sparingly. */
  caption?: string;
  /** When true, render only the `with_priors` value (e.g. Jaccard). */
  single?: boolean;
};

type Sample = {
  label: string;
  with_priors: number;
  without_priors: number;
};

type Props = {
  metrics: Metric[];
  samples: Sample[];
  /** Header labels for the two cells. */
  legend?: { left: string; right: string };
  /** Optional caption above the per-sample strip. */
  stripLabel?: string;
};

const {
  metrics,
  samples,
  legend = { left: "WITH PRIORS", right: "WITHOUT PRIORS" },
  stripLabel,
} = Astro.props;

function fmt(value: number | null, format: Format): string {
  if (value === null) {
    return "—";
  }
  if (format === "percent") {
    return `${(value * 100).toFixed(1)}%`;
  }
  if (format === "int") {
    return String(Math.round(value));
  }
  return value.toFixed(2);
}

function winner(m: Metric): "left" | "right" | null {
  if (m.single || m.without_priors === null || !m.better) {
    return null;
  }
  if (m.with_priors === m.without_priors) {
    return null;
  }
  const leftWins =
    m.better === "higher" ? m.with_priors > m.without_priors : m.with_priors < m.without_priors;
  return leftWins ? "left" : "right";
}

// Per-row bar scale: 0..max within the row so the visual delta matches the
// numeric delta. For percent metrics, cap at 1 so 100% reads as a full bar
// rather than getting stretched when both values are well below 1.
function rowMax(m: Metric): number {
  if (m.format === "percent") {
    return 1;
  }
  const candidates = [m.with_priors, m.without_priors ?? 0];
  return Math.max(...candidates) || 1;
}

// Stable sort for the per-sample strip: rows where the WITH cell wins most
// land first (positive delta), regressions at the end. Within ties,
// alphabetical for determinism.
const sortedSamples = [...samples].sort((a, b) => {
  const da = a.with_priors - a.without_priors;
  const db = b.with_priors - b.without_priors;
  if (db !== da) {
    return db - da;
  }
  return a.label.localeCompare(b.label);
});

// Delta-strip geometry: max absolute delta in the sample set sets the
// scale so the largest swing fills its half. Falls back to 1 if every
// sample is a no-op.
const maxAbsDelta =
  sortedSamples.reduce(
    (acc, s) => Math.max(acc, Math.abs(s.with_priors - s.without_priors)),
    0,
  ) || 1;
---

<div class="flex flex-col gap-8">
  {/* Legend strip — quiet, just labels the two columns of bars below. */}
  <div
    class="flex items-center gap-4 font-mono text-[0.65rem] uppercase tracking-widest text-black/55 dark:text-white/55"
  >
    <span class="inline-flex items-center gap-1.5">
      <span class="inline-block h-2 w-2 rounded-sm bg-[color:var(--accent)]"></span>
      {legend.left}
    </span>
    <span class="inline-flex items-center gap-1.5">
      <span
        class="inline-block h-2 w-2 rounded-sm bg-black/55 dark:bg-white/40"
      ></span>
      {legend.right}
    </span>
  </div>

  {/* Top: headline paired-bar rows. Consistent label width, consistent bar
      geometry — reads as one hierarchical block, not three loose rows. */}
  <div class="flex flex-col gap-5">
    {
      metrics.map((m) => {
        const max = rowMax(m);
        const w = (m.with_priors / max) * 100;
        const wo =
          m.without_priors === null ? 0 : (m.without_priors / max) * 100;
        const win = winner(m);
        const leftWins = win === "left";
        const rightWins = win === "right";
        return (
          <div class="grid grid-cols-[10rem_minmax(0,1fr)_4.5rem] items-center gap-4">
            <div class="flex flex-col gap-0.5">
              <span class="font-mono text-xs uppercase tracking-widest text-black/65 dark:text-white/65">
                {m.label}
              </span>
              {m.caption && (
                <span class="font-mono text-[0.65rem] tracking-wide text-black/45 dark:text-white/45">
                  {m.caption}
                </span>
              )}
            </div>

            <div class="flex flex-col gap-1">
              {/* WITH row */}
              <div class="relative h-2.5 bg-black/5 dark:bg-white/8">
                <div
                  class:list={[
                    "h-full",
                    leftWins
                      ? "bg-[color:var(--accent)]"
                      : "bg-black/55 dark:bg-white/40",
                  ]}
                  style={`width: ${w}%;`}
                />
              </div>
              {/* WITHOUT row — omitted entirely if single */}
              {!m.single && (
                <div class="relative h-2.5 bg-black/5 dark:bg-white/8">
                  <div
                    class:list={[
                      "h-full",
                      rightWins
                        ? "bg-[color:var(--accent)]"
                        : "bg-black/55 dark:bg-white/40",
                    ]}
                    style={`width: ${wo}%;`}
                  />
                </div>
              )}
            </div>

            <div class="flex flex-col gap-1 text-right font-mono text-xs tabular-nums">
              <span
                class:list={[
                  leftWins
                    ? "text-[color:var(--accent)]"
                    : "text-black dark:text-white",
                ]}
                style="font-variant-numeric: tabular-nums;"
              >
                {fmt(m.with_priors, m.format)}
              </span>
              {!m.single && (
                <span
                  class:list={[
                    rightWins
                      ? "text-[color:var(--accent)]"
                      : "text-black/55 dark:text-white/55",
                  ]}
                  style="font-variant-numeric: tabular-nums;"
                >
                  {fmt(m.without_priors, m.format)}
                </span>
              )}
            </div>
          </div>
        );
      })
    }
  </div>

  {/* Bottom: per-sample delta strip. Single bar anchored to a vertical
      mid-rule. Right = priors helped (accent); left = priors hurt (muted).
      The two raw recovery numbers trail as small mono text. */}
  {
    sortedSamples.length > 0 && (
      <div class="flex flex-col gap-3 border-t border-black/10 pt-6 dark:border-white/10">
        <div class="flex items-baseline justify-between gap-3">
          <span class="font-mono text-xs uppercase tracking-widest text-black/65 dark:text-white/65">
            {stripLabel ?? `Per-sample recovery (n=${sortedSamples.length})`}
          </span>
          <span class="font-mono text-[0.65rem] uppercase tracking-widest text-black/45 dark:text-white/45">
            delta · on − off
          </span>
        </div>
        <div class="flex flex-col gap-1">
          {sortedSamples.map((s) => {
            const delta = s.with_priors - s.without_priors;
            const magnitude = (Math.abs(delta) / maxAbsDelta) * 50; // %, half-track
            const helped = delta > 0;
            const neutral = delta === 0;
            return (
              <div class="grid grid-cols-[minmax(0,1fr)_minmax(120px,200px)_5rem] items-center gap-4">
                <span
                  class="truncate font-mono text-[0.7rem] text-black/65 dark:text-white/65"
                  title={s.label}
                >
                  {s.label}
                </span>
                {/* Delta bar — vertical mid-rule, bar extends from center. */}
                <div class="relative h-2">
                  {/* mid-rule */}
                  <div class="absolute inset-y-0 left-1/2 w-px bg-black/20 dark:bg-white/20" />
                  {!neutral && (
                    <div
                      class:list={[
                        "absolute top-0 h-full",
                        helped
                          ? "bg-[color:var(--accent)]"
                          : "bg-black/55 dark:bg-white/40",
                      ]}
                      style={
                        helped
                          ? `left: 50%; width: ${magnitude}%;`
                          : `right: 50%; width: ${magnitude}%;`
                      }
                    />
                  )}
                </div>
                <span
                  class="text-right font-mono text-[0.65rem] tabular-nums text-black/55 dark:text-white/55"
                  style="font-variant-numeric: tabular-nums;"
                >
                  {Math.round(s.with_priors * 100)}
                  <span class="text-black/30 dark:text-white/30"> / </span>
                  {Math.round(s.without_priors * 100)}
                </span>
              </div>
            );
          })}
        </div>
      </div>
    )
  }
</div>
