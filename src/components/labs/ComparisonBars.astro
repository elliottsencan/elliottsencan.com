---
/**
 * Comparison cell — A/B-shaped headline metrics + a per-sample strip.
 *
 * Three regions, top to bottom:
 *
 *   1. Slope chart for paired percent metrics (one line per metric,
 *      "without" → "with", accent slope = improvement). Reads the
 *      directional bet of the A/B at a glance — does the change move
 *      the needle the right way.
 *
 *   2. Stat-tile callouts for non-slope-friendly metrics: integer counts
 *      (e.g. distinct tags), single-sided values (e.g. Jaccard).
 *      Same hierarchy as the cell's headline number on the labs index,
 *      so the eye reads "supporting numbers" not "secondary chart."
 *
 *   3. Per-sample diverging strip: one row per sample, single bar
 *      anchored to a vertical mid-rule. Right = priors helped (accent);
 *      left = priors hurt (muted). Sorted biggest wins first.
 *
 * Mobile-first: every region is a single flex column at base; the
 * grid layouts only kick in at `md:`. The slope chart and diverging
 * strip both render through SVG/percent-width, so they fluid down to
 * a phone viewport without horizontal scroll.
 */
import SlopeChart, { type SlopeRow } from "./SlopeChart.astro";

type Format = "percent" | "int" | "decimal";

type Metric = {
  label: string;
  with_priors: number;
  without_priors: number | null;
  format: Format;
  better?: "higher" | "lower";
  caption?: string;
  single?: boolean;
};

type Sample = {
  label: string;
  with_priors: number;
  without_priors: number;
};

type Props = {
  metrics: Metric[];
  samples: Sample[];
  legend?: { left: string; right: string };
  stripLabel?: string;
};

const {
  metrics,
  samples,
  legend = { left: "without priors", right: "with priors" },
  stripLabel,
} = Astro.props;

function fmt(value: number | null, format: Format): string {
  if (value === null) {
    return "—";
  }
  if (format === "percent") {
    return `${(value * 100).toFixed(1)}%`;
  }
  if (format === "int") {
    return String(Math.round(value));
  }
  return value.toFixed(2);
}

// Slope-eligible: percent metrics with both a `with` and `without` value.
// Everything else falls through to the callout row.
const slopeMetrics: Metric[] = metrics.filter(
  (m) => m.format === "percent" && !m.single && m.without_priors !== null,
);
const calloutMetrics: Metric[] = metrics.filter((m) => !slopeMetrics.includes(m));

const slopeRows: SlopeRow[] = slopeMetrics.map((m) => ({
  label: m.label,
  from: m.without_priors as number,
  to: m.with_priors,
  format: m.format,
  better: m.better ?? "higher",
}));

// Per-sample sort: biggest priors-on wins land first. Ties → alpha.
const sortedSamples = [...samples].sort((a, b) => {
  const da = a.with_priors - a.without_priors;
  const db = b.with_priors - b.without_priors;
  if (db !== da) {
    return db - da;
  }
  return a.label.localeCompare(b.label);
});

const maxAbsDelta =
  sortedSamples.reduce((acc, s) => Math.max(acc, Math.abs(s.with_priors - s.without_priors)), 0) ||
  1;

// Callout helpers: render a count metric as "32 vs 53" with a tone hint
// in the smaller number.
function calloutSecondary(m: Metric): string | null {
  if (m.single || m.without_priors === null) {
    return null;
  }
  return fmt(m.without_priors, m.format);
}
function calloutAccent(m: Metric): boolean {
  if (m.single || m.without_priors === null || !m.better) {
    return false;
  }
  return m.better === "higher"
    ? m.with_priors > m.without_priors
    : m.with_priors < m.without_priors;
}
---

<div class="flex flex-col gap-8 md:gap-10">
  {/* ── Region 1 + 2: slope chart + callouts, side-by-side on md+, stacked below ── */}
  {(slopeRows.length > 0 || calloutMetrics.length > 0) && (
    <div class="grid grid-cols-1 gap-6 md:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)] md:gap-10">
      {slopeRows.length > 0 ? (
        <div class="flex flex-col gap-3">
          <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
            Headline · {legend.left} → {legend.right}
          </span>
          <SlopeChart
            rows={slopeRows}
            leftLabel={legend.left}
            rightLabel={legend.right}
            height={Math.max(160, slopeRows.length * 56)}
          />
        </div>
      ) : <div></div>}

      {calloutMetrics.length > 0 && (
        <div class="flex flex-col gap-5">
          {calloutMetrics.map((m) => {
            const accent = calloutAccent(m);
            const secondary = calloutSecondary(m);
            return (
              <div class="flex flex-col gap-1.5">
                <span class="font-mono text-xs uppercase tracking-widest text-black/55 dark:text-white/55">
                  {m.label}
                </span>
                <div class="flex flex-wrap items-baseline gap-3">
                  <span
                    class:list={[
                      "font-heading text-3xl font-normal tracking-tight tabular-nums md:text-[2.1rem]",
                      accent ? "text-[color:var(--accent)]" : "text-black dark:text-white",
                    ]}
                    style="font-variant-numeric: tabular-nums;"
                  >
                    {fmt(m.with_priors, m.format)}
                  </span>
                  {secondary && (
                    <span class="font-mono text-sm text-black/55 dark:text-white/55">
                      vs <span class="tabular-nums" style="font-variant-numeric: tabular-nums;">{secondary}</span>
                    </span>
                  )}
                </div>
                {m.caption && (
                  <span class="font-mono text-[0.7rem] text-black/55 dark:text-white/55">
                    {m.caption}
                  </span>
                )}
              </div>
            );
          })}
        </div>
      )}
    </div>
  )}

  {/* ── Region 3: per-sample diverging strip. Already mobile-friendly —
        labels truncate, the strip width stays bounded by the column. ── */}
  {sortedSamples.length > 0 && (
    <div class="flex flex-col gap-3 border-t border-black/10 pt-6 dark:border-white/10">
      <div class="flex items-baseline justify-between gap-3">
        <span class="font-mono text-xs uppercase tracking-widest text-black/65 dark:text-white/65">
          {stripLabel ?? `Per-sample · n=${sortedSamples.length}`}
        </span>
        <span class="hidden font-mono text-[0.65rem] uppercase tracking-widest text-black/45 sm:inline dark:text-white/45">
          ← priors hurt · priors helped →
        </span>
      </div>
      <div class="flex flex-col gap-1">
        {sortedSamples.map((s) => {
          const delta = s.with_priors - s.without_priors;
          const magnitude = (Math.abs(delta) / maxAbsDelta) * 50;
          const helped = delta > 0;
          const neutral = delta === 0;
          return (
            <div class="grid grid-cols-[minmax(0,1fr)_minmax(100px,200px)_4.5rem] items-center gap-3 md:grid-cols-[minmax(0,1fr)_minmax(140px,260px)_5rem] md:gap-4">
              <span
                class="truncate font-mono text-[0.7rem] text-black/65 dark:text-white/65"
                title={s.label}
              >
                {s.label}
              </span>
              <div class="relative h-2">
                <div class="absolute inset-y-0 left-1/2 w-px bg-black/20 dark:bg-white/20" />
                {!neutral && (
                  <div
                    class:list={[
                      "absolute top-0 h-full",
                      helped
                        ? "bg-[color:var(--accent)]"
                        : "bg-black/55 dark:bg-white/40",
                    ]}
                    style={
                      helped
                        ? `left: 50%; width: ${magnitude}%;`
                        : `right: 50%; width: ${magnitude}%;`
                    }
                  />
                )}
              </div>
              <span
                class="text-right font-mono text-[0.65rem] tabular-nums text-black/55 dark:text-white/55"
                style="font-variant-numeric: tabular-nums;"
              >
                {Math.round(s.with_priors * 100)}
                <span class="text-black/30 dark:text-white/30"> / </span>
                {Math.round(s.without_priors * 100)}
              </span>
            </div>
          );
        })}
      </div>
    </div>
  )}
</div>
