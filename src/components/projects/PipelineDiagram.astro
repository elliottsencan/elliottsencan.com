---
/**
 * Architecture diagram for the wiki synthesis pipeline.
 *
 * Hand-authored inline SVG. No external image, no SVG library. Renders the
 * flow from raw URLs through the worker endpoints into the labs sidecars.
 * Uses `currentColor` so the strokes and fills follow the prose color in
 * both light and dark themes.
 */
---

<figure class="my-10 not-prose">
  <svg
    viewBox="0 0 720 760"
    role="img"
    aria-labelledby="pipelineTitle pipelineDesc"
    class="block w-full max-w-[720px] mx-auto text-black/85 dark:text-white/85"
  >
    <title id="pipelineTitle">Wiki synthesis pipeline data flow</title>
    <desc id="pipelineDesc">
      Reading sources flow through the /link endpoint into per-source markdown
      entries, are clustered by topic into wiki articles by /synthesize, and
      measured by /eval into labs sidecar JSON consumed by labs cells.
    </desc>

    <defs>
      <marker
        id="arrow"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
      </marker>
    </defs>

    <!-- 1. Reading sources -->
    <g transform="translate(220, 20)">
      <rect width="280" height="56" rx="2" ry="2" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3" />
      <text x="140" y="26" text-anchor="middle" font-family="var(--font-heading), sans-serif" font-size="14" font-weight="500" fill="currentColor">Reading sources</text>
      <text x="140" y="44" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="11" fill="currentColor" opacity="0.6">URLs saved via iOS Shortcut</text>
    </g>

    <!-- arrow 1 -->
    <line x1="360" y1="76" x2="360" y2="110" stroke="currentColor" stroke-width="1" marker-end="url(#arrow)" />
    <text x="370" y="98" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.6">POST</text>

    <!-- 2. /link endpoint -->
    <g transform="translate(260, 110)">
      <rect width="200" height="44" rx="2" ry="2" fill="none" stroke="currentColor" stroke-width="1.5" />
      <text x="100" y="20" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="13" font-weight="500" fill="currentColor">/link</text>
      <text x="100" y="34" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.6">fetch + summarize</text>
    </g>

    <!-- arrow 2 -->
    <line x1="360" y1="154" x2="360" y2="188" stroke="currentColor" stroke-width="1" marker-end="url(#arrow)" />
    <text x="370" y="176" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.6">commit</text>

    <!-- 3. reading entry + topics sidecar -->
    <g transform="translate(220, 188)">
      <rect width="280" height="56" rx="2" ry="2" fill="none" stroke="currentColor" stroke-width="1" />
      <text x="140" y="26" text-anchor="middle" font-family="var(--font-heading), sans-serif" font-size="14" font-weight="500" fill="currentColor">reading entry</text>
      <text x="140" y="44" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="11" fill="currentColor" opacity="0.6">src/content/reading/&lt;slug&gt;.md</text>
    </g>

    <!-- topics sidecar callout -->
    <line x1="500" y1="216" x2="560" y2="216" stroke="currentColor" stroke-width="1" stroke-dasharray="2 3" />
    <text x="568" y="213" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.7">topics[]</text>
    <text x="568" y="225" font-family="var(--font-mono), monospace" font-size="9" fill="currentColor" opacity="0.55">stable slugs</text>

    <!-- arrow 3 -->
    <line x1="360" y1="244" x2="360" y2="278" stroke="currentColor" stroke-width="1" marker-end="url(#arrow)" />
    <text x="370" y="266" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.6">cluster by topic</text>

    <!-- 4. /synthesize endpoint -->
    <g transform="translate(260, 278)">
      <rect width="200" height="44" rx="2" ry="2" fill="none" stroke="currentColor" stroke-width="1.5" />
      <text x="100" y="20" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="13" font-weight="500" fill="currentColor">/synthesize</text>
      <text x="100" y="34" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.6">≥ MIN_WIKI_SOURCES</text>
    </g>

    <!-- arrow 4 -->
    <line x1="360" y1="322" x2="360" y2="356" stroke="currentColor" stroke-width="1" marker-end="url(#arrow)" />
    <text x="370" y="344" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.6">commit</text>

    <!-- 5. wiki article -->
    <g transform="translate(220, 356)">
      <rect width="280" height="56" rx="2" ry="2" fill="none" stroke="currentColor" stroke-width="1" />
      <text x="140" y="26" text-anchor="middle" font-family="var(--font-heading), sans-serif" font-size="14" font-weight="500" fill="currentColor">wiki article</text>
      <text x="140" y="44" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="11" fill="currentColor" opacity="0.6">src/content/wiki/&lt;slug&gt;.md</text>
    </g>

    <!-- crosslink phase callout -->
    <line x1="220" y1="384" x2="160" y2="384" stroke="currentColor" stroke-width="1" stroke-dasharray="2 3" />
    <text x="152" y="381" text-anchor="end" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.7">crosslink</text>
    <text x="152" y="393" text-anchor="end" font-family="var(--font-mono), monospace" font-size="9" fill="currentColor" opacity="0.55">waitUntil follow-up</text>

    <!-- arrow 5 -->
    <line x1="360" y1="412" x2="360" y2="446" stroke="currentColor" stroke-width="1" marker-end="url(#arrow)" />
    <text x="370" y="434" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.6">measure</text>

    <!-- 6. /eval endpoint -->
    <g transform="translate(260, 446)">
      <rect width="200" height="44" rx="2" ry="2" fill="none" stroke="currentColor" stroke-width="1.5" />
      <text x="100" y="20" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="13" font-weight="500" fill="currentColor">/eval</text>
      <text x="100" y="34" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.6">tiers 0 through 5</text>
    </g>

    <!-- arrow 6 -->
    <line x1="360" y1="490" x2="360" y2="524" stroke="currentColor" stroke-width="1" marker-end="url(#arrow)" />
    <text x="370" y="512" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.6">write</text>

    <!-- 7. labs sidecars -->
    <g transform="translate(220, 524)">
      <rect width="280" height="56" rx="2" ry="2" fill="none" stroke="currentColor" stroke-width="1" />
      <text x="140" y="26" text-anchor="middle" font-family="var(--font-heading), sans-serif" font-size="14" font-weight="500" fill="currentColor">labs sidecars</text>
      <text x="140" y="44" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="11" fill="currentColor" opacity="0.6">src/content/labs/data/*.json</text>
    </g>

    <!-- arrow 7 -->
    <line x1="360" y1="580" x2="360" y2="614" stroke="currentColor" stroke-width="1" marker-end="url(#arrow)" />
    <text x="370" y="602" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.6">read at build</text>

    <!-- 8. labs cells -->
    <g transform="translate(220, 614)">
      <rect width="280" height="56" rx="2" ry="2" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3" />
      <text x="140" y="26" text-anchor="middle" font-family="var(--font-heading), sans-serif" font-size="14" font-weight="500" fill="currentColor">labs cells</text>
      <text x="140" y="44" text-anchor="middle" font-family="var(--font-mono), monospace" font-size="11" fill="currentColor" opacity="0.6">/labs/&lt;slug&gt;</text>
    </g>

    <!-- legend -->
    <g transform="translate(40, 700)">
      <rect width="36" height="14" rx="1" ry="1" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3" />
      <text x="44" y="11" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.7">surface</text>

      <rect x="120" width="36" height="14" rx="1" ry="1" fill="none" stroke="currentColor" stroke-width="1" />
      <text x="164" y="11" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.7">artifact</text>

      <rect x="240" width="36" height="14" rx="1" ry="1" fill="none" stroke="currentColor" stroke-width="1.5" />
      <text x="284" y="11" font-family="var(--font-mono), monospace" font-size="10" fill="currentColor" opacity="0.7">worker endpoint</text>
    </g>
  </svg>
  <figcaption class="mt-3 text-center font-mono text-xs text-black/55 dark:text-white/55">
    Pipeline data flow. Endpoints run in workers/site-ingest; artifacts land in src/content.
  </figcaption>
</figure>
