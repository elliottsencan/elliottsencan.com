---
import Search from "astro-pagefind/components/Search";
---

<aside data-pagefind-ignore>
  <div
    transition:persist
    id="backdrop"
    class="pointer-events-none fixed inset-0 z-50 overflow-y-auto bg-black/50 p-4 opacity-0 transition-opacity duration-200 ease-out sm:p-6 md:p-20"
  >
    <div
      id="pagefind-container"
      class="mx-auto max-w-2xl overflow-hidden rounded-md border border-black/10 bg-[#f6f4ef] opacity-0 shadow-lg transition-opacity duration-150 ease-in dark:border-white/15 dark:bg-[#18161a]"
    >
      <Search
        id="search"
        className="pagefind-ui"
        uiOptions={{
          showImages: false,
          excerptLength: 30,
          resetStyles: false,
          showSubResults: true,
          translations: {
            placeholder: "Search writing, projects, about\u2026",
            zero_results: "No matches. Try a different keyword.",
          },
        }}
      />
    </div>
  </div>
</aside>

<script is:inline>
  (function () {
    var isMac =
      navigator.platform?.toUpperCase().startsWith("MAC") ||
      navigator.userAgentData?.platform?.toUpperCase().startsWith("MAC") ||
      false;
    var el = document.getElementById("search-shortcut");
    if (el) el.textContent = isMac ? "\u2318K" : "Ctrl+K";
  })();
</script>

<script is:inline>
  var magnifyingGlass = document.getElementById("magnifying-glass");
  var backdrop = document.getElementById("backdrop");
  var pagefindContainer = document.getElementById("pagefind-container");

  function openPagefind() {
    var searchDiv = document.getElementById("search");
    var search = searchDiv.querySelector("input");
    setTimeout(function () {
      search.focus();
    }, 0);
    backdrop?.classList.remove("opacity-0", "pointer-events-none");
    backdrop?.classList.add("opacity-100", "pointer-events-auto");
    pagefindContainer?.classList.remove("opacity-0");
    pagefindContainer?.classList.add("opacity-100");
  }

  function closePagefind() {
    var search = document.getElementById("search");
    search.value = "";
    pagefindContainer?.classList.add("opacity-0");
    pagefindContainer?.classList.remove("opacity-100");
    backdrop?.classList.add("opacity-0", "pointer-events-none");
    backdrop?.classList.remove("opacity-100", "pointer-events-auto");
  }

  // open pagefind
  magnifyingGlass?.addEventListener("click", function () {
    openPagefind();
  });

  document.addEventListener("keydown", function (e) {
    if (e.key === "/") {
      e.preventDefault();
      openPagefind();
    } else if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      openPagefind();
    }
  });

  // close pagefind
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") {
      closePagefind();
    }
  });

  // close pagefind when searched result(link) clicked
  document.addEventListener("click", function (event) {
    if (event.target.classList.contains("pagefind-ui__result-link")) {
      closePagefind();
    }
  });

  backdrop?.addEventListener("click", function (event) {
    if (!event.target.closest("#pagefind-container")) {
      closePagefind();
    }
  });
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.8;
    --pagefind-ui-border-width: 0;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: "Satoshi", sans-serif;
    --pagefind-ui-primary: #111827;
    --pagefind-ui-text: #374151;
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: transparent;
    --pagefind-ui-tag: #f3f4f6;
  }

  .dark {
    --pagefind-ui-primary: #d4d4d4;
    --pagefind-ui-text: #d4d4d4;
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: transparent;
  }

  /* Editorial prompt treatment: heading font, larger type, hairline rule.
     The input is the palette's centerpiece — it should read as a small
     editorial moment ("Search writing, projects, about…") rather than a
     form field. Border color matches the canvas hairlines used elsewhere. */
  #search .pagefind-ui__search-input {
    font-family: "Neue Montreal", "Satoshi", ui-sans-serif, system-ui, sans-serif;
    font-weight: 500;
    height: 3.5rem;
    padding-left: 2.75rem;
    background-color: transparent;
    border: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 0;
    outline: none;
    font-size: 1.125rem;
  }

  .dark #search .pagefind-ui__search-input {
    border-bottom-color: rgba(255, 255, 255, 0.15);
  }

  #search .pagefind-ui__search-clear {
    top: calc(50% - 12px);
  }

  /* Magnifying glass pseudo-element sits to the left of the input. Vertically
     center it inside the 3.5rem input (1.75rem midline, minus ~half icon). */
  #search .pagefind-ui__form::before {
    top: calc(1.75rem - 9px);
    left: 1rem;
    opacity: 0.4;
  }

  #search .pagefind-ui__results-area {
    padding: 0.5rem 1rem 1rem;
    max-height: min(60vh, 32rem);
    overflow-y: auto;
  }

  #search p {
    font-weight: normal;
  }

  #search .pagefind-ui__result-title {
    font-weight: 600;
  }

  #search .pagefind-ui__message {
    padding: 0.5rem 1rem;
    padding-bottom: 0.75rem;
  }

  /* Filter chips — Pagefind renders these automatically when the index
     contains data-pagefind-filter values. Align with the existing tag
     palette and the modal's spacing. */
  #search .pagefind-ui__filter-panel {
    padding: 0.25rem 1rem 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  #search .pagefind-ui__filter-block {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  #search .pagefind-ui__filter-name,
  #search .pagefind-ui__filter-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(0, 0, 0, 0.55);
  }

  .dark #search .pagefind-ui__filter-name,
  .dark #search .pagefind-ui__filter-label {
    color: rgba(255, 255, 255, 0.55);
  }

</style>
