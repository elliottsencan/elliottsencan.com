---
/**
 * Layout wrapper for a blog post. Takes a single content-collection entry and
 * derives every SEO/OpenGraph/JSON-LD field from its frontmatter, so the page
 * itself only supplies body content.
 *
 * Falls back to the dynamically generated OG image (/og/writing/{id}.png) when
 * the post frontmatter doesn't specify one explicitly.
 */
import type { CollectionEntry } from "astro:content";
import Layout from "@layouts/Layout.astro";

type Props = {
  post: CollectionEntry<"blog">;
};

const { post } = Astro.props;
const ogImage = post.data.image ?? `/og/writing/${post.id}.png`;
---

<Layout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  schemaType="BlogPosting"
  publishedTime={post.data.date}
  updatedTime={post.data.updated}
  tags={post.data.tags}
  canonical={post.data.canonical}
  image={ogImage}
>
  <slot />
</Layout>
