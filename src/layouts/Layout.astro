---
import Footer from "@components/Footer.astro";
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";

type Props = {
  title: string;
  description: string;
  image?: string;
  ogType?: "website" | "article";
  canonical?: string | URL;
  publishedTime?: Date;
  updatedTime?: Date;
  tags?: string[];
  author?: string;
  schemaType?: "BlogPosting" | "Article";
  includePersonSchema?: boolean;
};

const { title, description, ...headProps } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} {...headProps} />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:shadow-lg dark:focus:bg-neutral-900">
      Skip to content
    </a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Global search shortcut. Cmd/Ctrl+K and bare `/` jump to /search; on
      // /search itself they refocus the input so the shortcut stays harmless.
      // Editable targets keep `/` for typing — modifier keys are still active
      // because Cmd+K should always work.
      (function () {
        function isEditable(target) {
          if (!(target instanceof HTMLElement)) return false;
          const tag = target.tagName;
          return (
            tag === "INPUT" || tag === "TEXTAREA" || target.isContentEditable
          );
        }
        function focusSearchInput() {
          const host = document.getElementById("search");
          const input = host && host.querySelector("input");
          if (input) {
            input.focus();
            return true;
          }
          return false;
        }
        document.addEventListener("keydown", function (e) {
          const isCmdK = (e.metaKey || e.ctrlKey) && e.key === "k";
          const isSlash = e.key === "/" && !isEditable(e.target);
          if (!isCmdK && !isSlash) return;
          e.preventDefault();
          if (window.location.pathname === "/search") {
            focusSearchInput();
          } else {
            window.location.href = "/search";
          }
        });
      })();
    </script>
    <script>
      // Cursor-following halo for every `.dot-rule` on the page.
      //
      // Each rule carries a base dot layer (::before) and an overlay
      // (::after) that's masked by a radial-gradient centered at
      // `--pointer-x`. The overlay's visibility is driven by `:hover` in
      // global.css, which also owns the enter/exit opacity transitions.
      // This script's only job is to pipe the cursor's page-local x into
      // the CSS variable so the mask tracks horizontal movement.
      //
      // We deliberately do NOT reset `--pointer-x` on mouseleave: the
      // hover state dropping triggers the exit fade, and leaving
      // `--pointer-x` at the last value lets the halo fade IN PLACE
      // rather than snapping offscreen. The next mouseenter's first
      // mousemove overwrites it within a frame.
      //
      // Reduced-motion users never see the overlay because global.css
      // sets `display: none` on ::after.
      function initDotRule(el: Element) {
        const host = el as HTMLElement;
        let frame = 0;
        let latestX = 0;

        function apply() {
          frame = 0;
          host.style.setProperty("--pointer-x", `${latestX}px`);
        }

        // Prime `--pointer-x` synchronously on enter so the first frame
        // of the opacity fade-in already has the mask at the cursor,
        // avoiding a 16ms lag where the halo could appear at a stale X.
        host.addEventListener("mouseenter", (event) => {
          const rect = host.getBoundingClientRect();
          host.style.setProperty(
            "--pointer-x",
            `${event.clientX - rect.left}px`,
          );
        });

        host.addEventListener("mousemove", (event) => {
          const rect = host.getBoundingClientRect();
          latestX = event.clientX - rect.left;
          if (frame === 0) {
            frame = requestAnimationFrame(apply);
          }
        });

        host.addEventListener("mouseleave", () => {
          if (frame !== 0) {
            cancelAnimationFrame(frame);
            frame = 0;
          }
        });
      }

      function setup() {
        document.querySelectorAll(".dot-rule").forEach(initDotRule);
      }

      setup();
    </script>
  </body>
</html>
