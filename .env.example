# Worker admin CLI (scripts/worker.mjs)
SITE_INGEST_API_TOKEN=
# Optional override; defaults to deployed worker
# SITE_INGEST_BASE_URL=https://site-ingest.<account>.workers.dev

# Optional GitHub PAT used at site build time for the contributions rail.
# Classic PAT with `public_repo` + `read:user`, or fine-grained equivalent.
# Without it, the GitHub blocks degrade to null and the build still succeeds.
# GITHUB_TOKEN=
